<Window x:Class="ShareQ.Editor.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color picker"
        Width="500" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252525"
        Foreground="White">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,8,8" ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#DDDDDD">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#888888">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Padding" Value="2" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SV square -->
        <Border Grid.Row="0" Grid.Column="0"
                BorderBrush="#555" BorderThickness="1"
                ClipToBounds="True">
            <Grid x:Name="SvHost"
                  Background="Black"
                  MouseLeftButtonDown="OnSvMouseDown"
                  MouseMove="OnSvMouseMove"
                  MouseLeftButtonUp="OnSvMouseUp">
                <!-- Hue base -->
                <Rectangle x:Name="SvHueRect" />
                <!-- White overlay (saturation): white→transparent left to right -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="White" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Black overlay (value): transparent→black top to bottom -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#00000000" Offset="0" />
                            <GradientStop Color="Black" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Cursor (small circle) -->
                <Canvas IsHitTestVisible="False">
                    <Ellipse x:Name="SvCursor"
                             Width="12" Height="12"
                             Stroke="White" StrokeThickness="2"
                             Fill="Transparent" />
                </Canvas>
            </Grid>
        </Border>

        <!-- Hue strip -->
        <Border Grid.Row="0" Grid.Column="1"
                Margin="6,0,6,0"
                BorderBrush="#555" BorderThickness="1"
                ClipToBounds="True">
            <Grid x:Name="HueHost"
                  MouseLeftButtonDown="OnHueMouseDown"
                  MouseMove="OnHueMouseMove"
                  MouseLeftButtonUp="OnHueMouseUp">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FF0000" Offset="0.000" />
                            <GradientStop Color="#FFFF00" Offset="0.167" />
                            <GradientStop Color="#00FF00" Offset="0.333" />
                            <GradientStop Color="#00FFFF" Offset="0.500" />
                            <GradientStop Color="#0000FF" Offset="0.667" />
                            <GradientStop Color="#FF00FF" Offset="0.833" />
                            <GradientStop Color="#FF0000" Offset="1.000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas IsHitTestVisible="False">
                    <Rectangle x:Name="HueCursor"
                               Width="32" Height="3"
                               Stroke="White" StrokeThickness="1.5"
                               Fill="#80FFFFFF" />
                </Canvas>
            </Grid>
        </Border>

        <!-- Sliders + numeric inputs -->
        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,0">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="H" />
                <Slider Grid.Column="1" x:Name="HSlider" Minimum="0" Maximum="360" />
                <TextBox Grid.Column="2" x:Name="HBox" Margin="4,0,0,0" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="S" />
                <Slider Grid.Column="1" x:Name="SSlider" Minimum="0" Maximum="100" />
                <TextBox Grid.Column="2" x:Name="SBox" Margin="4,0,0,0" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="V" />
                <Slider Grid.Column="1" x:Name="VSlider" Minimum="0" Maximum="100" />
                <TextBox Grid.Column="2" x:Name="VBox" Margin="4,0,0,0" />
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="R" />
                <Slider Grid.Column="1" x:Name="RSlider" Minimum="0" Maximum="255" />
                <TextBox Grid.Column="2" x:Name="RBox" Margin="4,0,0,0" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="G" />
                <Slider Grid.Column="1" x:Name="GSlider" Minimum="0" Maximum="255" />
                <TextBox Grid.Column="2" x:Name="GBox" Margin="4,0,0,0" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="B" />
                <Slider Grid.Column="1" x:Name="BSlider" Minimum="0" Maximum="255" />
                <TextBox Grid.Column="2" x:Name="BBox" Margin="4,0,0,0" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="A" />
                <Slider Grid.Column="1" x:Name="ASlider" Minimum="0" Maximum="255" />
                <TextBox Grid.Column="2" x:Name="ABox" Margin="4,0,0,0" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Hex" />
                    <TextBox Grid.Column="1" x:Name="HexBox" />
                </Grid>
                <Border Grid.Column="1" Width="48" Height="28" Margin="6,0,0,0"
                        BorderBrush="#555" BorderThickness="1"
                        Background="{StaticResource CheckerBrush}">
                    <Border>
                        <Border.Background>
                            <SolidColorBrush x:Name="PreviewBrush" />
                        </Border.Background>
                    </Border>
                </Border>
            </Grid>
        </StackPanel>

        <!-- Bottom action bar -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="EyedropperBtn"
                    Content="Eyedropper" Padding="10,4"
                    Click="OnEyedropperClicked" />
            <Button Grid.Column="2" Content="OK" Width="80" Margin="0,0,4,0"
                    IsDefault="True" Click="OnOkClicked" />
            <Button Grid.Column="3" Content="Cancel" Width="80"
                    IsCancel="True" Click="OnCancelClicked" />
        </Grid>
    </Grid>
</Window>
