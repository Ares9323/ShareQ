<Window x:Class="ShareQ.Editor.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ShareQ.Editor.Views"
        Title="Color picker"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252525"
        Foreground="White">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,8,8" ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#DDDDDD">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#888888">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Padding" Value="2" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ╭──────── LEFT: H×S colour wheel ────────╮ -->
        <local:ColorWheelControl Grid.Row="0" Grid.Column="0" x:Name="ColorWheel" />

        <!-- ╭──────── RIGHT: top → bottom: preview, HSB, RGB/CMYK tab, alpha, hex+dec inline,
                                  palette ────────╮ -->
        <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
            <!-- Preview + sRGB + Eyedropper -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="120" Height="60"
                        BorderBrush="#555" BorderThickness="1"
                        Background="{StaticResource CheckerBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0">
                            <Border.Background>
                                <SolidColorBrush x:Name="OriginalPreviewBrush" />
                            </Border.Background>
                        </Border>
                        <Border Grid.Row="1">
                            <Border.Background>
                                <SolidColorBrush x:Name="NewPreviewBrush" />
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                    <CheckBox x:Name="SrgbToggle" Content="sRGB Preview" IsChecked="True"
                              Foreground="White" Margin="0,0,0,6"
                              ToolTip="Apply sRGB gamma to the preview swatches. Disable to see colors interpreted as linear (closer to how renderers like Unreal treat texture pixels)." />
                    <ui:Button Content="🔍 Eyedropper" HorizontalAlignment="Left"
                               Click="OnEyedropperClicked"
                               ToolTip="Sample a pixel from anywhere on screen" />
                </StackPanel>
            </Grid>

            <!-- HSB always visible -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="H" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="HSlider" Minimum="0" Maximum="360" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="HBox" />
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="S" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="SSlider" Minimum="0" Maximum="100" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="SBox" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="B" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="VSlider" Minimum="0" Maximum="100" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="VBox" />
            </Grid>

            <!-- Tab switch RGB / CMYK -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                <RadioButton x:Name="RgbTab" Content="RGB" GroupName="ColorMode" IsChecked="True"
                             Foreground="White" Margin="0,0,12,0" Checked="OnTabChanged" />
                <RadioButton x:Name="CmykTab" Content="CMYK" GroupName="ColorMode"
                             Foreground="White" Checked="OnTabChanged" />
            </StackPanel>

            <Grid x:Name="RgbBlock">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="R" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="RSlider" Minimum="0" Maximum="255" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="RBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="G" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="GSlider" Minimum="0" Maximum="255" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="GBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="B" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="BSlider" Minimum="0" Maximum="255" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="BBox" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid x:Name="CmykBlock" Visibility="Collapsed">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="C" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="CSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="CBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="M" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="MSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="MBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Y" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="YSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="YBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="K" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="KSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="KBox" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Alpha -->
            <Grid Margin="0,8,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="A" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="ASlider" Minimum="0" Maximum="255" ShowChecker="True" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="ABox" />
            </Grid>

            <!-- Hex + Dec inline. Each pair is "[📋 LABEL button] [editable textbox]" — the
                 button labels itself with the format name and copies on click; the textbox
                 stays a plain input so the user can paste / type values. CharacterCasing on
                 the hex textbox keeps user input uppercase too. -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Content="📋 Hex" Click="OnCopyHexClicked"
                           Padding="8,2" ToolTip="Copy hex value" />
                <TextBox  Grid.Column="1" x:Name="HexBox" Margin="4,0,0,0"
                          FontFamily="Consolas" CharacterCasing="Upper" />
                <ui:Button Grid.Column="3" Content="📋 Dec" Click="OnCopyDecimalClicked"
                           Padding="8,2" ToolTip="Copy decimal value" />
                <TextBox  Grid.Column="4" x:Name="DecBox" Margin="4,0,0,0"
                          FontFamily="Consolas" />
            </Grid>

            <!-- Palette: now in the right column, directly below Hex+Dec. -->
            <StackPanel Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton x:Name="PaletteRecent"   Content="Recent colors"   GroupName="Palette" IsChecked="True"
                                 Foreground="White" Margin="0,0,16,0" Checked="OnPaletteSourceChanged" />
                    <RadioButton x:Name="PaletteStandard" Content="Standard colors" GroupName="Palette"
                                 Foreground="White" Checked="OnPaletteSourceChanged" />
                </StackPanel>
                <ItemsControl x:Name="PaletteHost">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="14" Rows="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="22" Height="22" Margin="1"
                                    BorderBrush="#555" BorderThickness="1"
                                    Background="{Binding Brush}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnPaletteSwatchClick"
                                    Tag="{Binding Color}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>

        <!-- ╭──────── ACTION BAR — full width at the bottom ────────╮ -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <WrapPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Content="Copy all"     Margin="0,0,4,4" Click="OnCopyAllClicked"
                           ToolTip="Copy every format on separate lines — handy for pasting into a bug report or notes." />
                <ui:Button Content="Copy RGB"     Margin="0,0,4,4" Click="OnCopyRgbClicked"
                           ToolTip="rgb(R, G, B) — the CSS-style integer triplet." />
                <ui:Button Content="Copy CMYK"    Margin="0,0,4,4" Click="OnCopyCmykClicked"
                           ToolTip="cmyk(C%, M%, Y%, K%)" />
                <ui:Button Content="Copy HSB"     Margin="0,0,4,4" Click="OnCopyHsbClicked"
                           ToolTip="hsb(H°, S%, B%)" />
                <ui:Button Content="Copy Linear"  Margin="0,0,4,4" Click="OnCopyLinearClicked"
                           ToolTip="(R=1.000000,G=0.000000,B=0.000000,A=1.000000) — Unreal Engine FLinearColor." />
                <ui:Button Content="Copy BGRA"    Margin="0,0,4,4" Click="OnCopyBgraClicked"
                           ToolTip="(B=109,G=134,R=255,A=255) — Unreal Engine FColor (note BGRA channel order)." />
            </WrapPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- OK button = real applied accent. Plain WPF Button with a custom template so
                     hover/pressed don't tint the background grey (which is what ui:Button does
                     by default — fights with our solid accent fill). Hover/pressed use Opacity
                     to give subtle feedback while keeping the colour identity. -->
                <Button x:Name="OkButton" x:FieldModifier="public"
                        Content="OK" Width="80" Height="32" Margin="0,0,4,0"
                        IsDefault="True" Click="OnOkClicked"
                        FontWeight="SemiBold"
                        Background="{DynamicResource AccentBackgroundBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <ui:Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancelClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
