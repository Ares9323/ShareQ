<Window x:Class="ShareQ.Editor.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShareQ.Editor.Views"
        Title="Color picker"
        Width="780" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252525"
        Foreground="White">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,8,8" ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#DDDDDD">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#888888">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ╭──────── TOP-LEFT: SV square (Hue is driven by the H slider in the right panel,
                                  so the previously-redundant vertical Hue strip is gone — that
                                  also lets the SV square fill the full left column for finer
                                  saturation/value picking). ────────╮ -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                BorderBrush="#555" BorderThickness="1"
                ClipToBounds="True">
            <Grid x:Name="SvHost"
                  Background="Black"
                  MouseLeftButtonDown="OnSvMouseDown"
                  MouseMove="OnSvMouseMove"
                  MouseLeftButtonUp="OnSvMouseUp">
                <Rectangle x:Name="SvHueRect" />
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="White" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#00000000" Offset="0" />
                            <GradientStop Color="Black" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas IsHitTestVisible="False">
                    <Ellipse x:Name="SvCursor"
                             Width="12" Height="12"
                             Stroke="White" StrokeThickness="2"
                             Fill="Transparent" />
                </Canvas>
            </Grid>
        </Border>

        <!-- ╭──────── TOP-RIGHT: Old/New preview + Eyedropper + sRGB ────────╮ -->
        <Grid Grid.Row="0" Grid.Column="1" Margin="12,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Two-rect "old over new" preview (Unreal-style). Top = original color the picker
                 was opened with, bottom = current pick. Side-by-side via row split inside one
                 frame so you can compare easily. Background uses CheckerBrush so you can see
                 alpha through partially-transparent picks. -->
            <Border Grid.Column="0" Width="120" Height="60"
                    BorderBrush="#555" BorderThickness="1"
                    Background="{StaticResource CheckerBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0">
                        <Border.Background>
                            <SolidColorBrush x:Name="OriginalPreviewBrush" />
                        </Border.Background>
                    </Border>
                    <Border Grid.Row="1">
                        <Border.Background>
                            <SolidColorBrush x:Name="NewPreviewBrush" />
                        </Border.Background>
                    </Border>
                </Grid>
            </Border>
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                <CheckBox x:Name="SrgbToggle" Content="sRGB Preview" IsChecked="True" Margin="0,0,0,8"
                          ToolTip="Apply sRGB gamma to the preview swatches. Disable to see colors in linear space — closer to how renderers like Unreal interpret texture pixels." />
                <Button x:Name="EyedropperBtn" Content="🔍 Eyedropper" Padding="6,4" HorizontalAlignment="Left"
                        Click="OnEyedropperClicked"
                        ToolTip="Sample a pixel from anywhere on screen" />
            </StackPanel>
        </Grid>

        <!-- ╭──────── MID-RIGHT: HSV + RGB/CMYK tab + Alpha + Hex ────────╮ -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,0">
            <!-- HSB always visible -->
            <TextBlock Text="HSB" FontWeight="SemiBold" Margin="0,4,0,4" />
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="H" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="HSlider" Minimum="0" Maximum="360" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="HBox" />
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="S" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="SSlider" Minimum="0" Maximum="100" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="SBox" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="B" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="VSlider" Minimum="0" Maximum="100" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="VBox" />
            </Grid>

            <!-- Tab switch RGB / CMYK — alternate views, never both visible. -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                <RadioButton x:Name="RgbTab" Content="RGB" GroupName="ColorMode" IsChecked="True"
                             Margin="0,0,12,0" Checked="OnTabChanged" />
                <RadioButton x:Name="CmykTab" Content="CMYK" GroupName="ColorMode" Checked="OnTabChanged" />
            </StackPanel>

            <!-- RGB block -->
            <Grid x:Name="RgbBlock">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="R" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="RSlider" Minimum="0" Maximum="255" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="RBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="G" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="GSlider" Minimum="0" Maximum="255" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="GBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="B" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="BSlider" Minimum="0" Maximum="255" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="BBox" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- CMYK block (collapsed by default; CMYK tab flips visibility). -->
            <Grid x:Name="CmykBlock" Visibility="Collapsed">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="C" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="CSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="CBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="M" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="MSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="MBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Y" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="YSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="YBox" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="K" />
                        <local:ColorChannelSlider Grid.Column="1" x:Name="KSlider" Minimum="0" Maximum="100" Margin="4,0" />
                        <TextBox Grid.Column="2" x:Name="KBox" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Alpha — always visible regardless of RGB/CMYK tab. Track shows checker so the user
                 can see exactly how transparent the colour will render. -->
            <Grid Margin="0,8,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="A" />
                <local:ColorChannelSlider Grid.Column="1" x:Name="ASlider" Minimum="0" Maximum="255" ShowChecker="True" Margin="4,0" />
                <TextBox Grid.Column="2" x:Name="ABox" />
            </Grid>

            <!-- Hex + Decimal: both editable, both update preview live (TextChanged). Decimal
                 accepts the packed AARRGGBB integer, so users can paste from any tool that
                 emits decimal colours. -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Hex" />
                <TextBox Grid.Column="1" x:Name="HexBox" FontFamily="Consolas" />
            </Grid>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Dec" />
                <TextBox Grid.Column="1" x:Name="DecBox" FontFamily="Consolas" />
            </Grid>
        </StackPanel>

        <!-- ╭──────── BOTTOM ROW: palette + copy buttons + OK/Cancel ────────╮ -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <RadioButton x:Name="PaletteRecent"   Content="Recent colors"   GroupName="Palette" IsChecked="True"
                             Margin="0,0,16,0" Checked="OnPaletteSourceChanged" />
                <RadioButton x:Name="PaletteStandard" Content="Standard colors" GroupName="Palette"
                             Checked="OnPaletteSourceChanged" />
            </StackPanel>
            <ItemsControl x:Name="PaletteHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="14" Rows="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each swatch is a clickable Border. MouseDown commits the colour into
                             the picker state; double-click also closes with OK (keeps the
                             one-click-pick UX of standard ColorDialog feel-alikes). -->
                        <Border Width="22" Height="22" Margin="1"
                                BorderBrush="#555" BorderThickness="1"
                                Background="{Binding Brush}"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnPaletteSwatchClick"
                                Tag="{Binding Color}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Action bar -->
        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Six dedicated copy buttons, one per format. Avoids the "click dropdown → click
                 entry" two-click pattern of ShareX's Copy menu. -->
            <WrapPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Copy all"     Margin="0,0,4,4" Click="OnCopyAllClicked"
                        ToolTip="Copy every format on separate lines (RGB · Hex · CMYK · HSB · Decimal)" />
                <Button Content="Copy RGB"     Margin="0,0,4,4" Click="OnCopyRgbClicked"
                        ToolTip="rgb(R, G, B)" />
                <Button Content="Copy Hex"     Margin="0,0,4,4" Click="OnCopyHexClicked"
                        ToolTip="#AARRGGBB" />
                <Button Content="Copy CMYK"    Margin="0,0,4,4" Click="OnCopyCmykClicked"
                        ToolTip="cmyk(C%, M%, Y%, K%)" />
                <Button Content="Copy HSB"     Margin="0,0,4,4" Click="OnCopyHsbClicked"
                        ToolTip="hsb(H°, S%, B%)" />
                <Button Content="Copy Decimal" Margin="0,0,4,4" Click="OnCopyDecimalClicked"
                        ToolTip="Decimal integer of the 0xAARRGGBB packed colour" />
            </WrapPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="OK"     Width="80" Margin="0,0,4,0" IsDefault="True" Click="OnOkClicked" />
                <Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancelClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
