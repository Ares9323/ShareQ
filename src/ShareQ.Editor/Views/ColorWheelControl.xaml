<UserControl x:Class="ShareQ.Editor.Views.ColorWheelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid x:Name="Root"
          MouseLeftButtonDown="OnMouseDown"
          MouseMove="OnMouseMove"
          MouseLeftButtonUp="OnMouseUp"
          Background="Transparent">
        <!-- The bitmap is rendered once at V=1 (full brightness) and never recomputed —
             V is reflected by the black overlay below, an O(1) opacity tweak instead of
             an O(n²) per-pixel rerun on every slider tick. -->
        <Image x:Name="WheelImage" Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality" />
        <!-- Black ring + fill at variable alpha. The Stroke is always opaque (1px black) to give
             the disc a clean defined edge — hides the antialiasing seam between the bitmap's
             round area and the surrounding transparent corners. The Fill's brush alpha is what
             reflects V (set in code), so the ring stays visible even at V=1. -->
        <Ellipse x:Name="ValueOverlay" IsHitTestVisible="False"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Stroke="#000" StrokeThickness="1.5"
                 Width="{Binding ActualWidth, ElementName=WheelImage}"
                 Height="{Binding ActualHeight, ElementName=WheelImage}">
            <Ellipse.Fill>
                <SolidColorBrush x:Name="ValueOverlayBrush" Color="#00000000" />
            </Ellipse.Fill>
        </Ellipse>
        <Canvas IsHitTestVisible="False">
            <Ellipse x:Name="WheelCursor"
                     Width="14" Height="14"
                     Stroke="White" StrokeThickness="2"
                     Fill="Transparent" />
        </Canvas>
    </Grid>
</UserControl>
