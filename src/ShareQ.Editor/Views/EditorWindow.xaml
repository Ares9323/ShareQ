<ui:FluentWindow x:Class="ShareQ.Editor.Views.EditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ShareQ.Editor.ViewModels"
                 xmlns:tools="clr-namespace:ShareQ.Editor.Tools"
                 xmlns:views="clr-namespace:ShareQ.Editor.Views"
                 Title="ShareQ — Editor"
                 Width="1200" Height="820"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 KeyDown="OnWindowKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid.Resources>
            <!-- BasedOn the implicit Fluent button style so we keep its visuals (rounded bg, hover, etc.). -->
            <Style x:Key="ToolBtn" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Width" Value="76" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Margin" Value="0,2,0,0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="GroupHeader" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#888" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="Margin" Value="2,10,0,2" />
                <Setter Property="TextAlignment" Value="Left" />
            </Style>
        </Grid.Resources>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="3" Title="ShareQ — Editor" />

        <!-- Top toolbar: shape style defaults + history + zoom + save -->
        <Border Grid.Row="1" Grid.ColumnSpan="3" Padding="12,8" Background="#252525">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Outline:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" />
                <views:ColorSwatchButton x:Name="OutlineSwatch" Margin="0,0,16,0" />

                <TextBlock Text="Fill:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" />
                <views:ColorSwatchButton x:Name="FillSwatch" Margin="0,0,16,0" />

                <TextBlock Text="Stroke:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" />
                <Slider x:Name="StrokeSlider" Width="100" Minimum="1" Maximum="20" Value="2" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ElementName=StrokeSlider, Path=Value, StringFormat='{}{0:F0}px'}"
                           Foreground="White" VerticalAlignment="Center" Margin="4,0,16,0" />

                <ui:Button Content="Undo" Margin="0,0,4,0" Click="OnUndoClicked" />
                <ui:Button Content="Redo" Margin="0,0,16,0" Click="OnRedoClicked" />

                <ui:Button Content="−" Margin="0,0,4,0" Click="OnZoomOutClicked" />
                <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="White" VerticalAlignment="Center"
                           MinWidth="44" TextAlignment="Center" />
                <ui:Button Content="+" Margin="4,0,4,0" Click="OnZoomInClicked" />
                <ui:Button Content="1:1" Margin="0,0,16,0" Click="OnZoomResetClicked" />

                <ui:Button x:Name="SaveButton" Content="Save" Appearance="Primary" Margin="0,0,4,0" Click="OnSaveClicked" />
                <ui:Button x:Name="CancelButton" Content="Cancel" Click="OnCancelClicked" />
            </StackPanel>
        </Border>

        <!-- Left tool palette, grouped by category -->
        <Border Grid.Row="2" Grid.Column="0"
                Width="92" Padding="6,4"
                Background="#1F1F1F"
                BorderBrush="#333" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:Button x:Name="SelectToolBtn" Content="V Select" Style="{StaticResource ToolBtn}" Click="OnSelectToolClicked" />

                    <TextBlock Text="SHAPES" Style="{StaticResource GroupHeader}" />
                    <ui:Button x:Name="RectangleToolBtn" Content="R Rect" Style="{StaticResource ToolBtn}" Click="OnRectangleToolClicked" />
                    <ui:Button x:Name="EllipseToolBtn" Content="E Ellipse" Style="{StaticResource ToolBtn}" Click="OnEllipseToolClicked" />
                    <ui:Button x:Name="LineToolBtn" Content="L Line" Style="{StaticResource ToolBtn}" Click="OnLineToolClicked" />
                    <ui:Button x:Name="ArrowToolBtn" Content="A Arrow" Style="{StaticResource ToolBtn}" Click="OnArrowToolClicked" />
                    <ui:Button x:Name="FreehandToolBtn" Content="P Free" Style="{StaticResource ToolBtn}" Click="OnFreehandToolClicked" />

                    <TextBlock Text="OBJECTS" Style="{StaticResource GroupHeader}" />
                    <ui:Button x:Name="TextToolBtn" Content="T Text" Style="{StaticResource ToolBtn}" Click="OnTextToolClicked" />
                    <ui:Button x:Name="StepToolBtn" Content="N Step" Style="{StaticResource ToolBtn}" Click="OnStepToolClicked" />
                    <ui:Button x:Name="ImageBtn" Content="I Image" Style="{StaticResource ToolBtn}" Click="OnImageClicked" />

                    <TextBlock Text="EFFECTS" Style="{StaticResource GroupHeader}" />
                    <ui:Button x:Name="BlurToolBtn" Content="B Blur" Style="{StaticResource ToolBtn}" Click="OnBlurToolClicked" />
                    <ui:Button x:Name="PixelateToolBtn" Content="X Pixel" Style="{StaticResource ToolBtn}" Click="OnPixelateToolClicked" />
                    <ui:Button x:Name="SpotlightToolBtn" Content="O Spot" Style="{StaticResource ToolBtn}" Click="OnSpotlightToolClicked" />

                    <TextBlock Text="CANVAS" Style="{StaticResource GroupHeader}" />
                    <ui:Button x:Name="CropToolBtn" Content="C Crop" Style="{StaticResource ToolBtn}" Click="OnCropToolClicked" />
                    <ui:Button x:Name="ResizeBtn" Content="Resize…" Style="{StaticResource ToolBtn}" Click="OnResizeClicked" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Canvas -->
        <ScrollViewer Grid.Row="2" Grid.Column="1"
                      x:Name="CanvasScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="OnCanvasMouseWheel"
                      PreviewMouseLeftButtonDown="OnCanvasMouseDown"
                      PreviewMouseMove="OnCanvasMouseMove"
                      PreviewMouseLeftButtonUp="OnCanvasMouseUp"
                      Background="#1A1A1A">
            <Grid x:Name="CanvasHost" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="SourceImage" />
                <Canvas x:Name="DrawingCanvas" Background="Transparent" />
            </Grid>
        </ScrollViewer>

        <!-- Property panel (right) -->
        <Border Grid.Row="2" Grid.Column="2"
                Width="240" Padding="12" Background="#1F1F1F"
                BorderBrush="#333" BorderThickness="1,0,0,0">
            <StackPanel x:Name="PropertyPanel">
                <TextBlock Text="Properties" Foreground="White" FontSize="14" Margin="0,0,0,8" />
                <TextBlock x:Name="NoSelectionText"
                           Text="Select a shape to edit its properties (V tool, then click)."
                           Foreground="#888" TextWrapping="Wrap" />
                <StackPanel x:Name="SelectedShapeStack" Visibility="Collapsed">
                    <TextBlock x:Name="SelectedShapeKindText" Foreground="White" Margin="0,0,0,12" />

                    <Grid x:Name="SelOutlineFillRow" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" x:Name="SelOutlineSection">
                            <TextBlock Text="Outline" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                            <views:ColorSwatchButton x:Name="SelOutlineSwatch" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" x:Name="SelFillSection">
                            <TextBlock Text="Fill" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                            <views:ColorSwatchButton x:Name="SelFillSwatch" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="SelStrokeSection">
                        <TextBlock Text="Stroke" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Slider x:Name="SelStrokeSlider" Minimum="1" Maximum="20" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel x:Name="SelEffectSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock x:Name="SelEffectLabel" Text="Effect" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SelEffectSlider" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="SelEffectBox"
                                     Width="44" Margin="6,0,0,0" Padding="2"
                                     VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>
                        <StackPanel x:Name="SelEffectSecondarySection" Visibility="Collapsed">
                            <TextBlock x:Name="SelEffectSecondaryLabel" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" x:Name="SelEffectSecondarySlider" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="SelEffectSecondaryBox"
                                         Width="44" Margin="6,0,0,0" Padding="2"
                                         VerticalAlignment="Center" TextAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SelRotationSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock Text="Rotation" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SelRotationSlider" Minimum="-180" Maximum="180" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="SelRotationBox"
                                     Width="44" Margin="6,0,0,0" Padding="2"
                                     VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="SelTextStyleSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock Text="Text color" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <views:ColorSwatchButton x:Name="SelTextColorSwatch" HorizontalAlignment="Left" Margin="0,0,0,8" />

                        <TextBlock Text="Font" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <TextBox x:Name="SelFontInput" Padding="4,3" />
                            <Popup x:Name="SelFontPopup"
                                   PlacementTarget="{Binding ElementName=SelFontInput}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="#252525" BorderBrush="#555" BorderThickness="1" CornerRadius="3">
                                    <ListBox x:Name="SelFontList"
                                             MaxHeight="260"
                                             MinWidth="200"
                                             BorderThickness="0"
                                             Background="Transparent" />
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock Text="Size" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SelFontSizeSlider" Minimum="8" Maximum="96" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="SelFontSizeBox"
                                     Width="44" Margin="6,0,0,0" Padding="2"
                                     VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="SelBoldCheck" Content="Bold" Foreground="White" Margin="0,0,12,0" />
                            <CheckBox x:Name="SelItalicCheck" Content="Italic" Foreground="White" />
                        </StackPanel>

                        <TextBlock Text="Alignment" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="SelAlignLeftBtn" Content="L" Width="32" Margin="0,0,4,0" Click="OnSelAlignLeftClicked" />
                            <ToggleButton x:Name="SelAlignCenterBtn" Content="C" Width="32" Margin="0,0,4,0" Click="OnSelAlignCenterClicked" />
                            <ToggleButton x:Name="SelAlignRightBtn" Content="R" Width="32" Click="OnSelAlignRightClicked" />
                        </StackPanel>
                    </StackPanel>

                    <ui:Button Content="Apply current"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,0,4"
                               ToolTip="Apply the toolbar's current outline/fill/stroke to the selected shape(s)"
                               Click="OnApplyCurrentClicked" />
                    <ui:Button Content="Set as current"
                               HorizontalAlignment="Stretch"
                               ToolTip="Use the selected shape's outline/fill/stroke as the toolbar's current values"
                               Click="OnSetAsCurrentClicked" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
