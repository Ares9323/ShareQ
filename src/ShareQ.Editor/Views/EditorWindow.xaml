<ui:FluentWindow x:Class="ShareQ.Editor.Views.EditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ShareQ.Editor.ViewModels"
                 xmlns:tools="clr-namespace:ShareQ.Editor.Tools"
                 xmlns:views="clr-namespace:ShareQ.Editor.Views"
                 Title="ShareQ - Editor"
                 Icon="pack://application:,,,/ShareQ;component/Assets/icon.ico"
                 Width="1200" Height="820"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 Background="{DynamicResource Surface2Brush}"
                 Foreground="{DynamicResource AccentForegroundBrush}"
                 ExtendsContentIntoTitleBar="True"
                 KeyDown="OnWindowKeyDown">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Toolbar tool icons (Select/Rectangle/Ellipse/Line/Arrow/Freehand/Text/Step/
                     Image/Blur/Pixelate/Spotlight/Erase/Crop/Resize). Pulled from external SVGs;
                     see EditorToolIcons.xaml for the conversion notes. -->
                <ResourceDictionary Source="EditorToolIcons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <!-- Inlined ShareQ logo (same vector data the App-level ShareQLogo brush carries; copied
             here because ShareQ.Editor doesn't reference ShareQ.App and can't pick up its
             Resources. Other Editor-side windows (ColorPickerWindow) follow the same pattern. -->
        <DrawingImage x:Key="LocalShareQLogo">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#231f20" Geometry="M446.99,701.31l-2.4-2.08c-33.6-29.05-61.01-64.42-81.47-105.12-21.84-43.44-35.24-92.04-39.82-144.46l-.28-3.18,2.1-2.4c29.09-33.37,64.44-60.58,105.08-80.88,43.36-21.66,91.84-34.93,144.1-39.44l3.17-.27,2.4,2.09c33.48,29.17,60.76,64.63,81.08,105.4,21.7,43.52,34.95,92.18,39.38,144.64l.27,3.17-2.1,2.4c-29.05,33.2-64.31,60.29-104.81,80.5-43.2,21.56-91.5,34.8-143.55,39.35l-3.16.28ZM338.54,451.54c9.08,95.87,48.26,176.75,113.48,234.26,95.17-9,175.63-47.71,233.09-112.11-8.81-95.94-47.72-176.96-112.7-234.71-95.57,8.95-176.3,47.8-233.87,112.55Z" />
                    <GeometryDrawing Brush="#7fc99a" Geometry="M179.8,319.76c30.38-24.76,63.9-42.45,98.84-53.39,100.3-34.16,214.75-19.6,297.56,64.75-.42.04-.84.08-1.26.12,63.28,55.14,108.88,138.11,117.92,245.02,69.06-78.94,94.67-185.56,69.22-283.11-12.52-42.92-33.91-83.68-62.6-118.84-37.14-43.16-89.06-79.51-156.87-103.83.38-.16.75-.3,1.13-.46C293.55-30.89-45.1,203.09,69.26,480.9c.09-.21.17-.43.25-.64,18.86-65.53,59.02-120.59,110.29-160.51Z" />
                    <GeometryDrawing Brush="#7fc99a" Geometry="M954.49,544.58c-60.98,211.84-344.51,314.36-506.7,149.14.57-.05,1.13-.11,1.7-.16-63.51-54.92-109.38-137.74-118.72-244.56-70.49,80.86-95.51,190.62-66.87,289.93,13.54,42.36,35.76,82.37,65.07,116.66,36.8,40.93,87.27,75.4,152.41,98.76-.11.04-.21.08-.32.13,249.77,99.47,586.53-133.48,473.61-410.38-.06.15-.12.31-.18.46Z" />
                    <GeometryDrawing Brush="#e6e7e7" Geometry="M328.98,855.6c-31.55-35.1-53.04-74.96-65.07-116.66-28.64-99.31-3.62-209.07,66.87-289.93,55-63.09,137.68-108.58,244.16-117.78.42-.04.84-.08,1.26-.12-82.81-84.36-197.26-98.91-297.56-64.75-35.38,12.05-68.99,30.15-98.84,53.39-51.27,39.92-91.43,94.98-110.29,160.51-.09.21-.17.43-.25.64-100.35,250.34,133.93,588.68,411.81,473.59.11-.04.21-.08.32-.13-65.14-23.36-115.61-57.83-152.41-98.76Z" />
                    <GeometryDrawing Brush="#e6e7e7" Geometry="M699.48,174.31c30.9,35.9,51.55,76.51,62.6,118.84,25.45,97.55-.16,204.16-69.22,283.11-54.92,62.78-137.32,108.05-243.36,117.32-.57.05-1.13.11-1.7.16,162.19,165.22,445.72,62.7,506.7-149.14.06-.15.12-.31.18-.46,100.44-250.12-133.34-588.22-410.93-474.09-.38.16-.75.3-1.13.46,67.81,24.32,119.73,60.67,156.87,103.83Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <!-- Outer accent border + corner radius — matches MainWindow / ClipboardWindow / Launcher
         look. WindowBackdropType=None means we paint the whole chrome ourselves; the Border
         here gives the window its identity (Surface2 fill, accent dark frame, rounded). -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2" CornerRadius="8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid.Resources>
            <!-- Horizontal tool button: tighter than the old vertical version since we have to
                 fit ~14 entries on one row. BasedOn the implicit Fluent button style so we keep
                 the rounded bg / hover. -->
            <Style x:Key="ToolBtn" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Height" Value="30" />
                <Setter Property="MinWidth" Value="34" />
                <Setter Property="Padding" Value="4,2" />
                <Setter Property="Margin" Value="2,0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <!-- Inner icon: 18x18 keeps the 30-tall button visually balanced with ~6px padding
                 above/below; smaller would feel lost, larger crowds the button border. -->
            <Style x:Key="ToolIcon" TargetType="Image">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Stretch" Value="Uniform" />
            </Style>
            <!-- Vertical 1-px line between tool groups (replaces the old SHAPES / OBJECTS /
                 EFFECTS / CANVAS section headers from the sidebar layout). -->
            <Style x:Key="ToolGroupDivider" TargetType="Border">
                <Setter Property="Width" Value="1" />
                <Setter Property="Background" Value="{DynamicResource AccentForegroundDarkBrush}" />
                <Setter Property="Margin" Value="6,4" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="Opacity" Value="0.5" />
            </Style>
        </Grid.Resources>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Title="">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{StaticResource LocalShareQLogo}" Margin="0,0,-12,0" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <!-- Title text + tool palette inline. Title slot left empty (Title="") because a
                     wide Header would otherwise hide WPF-UI's own Title rendering — same
                     workaround used in ClipboardWindow / LauncherWindow. ScrollViewer wraps the
                     palette so a narrow window doesn't crop tools out. -->
                <Grid Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- title text -->
                        <ColumnDefinition Width="*" />     <!-- tools -->
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleBarText" Grid.Column="0" Text="ShareQ - Editor"
                               Foreground="#FFF" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,16,0" />
                    <ScrollViewer Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button x:Name="SelectToolBtn" Style="{StaticResource ToolBtn}" Click="OnSelectToolClicked" ToolTip="V Select">
                                <Image Source="{StaticResource ToolIconSelect}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>

                            <Border Style="{StaticResource ToolGroupDivider}" />
                            <ui:Button x:Name="RectangleToolBtn" Style="{StaticResource ToolBtn}" Click="OnRectangleToolClicked" ToolTip="R Rect">
                                <Image Source="{StaticResource ToolIconRectangle}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="EllipseToolBtn" Style="{StaticResource ToolBtn}" Click="OnEllipseToolClicked" ToolTip="E Ellipse">
                                <Image Source="{StaticResource ToolIconEllipse}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="LineToolBtn" Style="{StaticResource ToolBtn}" Click="OnLineToolClicked" ToolTip="L Line">
                                <Image Source="{StaticResource ToolIconLine}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="ArrowToolBtn" Style="{StaticResource ToolBtn}" Click="OnArrowToolClicked" ToolTip="A Arrow">
                                <Image Source="{StaticResource ToolIconArrow}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="FreehandToolBtn" Style="{StaticResource ToolBtn}" Click="OnFreehandToolClicked" ToolTip="F Free">
                                <Image Source="{StaticResource ToolIconFreehand}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>

                            <Border Style="{StaticResource ToolGroupDivider}" />
                            <ui:Button x:Name="TextToolBtn" Style="{StaticResource ToolBtn}" Click="OnTextToolClicked" ToolTip="T Text">
                                <Image Source="{StaticResource ToolIconText}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="StepToolBtn" Style="{StaticResource ToolBtn}" Click="OnStepToolClicked" ToolTip="N Step">
                                <Image Source="{StaticResource ToolIconStep}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="ImageBtn" Style="{StaticResource ToolBtn}" Click="OnImageClicked" ToolTip="I Image">
                                <Image Source="{StaticResource ToolIconImage}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>

                            <Border Style="{StaticResource ToolGroupDivider}" />
                            <ui:Button x:Name="BlurToolBtn" Style="{StaticResource ToolBtn}" Click="OnBlurToolClicked" ToolTip="B Blur">
                                <Image Source="{StaticResource ToolIconBlur}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="PixelateToolBtn" Style="{StaticResource ToolBtn}" Click="OnPixelateToolClicked" ToolTip="X Pixel">
                                <Image Source="{StaticResource ToolIconPixelate}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="SpotlightToolBtn" Style="{StaticResource ToolBtn}" Click="OnSpotlightToolClicked" ToolTip="O Spot">
                                <Image Source="{StaticResource ToolIconSpotlight}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="SmartEraserToolBtn" Style="{StaticResource ToolBtn}" Click="OnSmartEraserToolClicked" ToolTip="K Erase — fills the rect with a bilinear gradient of the 4 corner colors">
                                <Image Source="{StaticResource ToolIconErase}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>

                            <Border Style="{StaticResource ToolGroupDivider}" />
                            <ui:Button x:Name="CropToolBtn" Style="{StaticResource ToolBtn}" Click="OnCropToolClicked" ToolTip="C Crop">
                                <Image Source="{StaticResource ToolIconCrop}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="ResizeBtn" Style="{StaticResource ToolBtn}" Click="OnResizeClicked" ToolTip="Resize…">
                                <Image Source="{StaticResource ToolIconResize}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                            <ui:Button x:Name="EffectsBtn" Style="{StaticResource ToolBtn}" Click="OnEffectsClicked" ToolTip="Effects…">
                                <Image Source="{StaticResource ToolIconEffects}" Style="{StaticResource ToolIcon}" />
                            </ui:Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Tool palette merged into the titlebar above; this Row is now a 0-height
             placeholder so existing Grid.Row indexes don't have to shift. -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Height="0" />

        <!-- Canvas -->
        <ScrollViewer Grid.Row="2" Grid.Column="0"
                      x:Name="CanvasScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="OnCanvasMouseWheel"
                      PreviewMouseLeftButtonDown="OnCanvasMouseDown"
                      PreviewMouseMove="OnCanvasMouseMove"
                      PreviewMouseLeftButtonUp="OnCanvasMouseUp"
                      PreviewMouseRightButtonDown="OnCanvasRightButtonDown"
                      PreviewMouseRightButtonUp="OnCanvasRightButtonUp"
                      MouseLeave="OnCanvasMouseLeave"
                      Background="#1A1A1A">
            <Grid x:Name="CanvasHost" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="SourceImage" />
                <Canvas x:Name="DrawingCanvas" Background="Transparent" />
            </Grid>
        </ScrollViewer>

        <!-- Property panel (right) — DockPanel split: scrollable property surface on top,
             pinned footer (history + zoom) at the bottom of the column.
             CornerRadius matches the outer window's CornerRadius="8" minus its 2px border
             thickness on the bottom-right corner only — top stays flat against the titlebar
             and the left edge is straight where the sidebar meets the canvas column. Without
             this the Surface1 fill paints over the rounded outer corner and the bottom-right
             of the window looks square. -->
        <Border Grid.Row="2" Grid.Column="1"
                Width="240" Padding="12"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="1,0,0,0"
                CornerRadius="0,0,6,0">
        <DockPanel LastChildFill="True">

            <!-- Footer: zoom on top row, history on bottom row. Pinned at the panel's bottom
                 via DockPanel.Dock so a tall property surface scrolls UP instead of shoving
                 the controls off-screen. Undo gets Danger appearance per design — destructive
                 history action, visually distinguished from the neutral Redo. -->
            <Border DockPanel.Dock="Bottom"
                    Margin="0,12,0,0" Padding="0,10,0,0"
                    BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <UniformGrid Columns="4" Rows="1" Margin="0,0,0,6">
                        <ui:Button Content="−" Margin="0,0,2,0" HorizontalAlignment="Stretch" Click="OnZoomOutClicked" />
                        <Border Margin="2,0,2,0" Background="{DynamicResource Surface3Brush}"
                                CornerRadius="4" VerticalAlignment="Stretch">
                            <TextBlock x:Name="ZoomLabel" Text="100%"
                                       Foreground="{DynamicResource AccentForegroundBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontSize="11" />
                        </Border>
                        <ui:Button Content="+" Margin="2,0,2,0" HorizontalAlignment="Stretch" Click="OnZoomInClicked" />
                        <ui:Button Content="1:1" Margin="2,0,0,0" HorizontalAlignment="Stretch" Click="OnZoomResetClicked" />
                    </UniformGrid>
                    <UniformGrid Columns="2" Rows="1">
                        <ui:Button x:Name="UndoButton" Content="Undo" Appearance="Danger" Margin="0,0,2,0"
                                   HorizontalAlignment="Stretch" Click="OnUndoClicked" />
                        <ui:Button x:Name="RedoButton" Content="Redo" Margin="2,0,0,0"
                                   HorizontalAlignment="Stretch" Click="OnRedoClicked" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="PropertyPanel">
                <!-- Action triplet: Save (confirm + close) / Save as… (one-shot file export) /
                     Cancel. Sits above Properties so the user-visible "what do I do with this
                     edit" controls live next to the surface they just touched. -->
                <UniformGrid Columns="3" Rows="1" Margin="0,0,0,8">
                    <ui:Button x:Name="SaveButton" Content="Save" Appearance="Primary"
                               Margin="0,0,2,0" HorizontalAlignment="Stretch"
                               Click="OnSaveClicked"
                               ToolTip="Save the edited image into history (uses the global image format from Settings → Capture)" />
                    <ui:Button x:Name="SaveAsButton" Content="Save as…"
                               Margin="2,0,2,0" HorizontalAlignment="Stretch"
                               Click="OnSaveAsClicked"
                               ToolTip="Export to a file you pick. Format chosen via the dialog filter (PNG / JPEG / BMP / GIF). Does not touch history." />
                    <ui:Button x:Name="CancelButton" Content="Cancel"
                               Margin="2,0,0,0" HorizontalAlignment="Stretch"
                               Click="OnCancelClicked" />
                </UniformGrid>
                <Border Height="1" Background="#333" Margin="0,0,0,12" />

                <!-- Default properties: Outline / Fill / Stroke for the NEXT shape to draw.
                     Used to live on the top toolbar; moved here so all "what affects my next
                     stroke" controls are in one column with the live Properties below.
                     Outline + Fill render side-by-side as a 2-col grid; Stroke + value live
                     stacked underneath because the slider needs the full width. -->
                <TextBlock x:Name="DefaultPropertiesTitle" Text="Default properties" Foreground="White" FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock x:Name="OutlineLabel" Text="Outline" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"
                                   HorizontalAlignment="Center" />
                        <views:ColorSwatchButton x:Name="OutlineSwatch" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock x:Name="FillLabel" Text="Fill" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"
                                   HorizontalAlignment="Center" />
                        <views:ColorSwatchButton x:Name="FillSwatch" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock x:Name="TextLabel" Text="Text" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"
                                   HorizontalAlignment="Center" />
                        <views:ColorSwatchButton x:Name="TextSwatch" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,0,0,8">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StrokeLabel" Grid.Column="0" Text="Stroke" Foreground="#AAA" FontSize="11" />
                        <TextBlock Grid.Column="1" Foreground="#AAA" FontSize="11"
                                   Text="{Binding ElementName=StrokeSlider, Path=Value, StringFormat='{}{0:F0}px'}" />
                    </Grid>
                    <Slider x:Name="StrokeSlider" Minimum="1" Maximum="20" Value="2"
                            VerticalAlignment="Center" />
                </StackPanel>
                <!-- Apply the default outline/fill/stroke above to the currently selected
                     shape(s). Lives here in Default properties because it's the operation that
                     bridges defaults → selection. Disabled when nothing is selected; renamed
                     from the old "Apply current" since "to selected" reads more directly. -->
                <ui:Button x:Name="ApplyToSelectedBtn" Content="Apply to selected"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,12"
                           IsEnabled="False"
                           ToolTip="Apply the default outline / fill / stroke above to the selected shape(s)"
                           Click="OnApplyCurrentClicked" />
                <Border Height="1" Background="#333" Margin="0,0,0,12" />

                <!-- Dynamic title — set from RefreshPropertyPanel based on selection or active tool. -->
                <TextBlock x:Name="PanelTitleText" Text="Properties"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="NoSelectionText"
                           Text="Select a shape to edit its properties (V tool, then click)."
                           Foreground="#888" TextWrapping="Wrap" />
                <StackPanel x:Name="SelectedShapeStack" Visibility="Collapsed">

                    <Grid x:Name="SelOutlineFillRow" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" x:Name="SelOutlineSection">
                            <TextBlock x:Name="SelOutlineLabel" Text="Outline" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                            <views:ColorSwatchButton x:Name="SelOutlineSwatch" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" x:Name="SelFillSection">
                            <TextBlock x:Name="SelFillLabel" Text="Fill" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                            <views:ColorSwatchButton x:Name="SelFillSwatch" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="SelStrokeSection" Margin="0,0,0,12">
                        <!-- Header row mirrors Default properties: label on the left, live px
                             readout on the right bound to the slider's Value. -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SelStrokeLabel" Grid.Column="0" Text="Stroke" Foreground="#AAA" FontSize="11" />
                            <TextBlock Grid.Column="1" Foreground="#AAA" FontSize="11"
                                       Text="{Binding ElementName=SelStrokeSlider, Path=Value, StringFormat='{}{0:F0}px'}" />
                        </Grid>
                        <Slider x:Name="SelStrokeSlider" Minimum="1" Maximum="20" />
                    </StackPanel>

                    <StackPanel x:Name="SelEffectSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock x:Name="SelEffectLabel" Text="Effect" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SelEffectSlider" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="SelEffectBox"
                                     Width="44" Margin="6,0,0,0" Padding="2"
                                     VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>
                        <StackPanel x:Name="SelEffectSecondarySection" Visibility="Collapsed">
                            <TextBlock x:Name="SelEffectSecondaryLabel" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" x:Name="SelEffectSecondarySlider" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="SelEffectSecondaryBox"
                                         Width="44" Margin="6,0,0,0" Padding="2"
                                         VerticalAlignment="Center" TextAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SelFreehandSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <CheckBox x:Name="SelFreehandSmoothCheck"
                                  Content="Smooth stroke"
                                  Foreground="#DDD" FontSize="11"
                                  Margin="0,0,0,4"
                                  ToolTip="Apply Chaikin corner-cutting + Catmull-Rom rendering to remove hand jitter from this stroke." />
                        <CheckBox x:Name="SelFreehandEndArrowCheck"
                                  Content="End arrow"
                                  Foreground="#DDD" FontSize="11"
                                  ToolTip="Cap the stroke with an arrow head tangent to the last segment (ShareX-style freehand arrow)." />
                    </StackPanel>

                    <StackPanel x:Name="SelRotationSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock x:Name="SelRotationLabel" Text="Rotation" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SelRotationSlider" Minimum="-180" Maximum="180" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="SelRotationBox"
                                     Width="44" Margin="6,0,0,0" Padding="2"
                                     VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="SelStepCounterSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <!-- Step counter size now rides on the Stroke slider above (Radius =
                             StrokeWidth * 2.5), so this section only carries font knobs — no
                             dedicated radius control. -->
                        <TextBlock x:Name="SelStepFontLabel" Text="Font" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <TextBox x:Name="SelStepFontInput" Padding="4,3" />
                            <Popup x:Name="SelStepFontPopup"
                                   PlacementTarget="{Binding ElementName=SelStepFontInput}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="#252525" BorderBrush="#555" BorderThickness="1" CornerRadius="3">
                                    <ListBox x:Name="SelStepFontList"
                                             MaxHeight="260"
                                             MinWidth="200"
                                             BorderThickness="0"
                                             Background="Transparent" />
                                </Border>
                            </Popup>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="SelStepBoldCheck" Content="Bold" Foreground="White" Margin="0,0,12,0" />
                            <CheckBox x:Name="SelStepItalicCheck" Content="Italic" Foreground="White" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SelTextStyleSection" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock x:Name="SelTextColorLabel" Text="Text color" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <views:ColorSwatchButton x:Name="SelTextColorSwatch" HorizontalAlignment="Left" Margin="0,0,0,8" />

                        <TextBlock x:Name="SelFontLabel" Text="Font" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <TextBox x:Name="SelFontInput" Padding="4,3" />
                            <Popup x:Name="SelFontPopup"
                                   PlacementTarget="{Binding ElementName=SelFontInput}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="#252525" BorderBrush="#555" BorderThickness="1" CornerRadius="3">
                                    <ListBox x:Name="SelFontList"
                                             MaxHeight="260"
                                             MinWidth="200"
                                             BorderThickness="0"
                                             Background="Transparent" />
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock x:Name="SelSizeLabel" Text="Size" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SelFontSizeSlider" Minimum="8" Maximum="256" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="SelFontSizeBox"
                                     Width="44" Margin="6,0,0,0" Padding="2"
                                     VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="SelBoldCheck" Content="Bold" Foreground="White" Margin="0,0,12,0" />
                            <CheckBox x:Name="SelItalicCheck" Content="Italic" Foreground="White" />
                        </StackPanel>

                        <TextBlock x:Name="SelAlignmentLabel" Text="Alignment" Foreground="#AAA" FontSize="11" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="SelAlignLeftBtn" Content="L" Width="32" Margin="0,0,4,0" Click="OnSelAlignLeftClicked" />
                            <ToggleButton x:Name="SelAlignCenterBtn" Content="C" Width="32" Margin="0,0,4,0" Click="OnSelAlignCenterClicked" />
                            <ToggleButton x:Name="SelAlignRightBtn" Content="R" Width="32" Click="OnSelAlignRightClicked" />
                        </StackPanel>
                    </StackPanel>

                    <!-- "Apply to selected" lives in Default properties above. Set as current
                         remains here because it's the inverse operation — read FROM selection
                         INTO the defaults, so it makes sense paired with the selection-only
                         section. -->
                    <ui:Button x:Name="SetAsDefaultBtn" Content="Set as default"
                               HorizontalAlignment="Stretch"
                               ToolTip="Use the selected shape's outline/fill/stroke as the toolbar's current values"
                               Click="OnSetAsDefaultClicked" />
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </DockPanel>
        </Border>
    </Grid>
    </Border>
</ui:FluentWindow>
