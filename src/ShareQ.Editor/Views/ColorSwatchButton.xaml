<UserControl x:Class="ShareQ.Editor.Views.ColorSwatchButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="36" Height="36">
    <Border x:Name="SwatchBorder"
            BorderBrush="#888"
            BorderThickness="1"
            CornerRadius="18"
            Cursor="Hand"
            MouseLeftButtonUp="OnClicked">
        <Border.Background>
            <SolidColorBrush x:Name="SwatchBrush" Color="Red" />
        </Border.Background>
    </Border>
</UserControl>
