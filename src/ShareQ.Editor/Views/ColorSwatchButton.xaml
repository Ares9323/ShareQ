<UserControl x:Class="ShareQ.Editor.Views.ColorSwatchButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="36" Height="36">
    <UserControl.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,8,8" ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#DDDDDD">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#888888">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
    <Border x:Name="SwatchBorder"
            BorderBrush="#888"
            BorderThickness="1"
            CornerRadius="18"
            Cursor="Hand"
            Background="{StaticResource CheckerBrush}"
            MouseLeftButtonUp="OnClicked">
        <Border CornerRadius="18">
            <Border.Background>
                <SolidColorBrush x:Name="SwatchBrush" Color="Red" />
            </Border.Background>
        </Border>
    </Border>
</UserControl>
