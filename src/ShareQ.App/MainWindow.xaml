<ui:FluentWindow x:Class="ShareQ.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="ShareQ"
                 Icon="pack://application:,,,/Assets/icon.ico"
                 Width="520" Height="360"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ShareQ" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ShareQ" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Foreground="#AAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,4"
                       Text="Press Win+V to open the clipboard popup." />
            <TextBlock Foreground="#AAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,4"
                       Text="Use the tray icon to toggle incognito or quit." />
            <TextBlock Foreground="#777" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,0"
                       Text="Hotkeys: Ctrl+Alt+R region capture · Ctrl+Shift+P color picker · Ctrl+Alt+S record · Ctrl+Alt+G gif" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
