<ui:FluentWindow x:Class="ShareQ.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
                 Title="ShareQ"
                 Icon="pack://application:,,,/Assets/icon.ico"
                 Width="900" Height="600"
                 MinWidth="640" MinHeight="420"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <ui:FluentWindow.InputBindings>
        <!-- Esc routes to whichever inline-detail view is active. Each command's CanExecute is
             gated on its mode flag (IsConfiguringPlugin / IsEditingWorkflow); WPF picks the first
             KeyBinding whose CanExecute returns true. List the more specific modes first so they
             take precedence. KeyBindings sit on the Window's command routing layer and fire
             regardless of focus — unlike KeyDown handlers which require focus to be inside the
             listening element. The inline rename TextBox swallows Esc (e.Handled=true) so it
             doesn't bubble out and trigger these bindings while the user is still typing. -->
        <KeyBinding Key="Escape" Command="{Binding BackFromConfigCommand}" />
        <KeyBinding Key="Escape" Command="{Binding Hotkeys.BackToListCommand}" />
    </ui:FluentWindow.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Title="ShareQ" />

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Padding="8,12" BorderBrush="#333" BorderThickness="0,0,1,0">
            <StackPanel>
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Home"
                           Command="{Binding ShowHomeCommand}"
                           Appearance="{Binding IsHomeSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Plugins"
                           Command="{Binding ShowPluginsCommand}"
                           Appearance="{Binding IsPluginsSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Uploaders"
                           Command="{Binding ShowUploadersCommand}"
                           Appearance="{Binding IsUploadersSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Capture"
                           Command="{Binding ShowCaptureCommand}"
                           Appearance="{Binding IsCaptureSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Hotkeys &amp; workflows"
                           Command="{Binding ShowHotkeysCommand}"
                           Appearance="{Binding IsHotkeysSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Theme"
                           Command="{Binding ShowThemeCommand}"
                           Appearance="{Binding IsThemeSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="Debug"
                           Command="{Binding ShowDebugCommand}"
                           Appearance="{Binding IsDebugSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Content="About"
                           Command="{Binding ShowAboutCommand}"
                           Appearance="{Binding IsAboutSelected, Converter={StaticResource BoolToAppearance}}" />
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1" Grid.Column="1">
            <!-- Home -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsHomeSelected, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="ShareQ" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock Foreground="#AAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,4"
                           Text="Press Win+V to open the clipboard popup." />
                <TextBlock Foreground="#AAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,4"
                           Text="Use the tray icon to toggle incognito or quit." />
                <TextBlock Foreground="#777" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,8"
                           Text="Hotkeys: Ctrl+Alt+R region · Ctrl+Shift+P picker · Ctrl+Alt+S record · Ctrl+Alt+G gif" />
                <CheckBox IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                          Content="Run ShareQ when Windows starts"
                          Foreground="#DDD" FontSize="12"
                          HorizontalAlignment="Center" Margin="0,8,0,0"
                          ToolTip="Adds (or removes) ShareQ to the per-user Windows startup list. No admin rights needed." />
            </StackPanel>

            <!-- Plugins: list / configure inline detail. Single tab, two sub-views toggled by
                 IsConfiguringPlugin. Same shape as Hotkeys & workflows. -->
            <Grid Visibility="{Binding IsPluginsSelected, Converter={StaticResource BoolToVisibility}}">

                <!-- ── LIST VIEW ──────────────────────────────────────────────────────────── -->
                <ScrollViewer Visibility="{Binding IsConfiguringPlugin, Converter={StaticResource InverseBoolToVisibility}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,24,16">
                        <TextBlock Text="Plugins" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                                   Text="Toggle plugins on or off. Built-in plugins ship with ShareQ. External plugins live under %LOCALAPPDATA%\ShareQ\plugins\." />
                        <ItemsControl ItemsSource="{Binding Plugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PluginItemViewModel}">
                                    <Border Margin="0,0,0,8" Padding="14,10" Background="#1A1A1A"
                                            BorderBrush="#333" BorderThickness="1" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                                                    <Border Margin="8,0,0,0" Padding="6,1" Background="#333" CornerRadius="3"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Badge}" Foreground="#BBB" FontSize="10" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#888" FontSize="11"
                                                           TextWrapping="Wrap" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <ui:Button Content="Configure"
                                                           Command="{Binding ConfigureCommand}"
                                                           Visibility="{Binding HasConfig, Converter={StaticResource BoolToVisibility}}"
                                                           Margin="0,0,4,0"
                                                           ToolTip="Open this plugin's settings inline (sign-in, target folder, public/private, …)" />
                                                <ui:Button Content="Uninstall"
                                                           Command="{Binding UninstallCommand}"
                                                           Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="2"
                                                             IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                             VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── CONFIGURE DETAIL VIEW ───────────────────────────────────────────────── -->
                <!-- DataContext is set on the inner StackPanel rather than the ScrollViewer so
                     the ScrollViewer's Visibility binding still resolves against SettingsViewModel
                     (parent DataContext). Setting it on the ScrollViewer would re-root the binding
                     scope to ConfiguringPlugin, where IsConfiguringPlugin doesn't exist — the
                     binding would fall back to Visible and the panel would always render. -->
                <ScrollViewer Visibility="{Binding IsConfiguringPlugin, Converter={StaticResource BoolToVisibility}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,24,16" DataContext="{Binding ConfiguringPlugin}">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Content="← Back"
                                       Command="{Binding DataContext.BackFromConfigCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                       VerticalAlignment="Center"
                                       ToolTip="Back to the plugin list (Esc)" />
                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                        </Grid>

                        <!-- Auth section: visible only when the plugin implements IAuthenticatedUploader -->
                        <Border Background="#2A2A2A" BorderBrush="#444" BorderThickness="1" CornerRadius="4"
                                Padding="12,10" Margin="0,0,0,16"
                                Visibility="{Binding SupportsAuth, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Account" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding AuthStatus}" Foreground="#BBB" FontSize="11" />
                                </StackPanel>
                                <ui:Button Grid.Column="1" Content="Sign in"  Margin="0,0,4,0"
                                           Command="{Binding SignInCommand}" />
                                <ui:Button Grid.Column="2" Content="Sign out"
                                           Command="{Binding SignOutCommand}" />
                            </Grid>
                        </Border>

                        <!-- Settings list — auto-generated from IConfigurableUploader.GetSettings() -->
                        <ItemsControl ItemsSource="{Binding Settings}">
                            <ItemsControl.Resources>
                                <DataTemplate DataType="{x:Type vm:PluginSettingBoolRowViewModel}">
                                    <Border Margin="0,0,0,8" Padding="12,8" Background="#1A1A1A"
                                            BorderBrush="#333" BorderThickness="1" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding Description}" Foreground="#888" FontSize="11"
                                                           TextWrapping="Wrap" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Value, Mode=TwoWay}"
                                                             VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type vm:PluginSettingDropdownRowViewModel}">
                                    <Border Margin="0,0,0,8" Padding="12,8" Background="#1A1A1A"
                                            BorderBrush="#333" BorderThickness="1" CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="{Binding Description}" Foreground="#888" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,2,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding Options}"
                                                          SelectedValue="{Binding SelectedValue, Mode=TwoWay}"
                                                          SelectedValuePath="Value"
                                                          DisplayMemberPath="Display" />
                                                <ui:Button Grid.Column="1" Content="Refresh" Margin="6,0,0,0"
                                                           Command="{Binding RefreshOptionsCommand}"
                                                           Visibility="{Binding IsAsyncLoaded, Converter={StaticResource BoolToVisibility}}"
                                                           IsEnabled="{Binding IsLoadingOptions, Converter={StaticResource InverseBool}}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.Resources>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Uploaders -->
            <ScrollViewer Visibility="{Binding IsUploadersSelected, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,16,24,16">
                    <TextBlock Text="Uploaders" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="Pick which uploaders to use per content type. Multiple selections upload the same file to all of them; the resulting URLs end up on the clipboard, one per line." />

                    <TextBlock Text="Image uploaders" FontWeight="SemiBold" Margin="0,4,0,4" />
                    <ItemsControl ItemsSource="{Binding Uploaders.ImageUploaders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UploaderSelectionItemViewModel}">
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding IsPluginEnabled}"
                                          ToolTip="{Binding DisabledTooltip}"
                                          Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="File uploaders" FontWeight="SemiBold" Margin="0,16,0,4" />
                    <ItemsControl ItemsSource="{Binding Uploaders.FileUploaders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UploaderSelectionItemViewModel}">
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding IsPluginEnabled}"
                                          ToolTip="{Binding DisabledTooltip}"
                                          Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Text uploaders" FontWeight="SemiBold" Margin="0,16,0,4" />
                    <ItemsControl ItemsSource="{Binding Uploaders.TextUploaders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UploaderSelectionItemViewModel}">
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding IsPluginEnabled}"
                                          ToolTip="{Binding DisabledTooltip}"
                                          Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Video uploaders" FontWeight="SemiBold" Margin="0,16,0,4" />
                    <ItemsControl ItemsSource="{Binding Uploaders.VideoUploaders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UploaderSelectionItemViewModel}">
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding IsPluginEnabled}"
                                          ToolTip="{Binding DisabledTooltip}"
                                          Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Hotkeys & workflows: single tab with two sub-views toggled by IsEditingWorkflow.
                 List view (default) shows every hotkey-able workflow grouped by built-in / custom.
                 Edit view replaces it when the user clicks Edit on a row — it hosts the inline
                 rename, action buttons, and pipeline step editor. Back returns to list view. -->
            <Grid Visibility="{Binding IsHotkeysSelected, Converter={StaticResource BoolToVisibility}}">

                <!-- ── LIST VIEW ──────────────────────────────────────────────────────────── -->
                <ScrollViewer Visibility="{Binding Hotkeys.IsEditingWorkflow, Converter={StaticResource InverseBoolToVisibility}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,24,16">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Hotkeys" FontSize="20" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <ui:Button Grid.Column="1" Content="Reset all"
                                       Command="{Binding Hotkeys.Workflows.ResetAllToDefaultsCommand}"
                                       ToolTip="Reset every built-in workflow to its default steps and hotkey. Asks for confirmation; custom workflows are not touched." />
                        </Grid>
                        <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                                   Text="Click Rebind on a row to set a new key combo (Reset / Clear are inside the rebind dialog). Click Edit to open the workflow's step list." />

                        <TextBlock Text="Built-in workflows" FontSize="13" FontWeight="SemiBold" Foreground="#BBB"
                                   Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding Hotkeys.BuiltInItems}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:HotkeyItemViewModel}">
                                    <Border Margin="0,0,0,8" Padding="14,10" Background="#1A1A1A"
                                            BorderBrush="#333" BorderThickness="1" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Padding="8,3" Background="#2A2A2A"
                                                    BorderBrush="#444" BorderThickness="1" CornerRadius="3"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BindingDisplay}" FontFamily="Consolas"
                                                           FontSize="12" Foreground="#DDD" />
                                            </Border>
                                            <ui:Button Grid.Column="2" Content="Edit"
                                                       Command="{Binding OpenInWorkflowsCommand}"
                                                       Margin="0,0,4,0"
                                                       ToolTip="Open this workflow's step list" />
                                            <ui:Button Grid.Column="3" Content="Rebind"
                                                       Command="{Binding RebindCommand}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Custom workflows" FontSize="13" FontWeight="SemiBold" Foreground="#BBB"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="(none yet — click + Add custom workflow below to create one)"
                                   Foreground="#666" FontSize="11" FontStyle="Italic"
                                   Visibility="{Binding Hotkeys.CustomItems.Count, Converter={StaticResource ZeroToVisibility}}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Hotkeys.CustomItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:HotkeyItemViewModel}">
                                    <Border Margin="0,0,0,8" Padding="14,10" Background="#1A1A1A"
                                            BorderBrush="#333" BorderThickness="1" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Padding="8,3" Background="#2A2A2A"
                                                    BorderBrush="#444" BorderThickness="1" CornerRadius="3"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BindingDisplay}" FontFamily="Consolas"
                                                           FontSize="12" Foreground="#DDD" />
                                            </Border>
                                            <ui:Button Grid.Column="2" Content="Edit"
                                                       Command="{Binding OpenInWorkflowsCommand}"
                                                       Margin="0,0,4,0"
                                                       ToolTip="Open this workflow's step list" />
                                            <ui:Button Grid.Column="3" Content="Rebind"
                                                       Command="{Binding RebindCommand}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ui:Button Content="+ Add custom workflow" HorizontalAlignment="Left" Margin="0,4,0,0"
                                   Command="{Binding Hotkeys.AddCustomWorkflowCommand}" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ── EDIT VIEW ──────────────────────────────────────────────────────────── -->
                <!-- Esc handling lives on the Window (PreviewKeyDown there) so it fires regardless
                     of where focus currently sits — clicking Edit on a row leaves focus on the
                     (now hidden) button, so a ScrollViewer-scoped handler wouldn't catch it. -->
                <ScrollViewer Visibility="{Binding Hotkeys.IsEditingWorkflow, Converter={StaticResource BoolToVisibility}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,24,16">
                        <!-- Header: Back on the left, action cluster on the right. The inline name
                             editor sits below; rename happens on focus loss / Enter via the
                             SaveDisplayNameAsync hook in code-behind. -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Content="← Back"
                                       Command="{Binding Hotkeys.BackToListCommand}"
                                       ToolTip="Back to the hotkey list" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <ui:Button Content="Duplicate" Margin="0,0,4,0"
                                           Command="{Binding Hotkeys.Workflows.DuplicateWorkflowCommand}"
                                           ToolTip="Clone this workflow into a new editable copy" />
                                <ui:Button Content="Remove"    Margin="0,0,4,0"
                                           Command="{Binding Hotkeys.Workflows.RemoveWorkflowCommand}"
                                           ToolTip="Delete this workflow (built-ins can't be deleted)" />
                                <ui:Button Content="Reset to defaults"
                                           Command="{Binding Hotkeys.Workflows.Editor.ResetToDefaultsCommand}"
                                           Visibility="{Binding Hotkeys.Workflows.Editor.CanResetToDefaults, Converter={StaticResource BoolToVisibility}}"
                                           ToolTip="Restore this built-in workflow's original steps and hotkey." />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Workflow name" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox x:Name="WorkflowNameInline"
                                    Text="{Binding Hotkeys.Workflows.EditingDisplayName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    LostFocus="OnWorkflowNameLostFocus"
                                    KeyDown="OnWorkflowNameKeyDown"
                                    Padding="10,8"
                                    FontSize="13"
                                    Margin="0,0,0,16" />

                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pipeline steps" FontWeight="SemiBold" FontSize="14"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Add actions with the picker below; drag the ⋮⋮ handle to reorder; toggle to mute without removing; × removes. Plumbing steps run automatically and aren't shown." />
                        <ItemsControl x:Name="StepsItemsControl" ItemsSource="{Binding Hotkeys.Workflows.Editor.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WorkflowStepViewModel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="Transparent">
                                            <Border Height="2" Background="{DynamicResource AccentBackgroundBrush}" CornerRadius="1"
                                                    VerticalAlignment="Center" Margin="2,0"
                                                    Visibility="{Binding IsDropTargetAbove, Converter={StaticResource BoolToVisibility}}" />
                                        </Border>
                                        <Border Grid.Row="1" Padding="10,8" Background="#1A1A1A"
                                                BorderBrush="#333" BorderThickness="1" CornerRadius="4"
                                                Opacity="{Binding IsDragSource, Converter={StaticResource BoolToOpacity}}"
                                                AllowDrop="True"
                                                DragOver="OnStepRowDragOver"
                                                DragLeave="OnStepRowDragLeave"
                                                Drop="OnStepRowDrop">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Margin="0,0,12,0" Padding="6,4"
                                                        Cursor="SizeAll" Background="Transparent"
                                                        ToolTip="Drag to reorder"
                                                        MouseLeftButtonDown="OnStepHandleMouseDown"
                                                        MouseMove="OnStepHandleMouseMove"
                                                        MouseLeftButtonUp="OnStepHandleMouseUp">
                                                    <TextBlock Text="⋮⋮" Foreground="#777" FontSize="14"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                                                        <Border Margin="8,0,0,0" Padding="6,1" Background="#2A2A2A" CornerRadius="3"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding Category, Converter={StaticResource NonEmptyToVisibility}}">
                                                            <TextBlock Text="{Binding Category}" Foreground="#888" FontSize="10" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" Foreground="#888" FontSize="11"
                                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                Visibility="{Binding HasParameter, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding ParameterLabel}" Foreground="#AAA" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <ui:Button Content="−" MinWidth="32" Padding="6,0"
                                                                   VerticalAlignment="Center"
                                                                   Command="{Binding DecrementParameterCommand}"
                                                                   ToolTip="Decrease" />
                                                        <ui:TextBox Text="{Binding ParameterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="64" Margin="4,0"
                                                                    TextAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    VerticalContentAlignment="Center" />
                                                        <ui:Button Content="+" MinWidth="32" Padding="6,0"
                                                                   VerticalAlignment="Center"
                                                                   Command="{Binding IncrementParameterCommand}"
                                                                   ToolTip="Increase" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                 VerticalAlignment="Center" Margin="12,0,0,0" />
                                                <ui:Button Grid.Column="3" Content="×" Width="30" Height="22" Padding="0"
                                                           Command="{Binding RemoveCommand}"
                                                           ToolTip="Remove this step from the workflow"
                                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Height="12" Background="Transparent"
                                AllowDrop="True"
                                DragOver="OnStepFooterDragOver"
                                DragLeave="OnStepFooterDragLeave"
                                Drop="OnStepFooterDrop">
                            <Border Height="2" Background="{DynamicResource AccentBackgroundBrush}" CornerRadius="1"
                                    VerticalAlignment="Center" Margin="2,0"
                                    Visibility="{Binding Hotkeys.Workflows.Editor.IsDropTargetAtEnd, Converter={StaticResource BoolToVisibility}}" />
                        </Border>
                        <ui:Button x:Name="AddStepButton" Margin="0,4,0,0" HorizontalAlignment="Left"
                                   Content="+ Add step"
                                   Click="OnAddStepButtonClick" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Capture -->
            <StackPanel Visibility="{Binding IsCaptureSelected, Converter={StaticResource BoolToVisibility}}"
                        Margin="24,16,24,16">
                <TextBlock Text="Capture" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="Defaults applied when triggering captures from the tray menu or hotkeys. The pipeline that runs after each capture is configured under Workflows." />

                <TextBlock Text="Save folder" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding Capture.Folder, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="%USERPROFILE%\Pictures\ShareQ" />
                    <ui:Button Grid.Column="1" Content="Browse…" Command="{Binding Capture.BrowseFolderCommand}" Margin="6,0,0,0" />
                </Grid>

                <TextBlock Text="Sub-folder pattern (optional)" FontWeight="SemiBold" Margin="0,4,0,4" />
                <ui:TextBox Text="{Binding Capture.SubFolderPattern, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="e.g. %y-%mo  →  2026-04 sub-folder under the save folder"
                            Margin="0,0,0,4" />
                <TextBlock Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="Tokens: %y / %yy 4-digit / 2-digit year, %mo month (01–12), %mon month name, %d day, %h hour, %mi minute, %s second, %pm AM/PM. Leave empty for no sub-folder." />

                <TextBlock Text="Screenshot delay (seconds)" FontWeight="SemiBold" Margin="0,4,0,4" />
                <ui:NumberBox Value="{Binding Capture.DelaySeconds, Mode=TwoWay}"
                              Minimum="0" Maximum="30" SmallChange="1"
                              HorizontalAlignment="Left" Width="120" />
            </StackPanel>

            <!-- Theme -->
            <StackPanel Visibility="{Binding IsThemeSelected, Converter={StaticResource BoolToVisibility}}"
                        Margin="24,16,24,16">
                <TextBlock Text="Theme" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="Two colors that flow everywhere ShareQ uses an accent: primary buttons, toggle switches, the pinned-image border, drag-to-reorder indicators, and selected sidebar entries. Edit the hex values to see the changes apply live." />

                <!-- Background row -->
                <TextBlock Text="Accent background" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentBackgroundPreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="Click to open the color picker"
                            MouseLeftButtonDown="OnAccentBgSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentBackgroundHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#0078D4"
                                FontFamily="Consolas" />
                </Grid>

                <!-- Foreground row -->
                <TextBlock Text="Accent foreground" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentForegroundPreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="Click to open the color picker"
                            MouseLeftButtonDown="OnAccentFgSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentForegroundHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#FFFFFF"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="Foreground is the text/icon color drawn on top of the accent background — pick one with enough contrast (e.g. white on a dark accent, near-black on a light one)." />

                <!-- Live preview block + Apply: the sample shows the chosen pair on accent surfaces;
                     Apply forces a re-push of the colors through the resource pipeline (handy if
                     a third-party control templated against a brush before our override took
                     effect). Both side-by-side keeps the action visually tied to the preview. -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Background="{DynamicResource AccentBackgroundBrush}"
                            CornerRadius="4" Padding="12,8" VerticalAlignment="Center">
                        <TextBlock Text="Sample button label" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource AccentForegroundBrush}" />
                    </Border>
                    <ui:Button Content="Apply" Margin="8,0,0,0" VerticalAlignment="Center"
                               Command="{Binding Theme.ApplyNowCommand}"
                               ToolTip="Force a refresh of every themed surface — equivalent to a restart for the accent colors." />
                </StackPanel>

                <ui:Button Content="Reset to defaults" HorizontalAlignment="Left"
                           Command="{Binding Theme.ResetCommand}"
                           ToolTip="Restore the original ShareQ accent (#0078D4 background, white foreground)." />
            </StackPanel>

            <!-- Debug: live in-app log viewer. Captures every ILogger<T>.Log call across the
                 codebase via InMemoryLoggerProvider, so packaged builds + non-Rider runs still
                 give us visibility into errors / warnings / pipeline traces. -->
            <Grid Visibility="{Binding IsDebugSelected, Converter={StaticResource BoolToVisibility}}"
                  Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Debug log" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1" Content="Copy all" Margin="0,0,4,0"
                               Command="{Binding Debug.CopyAllCommand}"
                               ToolTip="Copy the visible log to the clipboard for pasting into a bug report" />
                    <ui:Button Grid.Column="2" Content="Clear"
                               Command="{Binding Debug.ClearCommand}"
                               ToolTip="Drop every entry in the buffer" />
                </Grid>
                <CheckBox Grid.Row="1" Content="Auto-scroll to latest"
                          IsChecked="{Binding Debug.AutoScroll, Mode=TwoWay}"
                          Foreground="#888" FontSize="11" Margin="0,8,0,8"
                          ToolTip="Locks the view to the most recent entry. Uncheck while scrolling up to read older lines." />
                <Border Grid.Row="2" Background="#0F0F0F" BorderBrush="#333" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="DebugLogList"
                             ItemsSource="{Binding Debug.Entries}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TimestampDisplay}" Foreground="#888" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding LevelDisplay}" Margin="0,0,8,0"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding LevelBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="#999" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#DDD" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- About -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsAboutSelected, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="ShareQ" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Foreground="#888" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Run Text="Version " /><Run Text="{Binding AppVersion, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="#888" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,0"
                           Text="Clipboard manager · screenshot &amp; share tool" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
