<Application x:Class="ShareQ.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:cv="clr-namespace:ShareQ.App.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <cv:BoolToAppearanceConverter x:Key="BoolToAppearance" />
            <cv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <cv:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
            <cv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <cv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility" />
            <cv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />
            <cv:BoolToOpacityConverter x:Key="BoolToOpacity" />
            <cv:InverseBoolConverter x:Key="InverseBool" />
            <cv:ZeroToVisibilityConverter x:Key="ZeroToVisibility" />
            <cv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <cv:BytesToImageConverter x:Key="BytesToImage" />

            <!-- FontAwesome Free Solid embedded via the standard WPF font-resource syntax.
                 Path before "#" is the folder relative to the assembly root; string after "#"
                 is the font's INTERNAL Family Name (verified via PrivateFontCollection), not
                 the filename. Used by category icons and the icon-picker dialog. -->
            <FontFamily x:Key="IconFont">/Assets/Fonts/#Font Awesome 7 Free Solid</FontFamily>

            <!-- Implicit TextBlock style: routes every plain TextBlock that doesn't set
                 Foreground locally onto AccentForegroundBrush via DynamicResource. WPF-UI v4's
                 FluentWindow template sets TextElement.Foreground with a StaticResource — the
                 reference is snapshotted at template instantiation, so swapping
                 TextFillColorPrimaryBrush at runtime never reaches the inherited tone. By
                 putting a DynamicResource on the implicit Style we get live retheming for the
                 thousands of "labelled hex" / header / inline-info TextBlocks across the app
                 without touching them one by one. Local Foreground setters still win. -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
