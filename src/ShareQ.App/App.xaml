<Application x:Class="ShareQ.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:cv="clr-namespace:ShareQ.App.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <cv:BoolToAppearanceConverter x:Key="BoolToAppearance" />
            <cv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <cv:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
            <cv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <cv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility" />
            <cv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />
            <cv:BoolToOpacityConverter x:Key="BoolToOpacity" />
            <cv:InverseBoolConverter x:Key="InverseBool" />
            <cv:ZeroToVisibilityConverter x:Key="ZeroToVisibility" />
            <cv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <cv:BytesToImageConverter x:Key="BytesToImage" />
            <cv:EnumValueDisplayConverter x:Key="EnumValueDisplay" />

            <!-- Checker pattern — used as a backdrop behind any partially-transparent fill so
                 the user can see the alpha (gradient stops, picked colours, preview swatches).
                 Same convention as Photoshop / GIMP / ShareX. -->
            <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" Stretch="None"
                          Viewport="0,0,10,10" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#3A3A3A">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,10,10" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#5A5A5A">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,5,5" />
                                    <RectangleGeometry Rect="5,5,5,5" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- ShareQ logo — five GeometryDrawings (one outline + two green leaves + two grey
                 highlights) that compose the brand mark. Defined once here so every window
                 (TitleBar icons, custom-chrome headers) renders the same vector at any size.
                 ImageSource-typed, so it plugs into ui:ImageIcon, Image.Source, and Window.Icon. -->
            <DrawingImage x:Key="ShareQLogo">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#231f20" Geometry="M446.99,701.31l-2.4-2.08c-33.6-29.05-61.01-64.42-81.47-105.12-21.84-43.44-35.24-92.04-39.82-144.46l-.28-3.18,2.1-2.4c29.09-33.37,64.44-60.58,105.08-80.88,43.36-21.66,91.84-34.93,144.1-39.44l3.17-.27,2.4,2.09c33.48,29.17,60.76,64.63,81.08,105.4,21.7,43.52,34.95,92.18,39.38,144.64l.27,3.17-2.1,2.4c-29.05,33.2-64.31,60.29-104.81,80.5-43.2,21.56-91.5,34.8-143.55,39.35l-3.16.28ZM338.54,451.54c9.08,95.87,48.26,176.75,113.48,234.26,95.17-9,175.63-47.71,233.09-112.11-8.81-95.94-47.72-176.96-112.7-234.71-95.57,8.95-176.3,47.8-233.87,112.55Z" />
                        <GeometryDrawing Brush="#7fc99a" Geometry="M179.8,319.76c30.38-24.76,63.9-42.45,98.84-53.39,100.3-34.16,214.75-19.6,297.56,64.75-.42.04-.84.08-1.26.12,63.28,55.14,108.88,138.11,117.92,245.02,69.06-78.94,94.67-185.56,69.22-283.11-12.52-42.92-33.91-83.68-62.6-118.84-37.14-43.16-89.06-79.51-156.87-103.83.38-.16.75-.3,1.13-.46C293.55-30.89-45.1,203.09,69.26,480.9c.09-.21.17-.43.25-.64,18.86-65.53,59.02-120.59,110.29-160.51Z" />
                        <GeometryDrawing Brush="#7fc99a" Geometry="M954.49,544.58c-60.98,211.84-344.51,314.36-506.7,149.14.57-.05,1.13-.11,1.7-.16-63.51-54.92-109.38-137.74-118.72-244.56-70.49,80.86-95.51,190.62-66.87,289.93,13.54,42.36,35.76,82.37,65.07,116.66,36.8,40.93,87.27,75.4,152.41,98.76-.11.04-.21.08-.32.13,249.77,99.47,586.53-133.48,473.61-410.38-.06.15-.12.31-.18.46Z" />
                        <GeometryDrawing Brush="#e6e7e7" Geometry="M328.98,855.6c-31.55-35.1-53.04-74.96-65.07-116.66-28.64-99.31-3.62-209.07,66.87-289.93,55-63.09,137.68-108.58,244.16-117.78.42-.04.84-.08,1.26-.12-82.81-84.36-197.26-98.91-297.56-64.75-35.38,12.05-68.99,30.15-98.84,53.39-51.27,39.92-91.43,94.98-110.29,160.51-.09.21-.17.43-.25.64-100.35,250.34,133.93,588.68,411.81,473.59.11-.04.21-.08.32-.13-65.14-23.36-115.61-57.83-152.41-98.76Z" />
                        <GeometryDrawing Brush="#e6e7e7" Geometry="M699.48,174.31c30.9,35.9,51.55,76.51,62.6,118.84,25.45,97.55-.16,204.16-69.22,283.11-54.92,62.78-137.32,108.05-243.36,117.32-.57.05-1.13.11-1.7.16,162.19,165.22,445.72,62.7,506.7-149.14.06-.15.12-.31.18-.46,100.44-250.12-133.34-588.22-410.93-474.09-.38.16-.75.3-1.13.46,67.81,24.32,119.73,60.67,156.87,103.83Z" />
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>

            <!-- FontAwesome Free Solid embedded via the standard WPF font-resource syntax.
                 Path before "#" is the folder relative to the assembly root; string after "#"
                 is the font's INTERNAL Family Name (verified via PrivateFontCollection), not
                 the filename. Used by category icons and the icon-picker dialog. -->
            <FontFamily x:Key="IconFont">/Assets/Fonts/#Font Awesome 7 Free Solid</FontFamily>

            <!-- Implicit TextBlock style: routes every plain TextBlock that doesn't set
                 Foreground locally onto AccentForegroundBrush via DynamicResource. WPF-UI v4's
                 FluentWindow template sets TextElement.Foreground with a StaticResource — the
                 reference is snapshotted at template instantiation, so swapping
                 TextFillColorPrimaryBrush at runtime never reaches the inherited tone. By
                 putting a DynamicResource on the implicit Style we get live retheming for the
                 thousands of "labelled hex" / header / inline-info TextBlocks across the app
                 without touching them one by one. Local Foreground setters still win. -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
