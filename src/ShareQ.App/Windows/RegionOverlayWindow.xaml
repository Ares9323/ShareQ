<Window x:Class="ShareQ.App.Windows.RegionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid x:Name="RootGrid">
        <Canvas x:Name="OverlayCanvas">
            <Rectangle x:Name="SelectionRect"
                       Stroke="#33B5FF"
                       StrokeThickness="1"
                       Fill="#3033B5FF"
                       Visibility="Collapsed" />
            <Border x:Name="SizeLabelBorder"
                    Background="#222"
                    Padding="6,2"
                    CornerRadius="3"
                    Visibility="Collapsed">
                <TextBlock x:Name="SizeLabel" Foreground="White" FontSize="11" />
            </Border>
        </Canvas>
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,12,0,0"
                   Foreground="White"
                   FontSize="13"
                   Text="Drag to select region · Esc to cancel" />
    </Grid>
</Window>
