<Window x:Class="ShareQ.App.Windows.RegionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid x:Name="RootGrid">
        <!-- Frozen screenshot of the desktop captured before the overlay was shown.
             Painted as the background so the dim layer above just darkens it without WPF
             needing AllowsTransparency (which would force Layered Window + disable HW accel). -->
        <Image x:Name="ScreenshotImage" Stretch="Fill" />
        <!-- Dim layer with an even-odd "hole" at the selection rect (rebuilt on each move). -->
        <Path x:Name="DimPath" Fill="#80000000" />
        <Canvas x:Name="OverlayCanvas">
            <Rectangle x:Name="SelectionRect"
                       Stroke="#33B5FF"
                       StrokeThickness="1"
                       Fill="Transparent"
                       Visibility="Collapsed" />
            <Border x:Name="SizeLabelBorder"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    Padding="6,3"
                    CornerRadius="3"
                    Visibility="Collapsed">
                <TextBlock x:Name="SizeLabel"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="16" />
            </Border>
            <Border x:Name="CursorPosBorder"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    Padding="6,3"
                    CornerRadius="3"
                    Visibility="Collapsed">
                <TextBlock x:Name="CursorPosLabel"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="16" />
            </Border>

            <!-- Magnifier panel near the cursor: zoomed preview + cursor coords underneath -->
            <Border x:Name="MagnifierBorder"
                    Background="#1F1F1F"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <StackPanel>
                    <Border BorderBrush="#888" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="MagnifierImage"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Fill" />
                            <Rectangle x:Name="MagnifierCrosshair"
                                       Stroke="Red" StrokeThickness="1.5"
                                       Fill="Transparent"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="MagnifierCoords"
                               Foreground="White"
                               FontFamily="Consolas"
                               FontWeight="SemiBold"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,4" />
                </StackPanel>
            </Border>
        </Canvas>
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,12,0,0"
                   Foreground="White"
                   FontSize="13"
                   Text="Drag to select region · Esc to cancel" />
    </Grid>
</Window>
