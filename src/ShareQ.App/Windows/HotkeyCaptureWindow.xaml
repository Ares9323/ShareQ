<Window x:Class="ShareQ.App.Windows.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set hotkey"
        Width="380" Height="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E"
        Foreground="White"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Press a key combination" FontSize="14" FontWeight="SemiBold" />
        <Border Grid.Row="1" Margin="0,12" Padding="12" Background="#2A2A2A" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ComboPreview" Text="(waiting for keys…)"
                           FontFamily="Consolas" FontSize="14" Foreground="#DDD"
                           HorizontalAlignment="Center" />
                <TextBlock Foreground="#888" FontSize="11" Margin="0,8,0,0" HorizontalAlignment="Center"
                           Text="Hold modifiers (Ctrl / Alt / Shift / Win) then press a key. Esc cancels." />
            </StackPanel>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Left side: distinct/separate actions on the binding itself. Reset only shows for
                 built-in workflows (which have a seeded default to restore). Cancel on the right
                 dismisses without changes. -->
            <Button Grid.Column="0" x:Name="ResetButton" Content="Reset to default" Width="130"
                    HorizontalAlignment="Left" Margin="0,0,8,0" />
            <Button Grid.Column="1" x:Name="ClearButton" Content="Clear binding" Width="120"
                    HorizontalAlignment="Left" />
            <Button Grid.Column="3" x:Name="CancelButton" Content="Cancel" Width="80" />
        </Grid>
    </Grid>
</Window>
