<Window x:Class="ShareQ.App.Windows.PinnedImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ShareQ pin"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Black"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Grid x:Name="RootGrid"
          MouseEnter="OnRootMouseEnter"
          MouseLeave="OnRootMouseLeave">
        <Border x:Name="ImageBorder"
                BorderThickness="0"
                BorderBrush="{DynamicResource AccentBackgroundBrush}"
                Padding="0">
            <Image x:Name="PinnedImage"
                   Stretch="Uniform"
                   MouseLeftButtonDown="OnImageMouseDown"
                   MouseRightButtonUp="OnImageRightClick"
                   MouseWheel="OnImageWheel" />
        </Border>
        <!-- Hover-revealed overlay with copy + zoom %. Sits at top-center, unobtrusive. -->
        <Border x:Name="OverlayBar"
                Visibility="Collapsed"
                Background="#CC1F1F1F"
                CornerRadius="4"
                Padding="6,3"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="CopyButton"
                        Content="📋"
                        FontSize="13"
                        Padding="4,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Copy image to clipboard"
                        Click="OnCopyClick" />
                <Button x:Name="EditButton"
                        Content="✏"
                        FontSize="13"
                        Padding="4,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Open in editor"
                        Click="OnEditClick" />
                <Button x:Name="ResetZoomButton"
                        Content="🔍"
                        FontSize="13"
                        Padding="4,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Reset zoom to 100%"
                        Click="OnResetZoomClick" />
                <TextBlock x:Name="ZoomLabel"
                           Text="100%"
                           Foreground="#DDD"
                           FontSize="11"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Margin="2,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
