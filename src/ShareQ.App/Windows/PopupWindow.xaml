<Window x:Class="ShareQ.App.Windows.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
        Title="ShareQ — Clipboard"
        Width="640" Height="520"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#1E1E1E"
        Foreground="White"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox"
                 Grid.Row="0"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="16"
                 Padding="8"
                 Background="#2A2A2A"
                 Foreground="White"
                 BorderBrush="#444"
                 BorderThickness="1"
                 CaretBrush="White" />

        <ListBox x:Name="ResultsList"
                 Grid.Row="1"
                 Margin="0,8,0,8"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemsSource="{Binding Rows}"
                 SelectedItem="{Binding SelectedRow}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ItemRowViewModel}">
                    <Border Padding="8" Margin="0,2" Background="#252525" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Ctrl+N quick-paste badge for the first 9 rows. -->
                            <Border Grid.Column="0"
                                    Width="22" Height="22"
                                    Margin="0,0,8,0"
                                    Background="#3A3A3A"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasIndexBadge, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding IndexBadge}"
                                           Foreground="#DDD"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <!-- Thumbnail (only for image rows that have a pre-generated PNG) -->
                            <Border Grid.Column="1"
                                    Width="56" Height="56"
                                    Margin="0,0,10,0"
                                    Background="#1A1A1A"
                                    BorderBrush="#444" BorderThickness="1"
                                    Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}">
                                <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                       Stretch="Uniform" />
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Preview}"
                                           Foreground="White"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           MaxHeight="60"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Foreground="#888" FontSize="11" Text="{Binding KindLabel}" />
                                    <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                    <TextBlock Foreground="#888" FontSize="11" Text="{Binding SourceProcess}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Foreground="#888" FontSize="11" Text="{Binding Age}" HorizontalAlignment="Right" />
                                <TextBlock Foreground="Gold" FontSize="11" Text="📌" HorizontalAlignment="Right"
                                           Visibility="{Binding Pinned, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2"
                   Foreground="#666"
                   FontSize="11"
                   Text="↑↓ navigate · Enter paste · Ctrl+1-9 quick paste · Ctrl+P pin · Esc close" />
    </Grid>
</Window>
