<Window x:Class="ShareQ.App.Windows.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
        Title="ShareQ — Clipboard"
        Width="920" Height="520"
        MinWidth="600" MinHeight="320"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E"
        Foreground="White"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="380" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="SearchBox"
                 Grid.Row="0"
                 Grid.Column="0"
                 Grid.ColumnSpan="2"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="16"
                 Padding="8"
                 Background="#2A2A2A"
                 Foreground="White"
                 BorderBrush="#444"
                 BorderThickness="1"
                 CaretBrush="White" />

        <ListBox x:Name="ResultsList"
                 Grid.Row="1"
                 Grid.Column="0"
                 Margin="0,8,8,8"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemsSource="{Binding Rows}"
                 SelectedItem="{Binding SelectedRow}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ItemRowViewModel}">
                    <Border Padding="8" Margin="0,2" Background="#252525" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Ctrl+N quick-paste badge for the first 9 rows. -->
                            <Border Grid.Column="0"
                                    Width="22" Height="22"
                                    Margin="0,0,8,0"
                                    Background="#3A3A3A"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasIndexBadge, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding IndexBadge}"
                                           Foreground="#DDD"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <!-- Thumbnail (only for image rows that have a pre-generated PNG) -->
                            <Border Grid.Column="1"
                                    Width="56" Height="56"
                                    Margin="0,0,10,0"
                                    Background="#1A1A1A"
                                    BorderBrush="#444" BorderThickness="1"
                                    Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}">
                                <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                       Stretch="Uniform" />
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Preview}"
                                           Foreground="White"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           MaxHeight="60"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Foreground="#888" FontSize="11" Text="{Binding KindLabel}" />
                                    <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                    <TextBlock Foreground="#888" FontSize="11" Text="{Binding SourceProcess}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Foreground="#888" FontSize="11" Text="{Binding Age}" HorizontalAlignment="Right" />
                                <TextBlock Foreground="Gold" FontSize="11" Text="📌" HorizontalAlignment="Right"
                                           Visibility="{Binding Pinned, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Side panel: rich preview of the selected row. Code-behind on PopupWindow watches the
             VM's PreviewRtfBytes / PreviewHtml since RichTextBox.Document and WebBrowser content
             can't be data-bound directly. -->
        <Border Grid.Row="1" Grid.Column="1"
                Margin="0,8,0,8"
                Background="#1A1A1A"
                BorderBrush="#333" BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Margin="8,6"
                           Foreground="#888"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding PreviewMeta}" />
                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <!-- Image preview -->
                    <Image Source="{Binding PreviewImageBytes, Converter={StaticResource BytesToImage}}"
                           Stretch="Uniform"
                           Margin="8"
                           Visibility="{Binding IsImagePreview, Converter={StaticResource BoolToVisibility}}" />
                    <!-- Plain text preview -->
                    <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                             IsReadOnly="True"
                             IsTabStop="False"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             FontSize="12"
                             Margin="6,0,6,6"
                             Visibility="{Binding IsTextPreview, Converter={StaticResource BoolToVisibility}}" />
                    <!-- RTF preview -->
                    <RichTextBox x:Name="RtfPreviewBox"
                                 IsReadOnly="True"
                                 IsTabStop="False"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Margin="6,0,6,6"
                                 Visibility="{Binding IsRtfPreview, Converter={StaticResource BoolToVisibility}}" />
                    <!-- HTML preview -->
                    <WebBrowser x:Name="HtmlPreviewBox"
                                Margin="6,0,6,6"
                                Visibility="{Binding IsHtmlPreview, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Foreground="#666"
                   FontSize="11"
                   Text="↑↓ navigate · Enter paste · Ctrl+1-9 quick paste · Ctrl+P pin · Esc close" />
    </Grid>
</Window>
