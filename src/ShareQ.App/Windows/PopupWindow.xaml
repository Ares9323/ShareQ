<Window x:Class="ShareQ.App.Windows.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
        Title="ShareQ — Clipboard"
        Width="640" Height="520"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#1E1E1E"
        Foreground="White"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox"
                 Grid.Row="0"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="16"
                 Padding="8"
                 Background="#2A2A2A"
                 Foreground="White"
                 BorderBrush="#444"
                 BorderThickness="1"
                 CaretBrush="White" />

        <ListBox x:Name="ResultsList"
                 Grid.Row="1"
                 Margin="0,8,0,8"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemsSource="{Binding Rows}"
                 SelectedItem="{Binding SelectedRow}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ItemRowViewModel}">
                    <Border Padding="8" Margin="0,2" Background="#252525" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Preview}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="White" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#888"
                                           FontSize="11"
                                           Text="{Binding KindLabel}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="#888"
                                       FontSize="11"
                                       Text="{Binding Age}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2"
                   Foreground="#666"
                   FontSize="11"
                   Text="↑↓ navigate · Enter paste · Esc close" />
    </Grid>
</Window>
