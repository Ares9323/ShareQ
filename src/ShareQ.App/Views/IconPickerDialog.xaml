<Window x:Class="ShareQ.App.Views.IconPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
        Title="Pick an icon"
        Width="540" Height="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E"
        Foreground="White"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <!-- WindowStyle=None drops the system frame; the Border below paints the same accent edge
         the rest of the dialogs use so this picker reads as part of the family. -->
    <Border BorderBrush="{DynamicResource AccentBackgroundDarkBrush}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Pick an icon" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="Hover an icon to see its FontAwesome name. Click to select."
                           Foreground="{DynamicResource AccentForegroundDarkBrush}"
                           FontSize="11" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Auto-fitting grid: ItemsControl with a UniformGrid panel. 8 columns × however
                 many rows the catalog produces; each cell is a clickable Button that fires
                 OnIconClicked with the IconCatalogEntry.Glyph as Tag. -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{x:Static vm:IconCatalog.All}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:IconCatalogEntry}">
                            <Button Width="56" Height="56" Margin="2"
                                    Background="{DynamicResource Surface3Brush}"
                                    BorderBrush="#3A3A3A" BorderThickness="1"
                                    Cursor="Hand"
                                    Tag="{Binding Glyph}"
                                    ToolTip="{Binding Name}"
                                    Click="OnIconClicked">
                                <!-- DynamicResource (not Static) so the lookup walks up to
                                     Application.Resources from this separate Window — Static
                                     would only see Window.Resources / parent visual tree. -->
                                <TextBlock Text="{Binding Glyph}"
                                           FontFamily="{DynamicResource IconFont}"
                                           FontSize="22"
                                           Foreground="#DDD"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Clear sets the picked Glyph to empty string and closes — used to remove an
                     existing icon from a category without re-typing one. -->
                <ui:Button Grid.Column="0" Content="Clear" Width="80" Click="OnClearClicked" />
                <ui:Button Grid.Column="2" Content="Cancel" Width="80" IsCancel="True" Click="OnCancelClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>
