<Window x:Class="ShareQ.App.Views.ScreenColorPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Cursor="Cross"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseRightButtonDown="OnMouseRightButtonDown"
        KeyDown="OnKeyDown">
    <Canvas x:Name="OverlayCanvas">
        <!-- Magnifier panel: zoomed 11×11 region + crosshair + color readout. -->
        <Border x:Name="MagnifierBorder"
                Width="160" Height="200"
                Background="{DynamicResource Surface2Brush}"
                BorderBrush="#80FFFFFF"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <Border Width="120" Height="120" Margin="20,12,20,8"
                        BorderBrush="#888" BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Image x:Name="MagnifierImage"
                               Width="120" Height="120"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="Fill" />
                        <!-- Crosshair indicating the centermost pixel (5,5 in the 11×11 sample → 60,60 in 120×120) -->
                        <Rectangle Width="11" Height="11"
                                   Stroke="Red" StrokeThickness="1.5"
                                   Fill="Transparent"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>
                <TextBlock x:Name="HexLabel"
                           Text="#000000"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2" />
                <TextBlock x:Name="RgbLabel"
                           Text="0, 0, 0"
                           Foreground="#AAA"
                           FontFamily="Consolas"
                           FontSize="11"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Click: pick · Esc/RMB: cancel"
                           Foreground="#666"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>
