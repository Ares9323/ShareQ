<ui:FluentWindow x:Class="ShareQ.App.Views.ImageEffectsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ShareQ.App.ViewModels.ImageEffects"
                 Title="ShareQ — Image effects"
                 Width="1200" Height="780"
                 MinWidth="900" MinHeight="600"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Surface1Brush}"
                 Foreground="{DynamicResource AccentForegroundBrush}">
    <ui:FluentWindow.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>
        <!-- Auto-select-all on focus for every TextBox in this window. The combined
             handlers (PreviewMouseLeftButtonDown + GotKeyboardFocus) match what File
             Explorer / Visual Studio do for numeric fields: a single click selects the
             contents so you can type a replacement without manually clearing first. -->
        <Style TargetType="TextBox">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnTextBoxPreviewMouseDown" />
            <EventSetter Event="GotKeyboardFocus" Handler="OnTextBoxGotFocus" />
        </Style>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentForegroundDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundDarkBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>
        <!-- Selection highlight uses AccentBackgroundDarkBrush instead of the default
             AccentBackgroundBrush (which is the lighter shade used for hover etc.) — easier
             to read on the surface2 panels and consistent with the picker UIs in the rest
             of the app. -->
        <!-- Glyph-button content: a FontAwesome 7 Free Solid character rendered through the
             app-wide IconFont resource. Same FontSize as the categories picker (13) — going
             smaller (12) made the glyph render at a non-natural height and the pen-to-square
             icon ended up clipped at the descender. No HorizontalAlignment override either —
             the WPF-UI Button centres its content already, and forcing it here was producing
             a vertically-stretched look on tall buttons. -->
        <Style x:Key="GlyphTextBlock" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource IconFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="ImageEffectsListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Surface3Brush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <!-- Accent-tinted frame around the whole window (matches the MainWindow / Launcher /
         Clipboard treatment so the editor doesn't read as a generic Win32 dialog). -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}"
            BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="ShareQ — Image effects" />

            <Grid Grid.Row="1" Margin="12,8,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" MinWidth="320" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Presets column -->
                <Border Grid.Column="0" Style="{StaticResource PanelStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Presets" Style="{StaticResource PanelHeader}" />
                        <!-- First row: + − ⧉ ✎ as discrete CRUD ops. Second row: full-width
                             Import button on its own line so it never clips at narrow widths.
                             All glyphs come from FontAwesome 7 Free Solid (same font already
                             used for the categories picker). -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:Button Margin="0,0,4,0" Command="{Binding AddPresetCommand}" ToolTip="New preset">
                                <TextBlock Text="&#xF067;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                            <ui:Button Margin="0,0,4,0" Appearance="Danger"
                                       Command="{Binding RemovePresetCommand}" ToolTip="Delete preset">
                                <TextBlock Text="&#xF068;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                            <ui:Button Margin="0,0,4,0" Command="{Binding DuplicatePresetCommand}" ToolTip="Duplicate">
                                <TextBlock Text="&#xF0C5;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                            <ui:Button Margin="0,0,4,0" Command="{Binding BeginRenameSelectedCommand}" ToolTip="Rename (F2)">
                                <TextBlock Text="&#xF044;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                        </StackPanel>
                        <ui:Button Grid.Row="2" Content="Import…" HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center" Margin="0,0,0,8"
                                   Click="OnImportSxieClicked" ToolTip="Import .sxie or .json preset" />
                        <ListBox Grid.Row="3"
                                 ItemsSource="{Binding Presets}"
                                 SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource AccentForegroundBrush}"
                                 ItemContainerStyle="{StaticResource ImageEffectsListBoxItem}">
                            <ListBox.InputBindings>
                                <KeyBinding Key="F2" Command="{Binding BeginRenameSelectedCommand}" />
                            </ListBox.InputBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PresetItemViewModel}">
                                    <Grid>
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                                 IsVisibleChanged="OnRenameTextBoxVisibilityChanged"
                                                 KeyDown="OnRenameTextBoxKeyDown"
                                                 LostFocus="OnRenameTextBoxLostFocus"
                                                 Padding="2,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Effects in selected preset -->
                <Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Effects in preset" Style="{StaticResource PanelHeader}" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:Button x:Name="AddEffectButton" Margin="0,0,4,0" Click="OnAddEffectClicked" ToolTip="Append a new effect">
                                <TextBlock Text="&#xF067;" Style="{StaticResource GlyphTextBlock}" />
                                <ui:Button.ContextMenu>
                                    <ContextMenu x:Name="AddEffectMenu" />
                                </ui:Button.ContextMenu>
                            </ui:Button>
                            <ui:Button Margin="0,0,4,0" Command="{Binding MoveEffectUpCommand}" ToolTip="Move up — order matters: each effect runs on the output of the previous one.">
                                <TextBlock Text="&#xF062;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                            <ui:Button Margin="0,0,4,0" Command="{Binding MoveEffectDownCommand}" ToolTip="Move down">
                                <TextBlock Text="&#xF063;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                            <ui:Button Margin="0,0,4,0" Appearance="Danger"
                                       Command="{Binding RemoveSelectedEffectCommand}" ToolTip="Remove selected effect">
                                <TextBlock Text="&#xF068;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                            <ui:Button Appearance="Danger"
                                       Command="{Binding ClearEffectsCommand}" ToolTip="Remove all">
                                <TextBlock Text="&#xF51A;" Style="{StaticResource GlyphTextBlock}" />
                            </ui:Button>
                        </StackPanel>
                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding EffectEntries}"
                                 SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource AccentForegroundBrush}"
                                 ItemContainerStyle="{StaticResource ImageEffectsListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:EffectEntryViewModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Property grid for the selected effect -->
                <Border Grid.Column="2" Style="{StaticResource PanelStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource PanelHeader}"
                                   Text="{Binding SelectedEntry.DisplayName, StringFormat='Properties — {0}', FallbackValue='Properties — (no selection)', Mode=OneWay}" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedEntry.Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:EffectParameterViewModel}">
                                        <Grid Margin="0,0,0,12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Header line: label on the left, contextual value readout on the right
                                                 (numeric for sliders, hex for colours, "L T R B" for paddings). -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value, StringFormat={}{0:F2}}"
                                                           Visibility="{Binding IsNumber, Converter={StaticResource BoolToVisibility}}"
                                                           Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                                            </Grid>

                                            <!-- Float / int — slider + numeric textbox. -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0"
                                                  Visibility="{Binding IsNumber, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="72" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0"
                                                        Minimum="{Binding Min}"
                                                        Maximum="{Binding Max}"
                                                        Value="{Binding Value, Mode=TwoWay}"
                                                        TickFrequency="{Binding Step}"
                                                        IsSnapToTickEnabled="False"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat='{}{0:F2}'}"
                                                         KeyDown="OnParameterTextBoxKeyDown"
                                                         HorizontalContentAlignment="Right"
                                                         VerticalContentAlignment="Center" />
                                            </Grid>

                                            <!-- Bool — single checkbox aligned with the label baseline. -->
                                            <CheckBox Grid.Row="1" Margin="0,4,0,0"
                                                      IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                      Visibility="{Binding IsBool, Converter={StaticResource BoolToVisibility}}" />

                                            <!-- Color — swatch + Pick… button. The swatch is a Border whose Background
                                                 is bound to the hex form of ColorValue; clicking either opens the picker. -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0"
                                                  Visibility="{Binding IsColor, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Height="22" CornerRadius="3"
                                                        BorderBrush="{DynamicResource AccentForegroundDarkBrush}"
                                                        BorderThickness="1"
                                                        Background="{Binding ColorBrush}"
                                                        Margin="0,0,8,0" />
                                                <ui:Button Grid.Column="1" Content="Pick…"
                                                           Click="OnPickColorClicked"
                                                           Tag="{Binding}" />
                                            </Grid>

                                            <!-- Padding — 4 numeric inputs in a single row, labelled L/T/R/B above each. -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0"
                                                  Visibility="{Binding IsPadding, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="L" FontSize="10" Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="T" FontSize="10" Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="R" FontSize="10" Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                                                <TextBlock Grid.Row="0" Grid.Column="3" Text="B" FontSize="10" Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                                                <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,4,0" Text="{Binding PaddingLeft, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" KeyDown="OnParameterTextBoxKeyDown" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,4,0" Text="{Binding PaddingTop, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" KeyDown="OnParameterTextBoxKeyDown" />
                                                <TextBox Grid.Row="1" Grid.Column="2" Margin="0,0,4,0" Text="{Binding PaddingRight, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" KeyDown="OnParameterTextBoxKeyDown" />
                                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding PaddingBottom, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" KeyDown="OnParameterTextBoxKeyDown" />
                                            </Grid>

                                            <!-- Enum — combobox of available names. -->
                                            <ComboBox Grid.Row="1" Margin="0,4,0,0"
                                                      ItemsSource="{Binding EnumOptions}"
                                                      SelectedItem="{Binding EnumValue, Mode=TwoWay}"
                                                      Visibility="{Binding IsEnum, Converter={StaticResource BoolToVisibility}}" />

                                            <!-- String — single-line textbox for watermark text, font descriptors,
                                                 image paths. LostFocus commit so re-render doesn't fire mid-typing. -->
                                            <TextBox Grid.Row="1" Margin="0,4,0,0"
                                                     Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     KeyDown="OnParameterTextBoxKeyDown"
                                                     Visibility="{Binding IsString, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Preview -->
                <Border Grid.Column="3" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!-- Header row: "Preview" label on the left, Live update toggle pushed
                             to the far right. Anchored above the image so the toggle is
                             always visible regardless of how the toolbar grows below. -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preview" Style="{StaticResource PanelHeader}" />
                            <CheckBox Grid.Column="2" Content="Live update"
                                      IsChecked="{Binding IsLivePreview, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,0,6"
                                      ToolTip="Re-render during slider drag (~30 fps) instead of waiting for the drag to settle." />
                        </Grid>
                        <Border Grid.Row="1" Background="#202020" CornerRadius="4">
                            <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:Button Content="Load image…" Margin="0,0,4,0" Click="OnLoadImageClicked" ToolTip="Replace the sample image" />
                            <ui:Button Content="Reset sample" Click="OnResetSampleClicked" />
                            <ui:Button Content="Export preset…" Margin="8,0,0,0" Click="OnExportPresetClicked" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Status bar -->
                <Border Grid.Row="1" Grid.ColumnSpan="4" Margin="0,8,0,0" Background="Transparent">
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
