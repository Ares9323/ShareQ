<Window x:Class="ShareQ.App.Views.WindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Pick a window"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#252525"
        Foreground="White">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pick a window" FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <ui:TextBox Grid.Row="1" x:Name="FilterBox"
                    PlaceholderText="🔍 Filter by title or process name…"
                    Margin="0,0,0,8"
                    TextChanged="OnFilterChanged" />

        <Border Grid.Row="2" Background="#1A1A1A" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="WindowList"
                     Background="Transparent" Foreground="White"
                     BorderThickness="0" Padding="2"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnListDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="Margin" Value="0,1" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Icon}"
                                   Width="20" Height="20" Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                       Foreground="White" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding ProcessName}"
                                       Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Height="32" Margin="0,0,4,0"
                    IsDefault="True" Click="OnOkClicked" FontWeight="SemiBold"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <ui:Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancelClicked" />
        </StackPanel>
    </Grid>
</Window>
