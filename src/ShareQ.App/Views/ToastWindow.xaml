<Window x:Class="ShareQ.App.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="340" SizeToContent="Height"
        ResizeMode="NoResize">
    <Border x:Name="Root"
            Background="#2A2A2A"
            BorderBrush="#404040"
            BorderThickness="1"
            CornerRadius="6"
            Margin="8"
            MouseLeftButtonDown="OnClicked"
            Cursor="Hand">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.5" />
        </Border.Effect>
        <Grid Margin="14,12,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TitleText"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="MessageText"
                           Foreground="#CCC"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    x:Name="CloseBtn"
                    Content="✕"
                    FontSize="11"
                    Foreground="#888"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="20" Height="20"
                    Padding="0"
                    VerticalAlignment="Top"
                    Cursor="Arrow"
                    Click="OnCloseClicked" />
        </Grid>
    </Border>
</Window>
