<Window x:Class="ShareQ.App.Views.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set hotkey"
        Width="460" Height="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E"
        Foreground="White"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <!-- WindowStyle=None strips the system chrome including the 1px frame, leaving the dialog
         visually melting into anything behind it that shares the dark background. The Border
         here paints our own 1px outline so the popup reads as a distinct window even when it
         lands over Settings (which uses the same Surface2 tone). -->
    <Border BorderBrush="{DynamicResource AccentBackgroundLightBrush}" BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Press a key combination" FontSize="14" FontWeight="SemiBold" />
        <Border Grid.Row="1" Margin="0,12" Padding="12" Background="{DynamicResource Surface3Brush}" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ComboPreview" Text="(waiting for keys…)"
                           FontFamily="Consolas" FontSize="14" Foreground="#DDD"
                           HorizontalAlignment="Center" />
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Margin="0,8,0,0" HorizontalAlignment="Center"
                           Text="Hold modifiers (Ctrl / Alt / Shift / Win) then press a key. Esc cancels." />
            </StackPanel>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Left side: distinct/separate actions on the binding itself. Reset only shows for
                 built-in workflows (which have a seeded default to restore). Cancel on the right
                 dismisses without changes. -->
            <Button Grid.Column="0" x:Name="ResetButton" Content="Reset to default" Width="130"
                    HorizontalAlignment="Left" Margin="0,0,8,0" />
            <Button Grid.Column="1" x:Name="ClearButton" Content="Clear binding" Width="120"
                    HorizontalAlignment="Left" />
            <Button Grid.Column="3" x:Name="CancelButton" Content="Cancel" Width="80" />
        </Grid>
    </Grid>
    </Border>
</Window>
