<Window x:Class="ShareQ.App.Views.RegionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid x:Name="RootGrid">
        <!-- Frozen screenshot of the desktop captured before the overlay was shown.
             Painted as the background so the dim layer above just darkens it without WPF
             needing AllowsTransparency (which would force Layered Window + disable HW accel). -->
        <Image x:Name="ScreenshotImage" Stretch="Fill" />
        <!-- Dim layer with an even-odd "hole" at the selection rect (rebuilt on each move). -->
        <Path x:Name="DimPath" Fill="#80000000" />
        <Canvas x:Name="OverlayCanvas">
            <Rectangle x:Name="SelectionRect"
                       Stroke="#33B5FF"
                       StrokeThickness="1"
                       Fill="Transparent"
                       Visibility="Collapsed" />
            <!-- Snap-preview rectangle highlighting the window under the cursor (visible only
                 while idle). Outline only — no fill — same look ShareX uses; a tinted fill makes
                 the preview feel intrusive when the user is just hovering. -->
            <Rectangle x:Name="SnapRect"
                       Stroke="#FFD000"
                       StrokeThickness="2"
                       StrokeDashArray="4,3"
                       Fill="Transparent"
                       Visibility="Collapsed"
                       IsHitTestVisible="False" />
            <Border x:Name="SizeLabelBorder"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    Padding="6,3"
                    CornerRadius="3"
                    Visibility="Collapsed">
                <TextBlock x:Name="SizeLabel"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="16" />
            </Border>
            <Border x:Name="CursorPosBorder"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    Padding="6,3"
                    CornerRadius="3"
                    Visibility="Collapsed">
                <TextBlock x:Name="CursorPosLabel"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="16" />
            </Border>

            <!-- Screen-edge crosshair (ShareX-style): 2 lines extending from cursor to canvas
                 bounds with marching-ants animation. Helps the user judge alignment of
                 distant features against the cursor. RenderOptions.EdgeMode = Aliased so the
                 1-px line stays crisp without sub-pixel anti-alias smearing. -->
            <Line x:Name="CrosshairH" Stroke="White" StrokeThickness="1"
                  StrokeDashArray="4,4" IsHitTestVisible="False" Visibility="Collapsed"
                  RenderOptions.EdgeMode="Aliased" />
            <Line x:Name="CrosshairHDark" Stroke="Black" StrokeThickness="1"
                  StrokeDashArray="4,4" StrokeDashOffset="4"
                  IsHitTestVisible="False" Visibility="Collapsed"
                  RenderOptions.EdgeMode="Aliased" />
            <Line x:Name="CrosshairV" Stroke="White" StrokeThickness="1"
                  StrokeDashArray="4,4" IsHitTestVisible="False" Visibility="Collapsed"
                  RenderOptions.EdgeMode="Aliased" />
            <Line x:Name="CrosshairVDark" Stroke="Black" StrokeThickness="1"
                  StrokeDashArray="4,4" StrokeDashOffset="4"
                  IsHitTestVisible="False" Visibility="Collapsed"
                  RenderOptions.EdgeMode="Aliased" />

            <!-- Round pixel-picker (ShareX-style). Image element clipped to an ellipse —
                 RenderOptions.BitmapScalingMode=NearestNeighbor only takes effect on Image,
                 not on ImageBrush (WPF falls back to bilinear there and pixels come out
                 blurred). Outer Ellipse + centred crosshair stack on top via the same Grid. -->
            <Grid x:Name="MagnifierGroup" Width="160" Height="160" Visibility="Collapsed">
                <Image x:Name="MagnifierImage"
                       Width="160" Height="160"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       IsHitTestVisible="False">
                    <Image.Clip>
                        <EllipseGeometry Center="80,80" RadiusX="80" RadiusY="80" />
                    </Image.Clip>
                </Image>
                <Ellipse x:Name="MagnifierCircle"
                         Width="160" Height="160"
                         Stroke="#80FFFFFF" StrokeThickness="1.5"
                         Fill="Transparent"
                         IsHitTestVisible="False" />
                <Rectangle x:Name="MagnifierCrosshair"
                           Stroke="Red" StrokeThickness="1.5"
                           Fill="Transparent"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </Grid>
            <Border x:Name="MagnifierCoordsBorder"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    Padding="6,3"
                    CornerRadius="3"
                    Visibility="Collapsed">
                <TextBlock x:Name="MagnifierCoords"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontWeight="SemiBold"
                           FontSize="14" />
            </Border>
            <!-- Single unified popup: hint row + status / zoom / Apply / Cancel below. The
                 user can drag it anywhere on the overlay (handled in code-behind, position
                 persisted across sessions). Background is the explicit drag handle — only
                 the Buttons inside opt out of the drag, so any background pixel grabs it. -->
            <Border x:Name="Toolbar"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    Cursor="SizeAll"
                    Canvas.ZIndex="200"
                    Canvas.Left="0" Canvas.Top="0">
                <StackPanel Orientation="Vertical">
                    <TextBlock Foreground="#BBB" FontSize="11"
                               Margin="0,0,0,6"
                               Text="Drag to add region · Click to select · Del to remove · Wheel to zoom · Drag this popup to move it" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="StatusLabel"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   Text="No regions yet — drag to start" />
                        <Border Width="1" Background="#80FFFFFF" Margin="0,0,16,0" />
                        <TextBlock x:Name="ZoomLabel"
                                   Foreground="#AAA" FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   Text="Zoom: 17px" />
                        <Border Width="1" Background="#80FFFFFF" Margin="0,0,16,0" />
                        <Button x:Name="ToolbarApplyButton"
                                Content="Apply (Enter)"
                                Click="OnToolbarApplyClicked"
                                Background="#249A56" Foreground="White"
                                BorderBrush="#249A56" BorderThickness="0"
                                Padding="10,4" Margin="0,0,8,0"
                                IsEnabled="False" />
                        <Button x:Name="ToolbarCancelButton"
                                Content="Cancel (Esc)"
                                Click="OnToolbarCancelClicked"
                                Background="#C54747" Foreground="White"
                                BorderBrush="#C54747" BorderThickness="0"
                                Padding="10,4" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
