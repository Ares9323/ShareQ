<Window x:Class="ShareQ.App.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ShareQ launcher"
        Width="1280" Height="640"
        MinWidth="800" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        KeyDown="OnKeyDown"
        Deactivated="OnDeactivated"
        Closing="OnLauncherClosing">
    <Window.Resources>
        <!-- Per-cell right-click menu. Single shared instance — DataContext is rebound to the
             clicked cell's view-model via the PlacementTarget binding so each invocation
             carries the right cell's payload. The five entries match the conventional file-
             manager actions on a slot: jump to its source on disk, edit, copy/paste between
             slots (own clipboard, doesn't touch the OS clipboard), wipe. -->
        <ContextMenu x:Key="LauncherCellMenu"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="Open file location" Click="OnMenuOpenLocation" />
            <MenuItem Header="Edit…"              Click="OnMenuEdit" />
            <Separator />
            <MenuItem Header="Copy"               Click="OnMenuCopy" />
            <MenuItem Header="Paste"              Click="OnMenuPaste" />
            <Separator />
            <MenuItem Header="Delete"             Click="OnMenuDelete" />
        </ContextMenu>
    </Window.Resources>
    <Border Background="#F0181818" CornerRadius="8"
            BorderBrush="#404040" BorderThickness="1">
        <!-- Outer wrapper grid: holds the main content + the resize thumb. The thumb sits on the
             outer card's bottom-right corner (not buried inside the inner padding) and only
             appears in drag mode — the launcher is a one-shot ephemeral overlay outside drag
             mode, so resizing should happen during the explicit "I'm editing" pass. -->
        <Grid>
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0: header (mode banner + toggle) -->
                <RowDefinition Height="Auto" />  <!-- 1: F-strip -->
                <RowDefinition Height="Auto" />  <!-- 2: gap -->
                <RowDefinition Height="Auto" />  <!-- 3: tab strip -->
                <RowDefinition Height="*" />     <!-- 4: row 1 — split the leftover height equally -->
                <RowDefinition Height="*" />     <!-- 5: row 2 -->
                <RowDefinition Height="*" />     <!-- 6: row 3 -->
                <RowDefinition Height="Auto" />  <!-- 7: footer -->
            </Grid.RowDefinitions>

            <!-- ── Header: drag-mode banner on the left, search box + drag-mode toggle on the
                  right. The whole header strip is the drag handle while drag mode is on (see
                  OnChromeMouseDown). Outside drag mode the launcher is meant to be ephemeral
                  and stays put. ───────────────────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="0,0,0,8"
                  Background="#01000000"
                  MouseLeftButtonDown="OnChromeMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DragModeBanner" Grid.Column="0"
                           Text="🎯 Drag-and-drop mode — drop files / folders / shortcuts onto cells to map them. Esc or click toggle to exit."
                           Foreground="#F4B400" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed" />
                <ui:TextBox Grid.Column="1" x:Name="SearchBox"
                            PlaceholderText="🔍 Search…"
                            FontSize="11" Margin="0,0,8,0"
                            TextChanged="OnSearchTextChanged"
                            ToolTip="Filter cells by label or path. Empty cells and the F-row are unaffected; tabs without matches lose their title." />
                <ui:Button Grid.Column="2" x:Name="DragToggle" Content="📥 Drag mode"
                           Padding="10,4" FontSize="11" Click="OnDragToggleClick"
                           ToolTip="Toggle drag-and-drop mode — the launcher stays open and cells accept dropped files / folders / shortcuts." />
            </Grid>

            <!-- ── Function-key strip — global, visible regardless of selected tab ──────────── -->
            <ItemsControl x:Name="FunctionRow" Grid.Row="1">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                Height="84"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="#DDD"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <Image Source="{Binding Icon}" Width="32" Height="32"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="2" Height="12" />

            <ItemsControl x:Name="TabStrip" Grid.Row="3">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3,0" CornerRadius="6,6,0,0"
                                Background="{Binding HeaderBackground}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1,1,1,0"
                                MouseLeftButtonDown="OnTabClick"
                                MouseRightButtonDown="OnTabRightClick"
                                Cursor="Hand"
                                Tag="{Binding TabKey}"
                                Height="44"
                                Visibility="{Binding HeaderVisibility}"
                                ToolTip="Right-click to rename this tab — drop a file to switch tab without firing.">
                            <Grid Margin="6,4">
                                <TextBlock Text="{Binding TabKey}" Foreground="#DDD"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <TextBlock Text="{Binding Title}" Foreground="#FFF"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Accent panel painted behind the active tab's QWERTY grid. The Border spans the
                 three key rows so the tab and its content read as one continuous coloured zone
                 (same convention as a TabControl's selected page). Z-order: declared first so
                 the cells render on top. All four corners round so the panel reads as a real
                 self-contained card regardless of which tab is active (the active tab might be
                 anywhere in the strip, not necessarily the first slot). -->
            <Border Grid.Row="4" Grid.RowSpan="3"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    CornerRadius="6"
                    Margin="-3,0,-3,-3" />

            <ItemsControl x:Name="Row1Host" Grid.Row="4" Margin="0,0,0,4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="#DDD"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="#DDD"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="Row2Host" Grid.Row="5" Margin="0,0,0,4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="#DDD"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="#DDD"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="Row3Host" Grid.Row="6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="#DDD"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="#DDD"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="7" Margin="0,10,0,0" HorizontalAlignment="Center"
                       Foreground="#666" FontSize="10"
                       Text="F1-F10 fire global · 1-9,0 / arrows switch tab · QWERTY fires tab cell · Esc closes · right-click to edit" />

        </Grid>
        <!-- Resize grip — manual thumb because AllowsTransparency hides the standard window
             resize cursor. Lives on the outer card's bottom-right corner (not inside the inner
             14px padding) so it visually attaches to the chrome. Visibility is toggled by
             SetDragMode: the launcher is meant to be ephemeral outside drag mode, so resizing
             only happens while the user is explicitly editing the layout. -->
        <Thumb x:Name="ResizeThumb"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Width="14" Height="14"
               Cursor="SizeNWSE"
               DragDelta="OnResizeThumbDelta"
               Margin="0,0,4,4"
               Visibility="Collapsed">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Path Stroke="#888" StrokeThickness="1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 4,13 L 13,4 M 7,13 L 13,7 M 10,13 L 13,10" />
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        </Grid>
    </Border>
</Window>
