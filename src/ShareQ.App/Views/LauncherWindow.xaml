<ui:FluentWindow x:Class="ShareQ.App.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:Markup="clr-namespace:ShareQ.App.Markup"
        Title="ShareQ - Launcher"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="1280" Height="640"
        MinWidth="800" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="None"
        Background="{DynamicResource Surface2Brush}"
        Foreground="{DynamicResource AccentForegroundBrush}"
        ExtendsContentIntoTitleBar="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        KeyDown="OnKeyDown"
        Deactivated="OnDeactivated"
        Closing="OnLauncherClosing">
    <ui:FluentWindow.Resources>
        <!-- Per-cell right-click menu. Single shared instance — DataContext is rebound to the
             clicked cell's view-model via the PlacementTarget binding so each invocation
             carries the right cell's payload. The five entries match the conventional file-
             manager actions on a slot: jump to its source on disk, edit, copy/paste between
             slots (own clipboard, doesn't touch the OS clipboard), wipe. -->
        <ContextMenu x:Key="LauncherCellMenu"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="{Markup:Loc Launcher_MenuOpenLocation}" Click="OnMenuOpenLocation" />
            <MenuItem Header="{Markup:Loc Launcher_MenuEdit}"         Click="OnMenuEdit" />
            <Separator />
            <MenuItem Header="{Markup:Loc Launcher_MenuCopy}"          Click="OnMenuCopy" />
            <MenuItem Header="{Markup:Loc Launcher_MenuPaste}"         Click="OnMenuPaste" />
            <Separator />
            <MenuItem Header="{Markup:Loc Launcher_MenuDelete}"        Click="OnMenuDelete" />
        </ContextMenu>
    </ui:FluentWindow.Resources>
    <!-- Accent-tinted 2px frame around the whole window content (titlebar + body), matching
         MainWindow / ImageEffectsWindow / GradientEditorWindow / QrGeneratorWindow. FluentWindow's
         own chrome stays outside this Border, so the accent line reads as an inner "telaio". -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0 titlebar -->
                <RowDefinition Height="*" />     <!-- 1 main content -->
            </Grid.RowDefinitions>

            <!-- WPF-UI titlebar — drag / max / min / close + dark caption via DWM. The title's
                 right-side hosts inline content: search → drag toggle → sliders. Sliders show
                 only in drag mode (Visibility flipped by SetDragMode in code-behind). The drag
                 banner moved out of here and into the footer. -->
            <!-- Title="" intentionally — WPF-UI's Title slot gets hidden behind a wide Header,
                 so we render the title text explicitly as the first column of the Header. With
                 Title set, an empty placeholder slot still reserves space and pushes our text
                 further right; clearing it lets the Header sit flush against the icon. -->
            <ui:TitleBar Grid.Row="0" Title="">
                <ui:TitleBar.Icon>
                    <!-- Negative right margin pulls the title text closer to the icon — WPF-UI's
                         default TitleBar template leaves a wide gap. -->
                    <ui:ImageIcon Source="{StaticResource ShareQLogo}" Margin="0,0,-12,0" />
                </ui:TitleBar.Icon>
                <ui:TitleBar.Header>
                <Grid Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />    <!-- title text -->
                        <ColumnDefinition Width="200" />     <!-- search -->
                        <ColumnDefinition Width="Auto" />    <!-- drag toggle -->
                        <ColumnDefinition Width="*" />       <!-- sliders (drag-mode only) -->
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Markup:Loc Launcher_Title}"
                               Foreground="#FFF" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,16,0" />
                    <ui:TextBox Grid.Column="1" x:Name="SearchBox"
                                PlaceholderText="{Markup:Loc Clipboard_SearchPlaceholder}"
                                FontSize="11"
                                Margin="0,0,8,0"
                                TextChanged="OnSearchTextChanged"
                                ToolTip="{Markup:Loc Launcher_TooltipSearch}" />
                    <ui:Button Grid.Column="2" x:Name="DragToggle" Content="{Markup:Loc Launcher_DragMode}"
                               Padding="10,4" FontSize="11" Margin="0,0,8,0" Click="OnDragToggleClick"
                               ToolTip="{Markup:Loc Launcher_TooltipDragMode}" />
                    <Grid x:Name="DragSizingPanel" Grid.Column="3" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Markup:Loc Launcher_LabelIcon}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                        <Slider Grid.Column="1"
                                Minimum="24" Maximum="96"
                                Value="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0:F0}}"
                                   FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource AccentForegroundDarkBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="3" Text="{Markup:Loc Launcher_LabelLabel}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                        <Slider Grid.Column="4"
                                Minimum="8" Maximum="18"
                                Value="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Grid.Column="5"
                                   Text="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0:F0}}"
                                   FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                    </Grid>
                </Grid>
                </ui:TitleBar.Header>
            </ui:TitleBar>

        <Grid Grid.Row="1" Margin="14,0,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />     <!-- 0: F-strip -->
                <RowDefinition Height="Auto" />     <!-- 1: gap -->
                <RowDefinition Height="Auto" />     <!-- 2: tab strip -->
                <RowDefinition Height="*" />        <!-- 3: row 1 -->
                <RowDefinition Height="*" />        <!-- 4: row 2 -->
                <RowDefinition Height="*" />        <!-- 5: row 3 -->
                <RowDefinition Height="Auto" />     <!-- 6: footer -->
            </Grid.RowDefinitions>

            <!-- ── Function-key strip — global, visible regardless of selected tab ──────────── -->
            <ItemsControl x:Name="FunctionRow" Grid.Row="0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- F-row: same layout shape as the QWERTY rows below — corner
                                     badge + centred icon + label underneath. Icon size and label
                                     font size bind to the parent Window's IconSize / LabelFontSize
                                     (drag-mode sliders) so a single user setting drives every cell. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}"
                                           Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="1" Height="8" /> <!-- gap between the function keys and the tab strip -->

            <ItemsControl x:Name="TabStrip" Grid.Row="2">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Background swap via DataTrigger so both brushes resolve as
                             DynamicResource — switching theme in Settings retunes active +
                             inactive headers immediately. The previous Binding HeaderBackground
                             snapshotted Application.Current.Resources at materialise time and
                             didn't notify on theme change. -->
                        <Border Margin="3,0" CornerRadius="6,6,0,0"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1,1,1,0"
                                MouseLeftButtonDown="OnTabClick"
                                MouseRightButtonDown="OnTabRightClick"
                                Cursor="Hand"
                                Tag="{Binding TabKey}"
                                Height="44"
                                Visibility="{Binding HeaderVisibility}"
                                ToolTip="{Markup:Loc Launcher_TabRenameHint}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentBackgroundBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="6,4">
                                <TextBlock Text="{Binding TabKey}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Accent panel painted behind the active tab's QWERTY grid. The Border spans the
                 three key rows so the tab and its content read as one continuous coloured zone
                 (same convention as a TabControl's selected page). Z-order: declared first so
                 the cells render on top. All four corners round so the panel reads as a real
                 self-contained card regardless of which tab is active (the active tab might be
                 anywhere in the strip, not necessarily the first slot). -->
            <Border Grid.Row="3" Grid.RowSpan="3"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    CornerRadius="6"
                    Margin="-3,0,-3,-3" />

            <ItemsControl x:Name="Row1Host" Grid.Row="3" Margin="0,4,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}"
                                           Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="Row2Host" Grid.Row="4" Margin="0,0,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}"
                                           Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="Row3Host" Grid.Row="5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}"
                                           Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer hint + drag-mode banner side by side, both centred horizontally. The
                 banner only renders while drag mode is on (DragModeBanner.Visibility flipped
                 in SetDragMode); when off the F1-F10 hint sits alone, centred. Banner uses
                 AccentBackgroundLightBrush to read brighter than the always-on hint. -->
            <StackPanel Grid.Row="6" Margin="0,10,0,0" Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="10"
                           VerticalAlignment="Center"
                           Text="{Markup:Loc Launcher_HelpHint}" />
                <TextBlock x:Name="DragModeBanner" Margin="16,0,0,0" FontSize="10"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentBackgroundLightBrush}"
                           Visibility="Collapsed"
                           Text="{Markup:Loc Launcher_DragModeBanner}" />
            </StackPanel>

        </Grid>
    </Grid>
    </Border>
</ui:FluentWindow>
