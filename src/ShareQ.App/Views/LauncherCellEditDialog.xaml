<Window x:Class="ShareQ.App.Views.LauncherCellEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Edit launcher cell"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252525"
        Foreground="White">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: header -->
            <RowDefinition Height="Auto" />  <!-- 1: label -->
            <RowDefinition Height="Auto" />  <!-- 2: path -->
            <RowDefinition Height="Auto" />  <!-- 3: icon -->
            <RowDefinition Height="Auto" />  <!-- 4: args -->
            <RowDefinition Height="Auto" />  <!-- 5: advanced expander -->
            <RowDefinition Height="*" />     <!-- 6: spacer (absorbs slack so button row stays at bottom) -->
            <RowDefinition Height="Auto" />  <!-- 7: ok/cancel -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Label -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Label" Foreground="#DDD" />
            <ui:TextBox Grid.Column="1" x:Name="LabelBox"
                        PlaceholderText="(short name shown on the cell)" />
        </Grid>

        <!-- Path with both pickers (file or folder) -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Path / target" Foreground="#DDD" />
            <ui:TextBox Grid.Column="1" x:Name="PathBox"
                        PlaceholderText="exe / file / folder / URL — anything the shell can open" />
            <ui:Button Grid.Column="2" Content="📄" Margin="4,0,0,0" Padding="6,2"
                       Click="OnPickFile" ToolTip="Pick a file…" />
            <ui:Button Grid.Column="3" Content="📁" Margin="4,0,0,0" Padding="6,2"
                       Click="OnPickFolder" ToolTip="Pick a folder…" />
        </Grid>

        <!-- Custom icon override + multi-icon container index -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Icon" Foreground="#DDD" />
            <ui:TextBox Grid.Column="1" x:Name="IconBox"
                        PlaceholderText="(optional — custom .ico / .png / .jpg overriding the default shell icon)" />
            <!-- Index = which icon inside a multi-icon container (.dll/.exe/.ico). 0 = first.
                 Useful when the user picks shell32.dll or imageres.dll and wants the N-th
                 icon out of the hundreds those files carry. Ignored for raster images. -->
            <ui:TextBox Grid.Column="2" x:Name="IconIndexBox"
                        PlaceholderText="0"
                        ToolTip="Icon index inside a multi-icon container (.dll / .exe / .ico). 0 = first."
                        Margin="4,0,0,0" />
            <ui:Button Grid.Column="3" Content="📄" Margin="4,0,0,0" Padding="6,2"
                       Click="OnPickIcon" ToolTip="Pick an icon file…" />
            <ui:Button Grid.Column="4" Content="✕" Margin="4,0,0,0" Padding="6,2"
                       Click="OnClearIcon" ToolTip="Clear the custom icon (revert to default shell icon)." />
        </Grid>

        <!-- Args -->
        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Args" Foreground="#DDD" />
            <ui:TextBox Grid.Column="1" x:Name="ArgsBox"
                        PlaceholderText="(optional command-line arguments)" />
        </Grid>

        <!-- Advanced options: admin elevation + window mode + activate-if-running matchers -->
        <Expander Grid.Row="5" Header="Advanced" Foreground="#DDD" Margin="0,4,0,0" IsExpanded="False">
            <StackPanel Margin="0,8,0,0">
                <CheckBox x:Name="RunAsAdminBox" Content="Run as administrator"
                          Foreground="#DDD" Margin="0,0,0,8"
                          ToolTip="Launch with the &quot;runas&quot; verb so Windows prompts UAC for elevation. Use sparingly — admin processes can change system state." />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Window mode" Foreground="#DDD" />
                    <ComboBox Grid.Column="1" x:Name="WindowModeBox"
                              ToolTip="How the launched window appears initially. Most GUI apps honour Maximized/Minimized; some ignore the hint. Hidden runs the process without showing a window — useful for headless tasks." />
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Window title" Foreground="#DDD" />
                    <ui:TextBox Grid.Column="1" x:Name="WindowTitleBox"
                                PlaceholderText="(if a window with this title is open, focus it instead of launching)" />
                    <!-- "Pick window" opens a list of currently-open windows; choosing one fills
                         both Window Title and Process Name. Same UX ShareX uses in its
                         Tools→Borderless Window flow. -->
                    <ui:Button Grid.Column="2" Content="🔍" Margin="4,0,0,0" Padding="6,2"
                               Click="OnPickWindow"
                               ToolTip="Pick from currently-open windows…" />
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Process name" Foreground="#DDD" />
                    <ui:TextBox Grid.Column="1" x:Name="ProcessNameBox"
                                PlaceholderText="(if a process with this name is running, focus it — e.g. notepad)" />
                </Grid>

                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="Window title / process name: substring match (case-insensitive). Either one being non-empty enables &quot;activate if already running&quot; mode — the cell focuses the existing window instead of starting a new instance. Leave both empty for the default &quot;always launch&quot; behaviour." />
            </StackPanel>
        </Expander>

        <!-- OK / Cancel docked at the bottom -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="Clear" Width="80" Margin="0,0,8,0" Click="OnClearClicked"
                       ToolTip="Empty this cell — removes the mapping." />
            <Button x:Name="OkButton" Content="OK" Width="80" Height="32" Margin="0,0,4,0"
                    IsDefault="True" Click="OnOkClicked" FontWeight="SemiBold"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <ui:Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancelClicked" />
        </StackPanel>
    </Grid>
</Window>
