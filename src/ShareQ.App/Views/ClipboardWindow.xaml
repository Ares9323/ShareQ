<ui:FluentWindow x:Class="ShareQ.App.Views.ClipboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
        Title="ShareQ - Clipboard"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="980" Height="600"
        MinWidth="640" MinHeight="380"
        WindowStartupLocation="Manual"
        WindowBackdropType="None"
        Background="{DynamicResource Surface2Brush}"
        ExtendsContentIntoTitleBar="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <ui:FluentWindow.Resources>
        <!-- Same Primary-button override as the Settings sidebar: rest = AccentBackgroundDark
             (deeper green/blue), hover/pressed flip to the brighter AccentBackground for
             visible feedback. Border colour matches the fill so no light halo around the
             primary buttons. Scoped to this Window so other Primary buttons elsewhere stay
             on the global accent. Covers the selected category tab, the toolbar copy/edit/pin
             buttons, the Clear all button, and any future Primary button added to the popup. -->
        <SolidColorBrush x:Key="AccentButtonBackground"
                         Color="{DynamicResource AccentBackgroundDarkColor}" />
        <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"
                         Color="{DynamicResource AccentBackgroundColor}" />
        <SolidColorBrush x:Key="AccentButtonBackgroundPressed"
                         Color="{DynamicResource AccentBackgroundColor}" />
        <SolidColorBrush x:Key="AccentControlElevationBorderBrush"
                         Color="{DynamicResource AccentBackgroundDarkColor}" />
        <SolidColorBrush x:Key="AccentButtonBorderBrushPressed"
                         Color="{DynamicResource AccentBackgroundColor}" />
    </ui:FluentWindow.Resources>
    <!-- Accent-tinted 2px frame around the whole window content (titlebar + body), matching
         MainWindow / ImageEffectsWindow / GradientEditorWindow / QrGeneratorWindow. FluentWindow's
         own chrome stays outside this Border, so the accent line reads as an inner "telaio". -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0 titlebar -->
                <RowDefinition Height="*" />     <!-- 1 main content -->
            </Grid.RowDefinitions>

            <!-- WPF-UI titlebar — handles drag, double-click maximise, min/max/close buttons,
                 and the dark caption color via DWM. Replaces the old custom DragHandle that had
                 to live inside an AllowsTransparency=True window with a manual Thumb resize. -->
            <ui:TitleBar Grid.Row="0" Title="ShareQ - Clipboard">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{StaticResource ShareQLogo}" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <Grid Grid.Row="1" Margin="14,0,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- type chips + tabs + Clear all + search (combined header) -->
                    <RowDefinition Height="*" />     <!-- history + toolbar + preview -->
                    <RowDefinition Height="Auto" />  <!-- footer -->
                </Grid.RowDefinitions>

                <!-- ── Combined header: image/files chips, category tabs, Clear all, search.
                      Single row to save vertical space — replaces the old two-row layout where
                      Clear all + search lived above the tab strip and a kind-filter dropdown
                      sat to the right of the tabs. ───────────────────────────────────────── -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- type chips -->
                        <ColumnDefinition Width="*" />     <!-- category tabs -->
                        <ColumnDefinition Width="Auto" />  <!-- Clear all -->
                        <ColumnDefinition Width="220" />   <!-- search -->
                    </Grid.ColumnDefinitions>

                    <!-- Type chips. ToggleButton; ON = include that kind in the list, OFF =
                         hide. ShowImages also covers files / videos; ShowText covers HTML
                         (an image-URL pasted from a browser is HTML clipboard, not Image — gating
                         it under the text chip matches user expectation). Both off = empty list.
                         State persisted to clipboard.show_images / clipboard.show_text.
                         Background = AccentBackgroundDarkBrush so the chips match the unselected
                         category-tab tone next to them; foreground stays the default light
                         AccentForegroundBrush so the glyph reads on top. -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <StackPanel.Resources>
                            <!-- Off → Surface3Brush (neutral, "filter not applied").
                                 On → AccentBackgroundDarkBrush (the inactive-tab tone, signals
                                 the filter is active). Hover → AccentBackgroundBrush (highlight).
                                 Foreground stays light at every state. -->
                            <Style TargetType="ToggleButton">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Surface3Brush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBackgroundBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBackgroundBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>
                        <ToggleButton IsChecked="{Binding ShowImages, Mode=TwoWay}"
                                      Margin="0,0,4,0">
                            <ToggleButton.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="Image filter" FontWeight="SemiBold" />
                                        <TextBlock Text="When on, the list includes:" Margin="0,4,0,2" />
                                        <TextBlock Text="• Images (PNG, JPEG, BMP, GIF, screenshots)" />
                                        <TextBlock Text="• File copies (Explorer Ctrl+C / drag-drop, .sxie etc.)" />
                                        <TextBlock Text="• Video / GIF recordings (.mp4, .gif)" />
                                        <TextBlock Text="Click to hide all of these." Margin="0,4,0,0" FontStyle="Italic" />
                                    </StackPanel>
                                </ToolTip>
                            </ToggleButton.ToolTip>
                            <TextBlock Text="&#xEB9F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding ShowText, Mode=TwoWay}">
                            <ToggleButton.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="Text filter" FontWeight="SemiBold" />
                                        <TextBlock Text="When on, the list includes:" Margin="0,4,0,2" />
                                        <TextBlock Text="• Plain text (everything you copy as text)" />
                                        <TextBlock Text="• HTML (browsers' Copy link / Copy image address)" />
                                        <TextBlock Text="• RTF (formatted text from Word / Outlook / etc.)" />
                                        <TextBlock Text="Click to hide all of these." Margin="0,4,0,0" FontStyle="Italic" />
                                    </StackPanel>
                                </ToolTip>
                            </ToggleButton.ToolTip>
                            <!-- E8A5 = Document — universal page glyph available in both Segoe
                                 Fluent Icons (Win11) and Segoe MDL2 Assets (Win10) fallback. -->
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                    </StackPanel>

                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Categories}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryTab}">
                                <!-- Icon + name on the same row. Icon is empty for the
                                     synthetic "All" tab and for categories the user hasn't
                                     given an emoji to; the StackPanel collapses spacing in
                                     that case (no margin around an empty TextBlock). -->
                                <ui:Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding Name}"
                                           Appearance="{Binding IsActive, Converter={StaticResource BoolToAppearance}}"
                                           Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{DynamicResource IconFont}"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Icon, Converter={StaticResource NonEmptyToVisibility}}" />
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </ui:Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ui:Button Grid.Column="2"
                               Content="Clear all"
                               Appearance="Danger"
                               Margin="8,0,8,0"
                               Cursor="Arrow"
                               Command="{Binding ClearAllCommand}"
                               ToolTip="Delete every non-pinned item (Ctrl+Shift+Del)" />
                    <ui:TextBox Grid.Column="3" x:Name="SearchBox"
                                PlaceholderText="🔍 Search…"
                                FontSize="11"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!-- ── Body: history list | splitter | preview pane | vertical toolbar ────── -->
                <!-- Toolbar lives in the rightmost (Auto) column so the GridSplitter (col 1)
                     resizes only the list and the preview — the toolbar stays anchored to the
                     window's right edge and never gets in the way of the resize handle. -->
                <Grid Grid.Row="1">
                    <!-- MinWidths kept low so the toolbar (Auto column on the right) is always
                         guaranteed its ~40 px regardless of how aggressively the user shrinks the
                         window. The preview column's content (text + image) wraps/scales below
                         these mins, which is the right trade-off — losing toolbar buttons on
                         shrink is much worse than a tighter preview. -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="160" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition x:Name="PreviewColumn" Width="2*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource Surface1Brush}"
                            BorderBrush="{DynamicResource Surface3Brush}" BorderThickness="1" CornerRadius="4"
                            Padding="6">
                            <ListBox x:Name="HistoryList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding Rows}"
                                     SelectedItem="{Binding SelectedRow}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <!-- Kill the system focus rectangle (the faint blue square
                                             outline on the selected row) — we already paint our own
                                             selection state on the inner Border via IsSelected
                                             DataTrigger below. -->
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <!-- Replace the default ListBoxItem template with a flat
                                             ContentPresenter. The default template renders a
                                             SystemColors-tinted selection chrome on top of our
                                             custom Border, producing the doubled-up "blue rectangle
                                             over green fill" look the user reported. A transparent
                                             pass-through template lets the inner Border be the only
                                             visual for selection / hover. -->
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ItemRowViewModel}">
                                        <Border Padding="8,6" Margin="0,2"
                                                CornerRadius="4"
                                                BorderThickness="2"
                                                PreviewMouseRightButtonDown="OnItemRowPreviewRightClick"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Border.ContextMenu>
                                                <!-- ContextMenu lives in a popup outside the visual tree, so
                                                     RelativeSource AncestorType=Window doesn't resolve from inside.
                                                     Stash the parent VM in Border.Tag and rebind the menu's
                                                     DataContext via PlacementTarget.Tag. -->
                                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="Pin / unpin"
                                                              Command="{Binding TogglePinSelectedCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Move to"
                                                              ItemsSource="{Binding MovableCategories}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command"
                                                                        Value="{Binding DataContext.MoveSelectedToCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <MenuItem Header="Copy to"
                                                              ItemsSource="{Binding MovableCategories}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command"
                                                                        Value="{Binding DataContext.CopySelectedToCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <Separator />
                                                    <!-- Generate QR — only meaningful for text-shaped rows
                                                         (Text/Html/Rtf). On Image/Video/Files the entry hides
                                                         entirely; the handler still has a defensive bail-out for
                                                         programmatic invocation paths. -->
                                                    <MenuItem Header="Generate QR code…"
                                                              Click="OnGenerateQrFromItemClicked"
                                                              Visibility="{Binding IsTextSelected, Converter={StaticResource BoolToVisibility}}" />
                                                    <Separator />
                                                    <MenuItem Header="Delete"
                                                              Command="{Binding DeleteSelectedCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBackgroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Left rail: Ctrl+N quick-paste badge on top, pin glyph below.
                                                     Each collapses when its trigger is false. -->
                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,0,8,0">
                                                    <Border Width="22" Height="22"
                                                            Background="{DynamicResource AccentBackgroundLightBrush}"
                                                            CornerRadius="3"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,0,0,2"
                                                            Visibility="{Binding HasIndexBadge, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding IndexBadge}"
                                                                   Foreground="{DynamicResource Surface1Brush}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Foreground="Gold" FontSize="11" Text="📌" HorizontalAlignment="Center"
                                                               Visibility="{Binding Pinned, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Width="56" Height="56"
                                                        Margin="0,0,10,0"
                                                        Background="{DynamicResource Surface1Brush}"
                                                        BorderBrush="#444" BorderThickness="1"
                                                        Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}">
                                                    <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                                           Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Preview}"
                                                               Foreground="{DynamicResource AccentForegroundBrush}"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="60"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding Age}" />
                                                        <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding KindLabel}" />
                                                        <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding SourceProcess}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="4"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ShowsPreview="False" />

                    <!-- Preview pane: meta line + image / text / RTF / HTML body. The body
                         visibilities are driven by the VM's IsImagePreview / IsTextPreview /
                         IsRtfPreview / IsHtmlPreview flags. RichTextBox.Document and
                         WebBrowser.NavigateToString aren't bindable — code-behind watches the
                         VM's PropertyChanged and pushes the documents imperatively. -->
                    <Border Grid.Column="2"
                            x:Name="PreviewPane"
                            Background="{DynamicResource Surface1Brush}"
                            BorderBrush="{DynamicResource Surface3Brush}" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Margin="8,6"
                                       Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding PreviewMeta}" />
                            <Grid Grid.Row="1" Margin="0,0,0,4">
                                <!-- Image preview wrapped in a ScrollViewer so the user can pan after
                                     zooming. Ctrl+wheel scales the LayoutTransform (PreviewMouseWheel
                                     in code-behind to intercept before the ScrollViewer tries to
                                     consume the event for vertical scroll). The wheel without Ctrl
                                     keeps the default scroll behaviour. PreviewImageScale is reset
                                     to 1.0 every time SelectedRow flips so a new item starts
                                     fit-to-container instead of inheriting the previous zoom. -->
                                <ScrollViewer x:Name="PreviewImageScroller"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="OnPreviewImageWheel"
                                              PreviewMouseRightButtonDown="OnPreviewImageRightButtonDown"
                                              PreviewMouseMove="OnPreviewImageMouseMove"
                                              PreviewMouseRightButtonUp="OnPreviewImageRightButtonUp"
                                              Visibility="{Binding IsImagePreview, Converter={StaticResource BoolToVisibility}}">
                                    <Image Source="{Binding PreviewImageBytes, Converter={StaticResource BytesToImage}}"
                                           Stretch="Uniform"
                                           Margin="8">
                                        <Image.LayoutTransform>
                                            <ScaleTransform x:Name="PreviewImageScale" ScaleX="1" ScaleY="1" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </ScrollViewer>
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         FontSize="12"
                                         Margin="6,0,6,6"
                                         Visibility="{Binding IsTextPreview, Converter={StaticResource BoolToVisibility}}" />
                                <RichTextBox x:Name="RtfPreviewBox"
                                             IsReadOnly="True"
                                             IsTabStop="False"
                                             Background="Transparent"
                                             Foreground="White"
                                             BorderThickness="0"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Margin="6,0,6,6"
                                             Visibility="{Binding IsRtfPreview, Converter={StaticResource BoolToVisibility}}" />
                                <WebBrowser x:Name="HtmlPreviewBox"
                                            Margin="6,0,6,6"
                                            Visibility="{Binding IsHtmlPreview, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Vertical CopyQ-style icon toolbar — anchored to the window's right edge
                         so the GridSplitter has clear vertical track. Glyphs are Segoe Fluent
                         Icons (built-in on Win11; Segoe MDL2 Assets on Win10 — same code points).
                         Wrapped in a ScrollViewer so a very short window can scroll the toolbar
                         instead of clipping the bottom buttons. -->
                    <ScrollViewer Grid.Column="3"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="8,2,0,2">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Paste (Enter)"
                                       Appearance="Primary"
                                       Command="{Binding PasteSelectedCommand}">
                                <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Pin / unpin (Ctrl+P)"
                                       Command="{Binding TogglePinSelectedCommand}">
                                <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Generate QR — opens the live generator pre-filled with the row's
                                 preview text. Visible only for text-shaped rows (Text/Html/Rtf):
                                 a QR code carries a textual payload, so on Image/Video/Files
                                 rows the button has nothing useful to do and collapses out. -->
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Generate QR code…"
                                       Click="OnGenerateQrFromItemClicked"
                                       Visibility="{Binding IsTextSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xED14;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Edit / show-in-explorer hidden (Visibility=Collapsed) when they
                                 don't apply to the current selection — text rows have nothing to
                                 edit, ephemeral entries have no file on disk to reveal. -->
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Open in editor (image only)"
                                       Command="{Binding OpenInEditorCommand}"
                                       Visibility="{Binding IsImageSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Show in explorer"
                                       Command="{Binding OpenInExplorerCommand}"
                                       Visibility="{Binding HasFileOnDisk, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Open URL in browser — visible only when the selected text item parses
                                 as an http(s) URL. Glyph: Globe (Segoe Fluent Icons E774). -->
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Open URL in browser"
                                       Command="{Binding OpenInBrowserCommand}"
                                       Visibility="{Binding IsUrlSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Capture webpage — visible when the row holds a URL AND the
                                 WebView2 Runtime is installed (CanCaptureWebpage). Older Win10
                                 builds without the runtime get the button hidden entirely; the
                                 tray menu offers a "(install runtime)" fallback in that case.
                                 Renders the URL in a hidden WebView2, feeds the PNG into the
                                 webpage-capture pipeline (save / history / copy / upload /
                                 toast). Glyph: ScreenSnapshot (E89E). -->
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="Capture webpage (full-page screenshot of the URL)"
                                       Command="{Binding CaptureWebpageCommand}"
                                       Visibility="{Binding CanCaptureWebpage, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE89E;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <ui:Button Width="32" Height="32" Padding="0"
                                       ToolTip="Delete (Del)"
                                       Appearance="Danger"
                                       Command="{Binding DeleteSelectedCommand}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── Footer hint ─────────────────────────────────────────────────────────── -->
                <TextBlock Grid.Row="2"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#666" FontSize="11"
                           Text="↑↓ navigate · 1-9 focus · Enter paste · Ctrl+1-9 quick paste · ←→ switch category · Ctrl+F search · Ctrl+P pin · Ctrl+Shift+Del clear all · Esc close" />
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
