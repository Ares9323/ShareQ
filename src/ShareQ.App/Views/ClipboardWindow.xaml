<Window x:Class="ShareQ.App.Views.ClipboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ShareQ.App.ViewModels"
        Title="ShareQ Clipboard"
        Width="980" Height="600"
        MinWidth="640" MinHeight="380"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource Surface2Brush}" CornerRadius="8"
            BorderBrush="#404040" BorderThickness="1">
        <Grid>
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- header -->
                    <RowDefinition Height="Auto" />  <!-- categories tabs + filters -->
                    <RowDefinition Height="*" />     <!-- history + toolbar + preview -->
                    <RowDefinition Height="Auto" />  <!-- footer -->
                </Grid.RowDefinitions>

                <!-- ── Header chrome (icon + title + close + search) ───────────────────────── -->
                <Grid x:Name="DragHandle"
                      Grid.Row="0"
                      Background="#01000000"
                      Cursor="SizeAll"
                      MouseLeftButtonDown="OnChromeMouseDown"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <!-- Header columns: 0 icon | 1 title | 2 spacer | 3 Clear all | 4 search -->

                    <Viewbox Grid.Column="0" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Canvas Width="1024" Height="1024">
                            <Path Fill="#231f20" Data="M446.99,701.31l-2.4-2.08c-33.6-29.05-61.01-64.42-81.47-105.12-21.84-43.44-35.24-92.04-39.82-144.46l-.28-3.18,2.1-2.4c29.09-33.37,64.44-60.58,105.08-80.88,43.36-21.66,91.84-34.93,144.1-39.44l3.17-.27,2.4,2.09c33.48,29.17,60.76,64.63,81.08,105.4,21.7,43.52,34.95,92.18,39.38,144.64l.27,3.17-2.1,2.4c-29.05,33.2-64.31,60.29-104.81,80.5-43.2,21.56-91.5,34.8-143.55,39.35l-3.16.28ZM338.54,451.54c9.08,95.87,48.26,176.75,113.48,234.26,95.17-9,175.63-47.71,233.09-112.11-8.81-95.94-47.72-176.96-112.7-234.71-95.57,8.95-176.3,47.8-233.87,112.55Z" />
                            <Path Fill="#7fc99a" Data="M179.8,319.76c30.38-24.76,63.9-42.45,98.84-53.39,100.3-34.16,214.75-19.6,297.56,64.75-.42.04-.84.08-1.26.12,63.28,55.14,108.88,138.11,117.92,245.02,69.06-78.94,94.67-185.56,69.22-283.11-12.52-42.92-33.91-83.68-62.6-118.84-37.14-43.16-89.06-79.51-156.87-103.83.38-.16.75-.3,1.13-.46C293.55-30.89-45.1,203.09,69.26,480.9c.09-.21.17-.43.25-.64,18.86-65.53,59.02-120.59,110.29-160.51Z" />
                            <Path Fill="#7fc99a" Data="M954.49,544.58c-60.98,211.84-344.51,314.36-506.7,149.14.57-.05,1.13-.11,1.7-.16-63.51-54.92-109.38-137.74-118.72-244.56-70.49,80.86-95.51,190.62-66.87,289.93,13.54,42.36,35.76,82.37,65.07,116.66,36.8,40.93,87.27,75.4,152.41,98.76-.11.04-.21.08-.32.13,249.77,99.47,586.53-133.48,473.61-410.38-.06.15-.12.31-.18.46Z" />
                            <Path Fill="#e6e7e7" Data="M328.98,855.6c-31.55-35.1-53.04-74.96-65.07-116.66-28.64-99.31-3.62-209.07,66.87-289.93,55-63.09,137.68-108.58,244.16-117.78.42-.04.84-.08,1.26-.12-82.81-84.36-197.26-98.91-297.56-64.75-35.38,12.05-68.99,30.15-98.84,53.39-51.27,39.92-91.43,94.98-110.29,160.51-.09.21-.17.43-.25.64-100.35,250.34,133.93,588.68,411.81,473.59.11-.04.21-.08.32-.13-65.14-23.36-115.61-57.83-152.41-98.76Z" />
                            <Path Fill="#e6e7e7" Data="M699.48,174.31c30.9,35.9,51.55,76.51,62.6,118.84,25.45,97.55-.16,204.16-69.22,283.11-54.92,62.78-137.32,108.05-243.36,117.32-.57.05-1.13.11-1.7.16,162.19,165.22,445.72,62.7,506.7-149.14.06-.15.12-.31.18-.46,100.44-250.12-133.34-588.22-410.93-474.09-.38.16-.75.3-1.13.46,67.81,24.32,119.73,60.67,156.87,103.83Z" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Grid.Column="1" Text="ShareQ Clipboard"
                               Foreground="#FFF" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center" />
                    <ui:Button Grid.Column="3"
                               Content="Clear all"
                               Margin="0,0,8,0"
                               Cursor="Arrow"
                               Command="{Binding ClearAllCommand}"
                               ToolTip="Delete every non-pinned item (Ctrl+Shift+Del)" />
                    <ui:TextBox Grid.Column="4" x:Name="SearchBox"
                                PlaceholderText="🔍 Search…"
                                FontSize="11"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!-- ── Categories tab strip + Filters dropdown ─────────────────────────────── -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="0" ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryTab}">
                                <ui:Button Content="{Binding DisplayName}"
                                           Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding Name}"
                                           Appearance="{Binding IsActive, Converter={StaticResource BoolToAppearance}}"
                                           Margin="0,0,4,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ComboBox Grid.Column="1"
                              x:Name="FiltersBox"
                              Width="120"
                              SelectedIndex="0"
                              SelectionChanged="OnFilterChanged"
                              ToolTip="Filter by item type">
                        <ComboBoxItem Content="All"   Tag="{x:Null}" />
                        <ComboBoxItem Content="Text"  Tag="Text" />
                        <ComboBoxItem Content="Image" Tag="Image" />
                    </ComboBox>
                </Grid>

                <!-- ── Body: history list | splitter | preview pane | vertical toolbar ────── -->
                <!-- Toolbar lives in the rightmost (Auto) column so the GridSplitter (col 1)
                     resizes only the list and the preview — the toolbar stays anchored to the
                     window's right edge and never gets in the way of the resize handle. -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition x:Name="PreviewColumn" Width="2*" MinWidth="240" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource Surface1Brush}"
                            BorderBrush="#333" BorderThickness="1" CornerRadius="4"
                            Padding="6">
                            <ListBox x:Name="HistoryList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding Rows}"
                                     SelectedItem="{Binding SelectedRow}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ItemRowViewModel}">
                                        <Border Padding="8,6" Margin="0,2"
                                                CornerRadius="4"
                                                BorderThickness="2"
                                                PreviewMouseRightButtonDown="OnItemRowPreviewRightClick"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Border.ContextMenu>
                                                <!-- ContextMenu lives in a popup outside the visual tree, so
                                                     RelativeSource AncestorType=Window doesn't resolve from inside.
                                                     Stash the parent VM in Border.Tag and rebind the menu's
                                                     DataContext via PlacementTarget.Tag. -->
                                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="Pin / unpin"
                                                              Command="{Binding TogglePinSelectedCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Move to"
                                                              ItemsSource="{Binding MovableCategories}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command"
                                                                        Value="{Binding DataContext.MoveSelectedToCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <MenuItem Header="Copy to"
                                                              ItemsSource="{Binding MovableCategories}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command"
                                                                        Value="{Binding DataContext.CopySelectedToCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <Separator />
                                                    <MenuItem Header="Delete"
                                                              Command="{Binding DeleteSelectedCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Background" Value="#2A3340" />
                                                            <Setter Property="BorderBrush" Value="#5A7CA8" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Left rail: Ctrl+N quick-paste badge on top, pin glyph below.
                                                     Each collapses when its trigger is false. -->
                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,0,8,0">
                                                    <Border Width="22" Height="22"
                                                            Background="#3A3A3A"
                                                            CornerRadius="3"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,0,0,2"
                                                            Visibility="{Binding HasIndexBadge, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding IndexBadge}"
                                                                   Foreground="#DDD"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Foreground="Gold" FontSize="11" Text="📌" HorizontalAlignment="Center"
                                                               Visibility="{Binding Pinned, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Width="56" Height="56"
                                                        Margin="0,0,10,0"
                                                        Background="{DynamicResource Surface1Brush}"
                                                        BorderBrush="#444" BorderThickness="1"
                                                        Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}">
                                                    <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                                           Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Preview}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="60"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding Age}" />
                                                        <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding KindLabel}" />
                                                        <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding SourceProcess}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="4"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ShowsPreview="False" />

                    <!-- Preview pane: meta line + image / text / RTF / HTML body. The body
                         visibilities are driven by the VM's IsImagePreview / IsTextPreview /
                         IsRtfPreview / IsHtmlPreview flags. RichTextBox.Document and
                         WebBrowser.NavigateToString aren't bindable — code-behind watches the
                         VM's PropertyChanged and pushes the documents imperatively. -->
                    <Border Grid.Column="2"
                            x:Name="PreviewPane"
                            Background="{DynamicResource Surface1Brush}"
                            BorderBrush="#333" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Margin="8,6"
                                       Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding PreviewMeta}" />
                            <Grid Grid.Row="1" Margin="0,0,0,4">
                                <Image Source="{Binding PreviewImageBytes, Converter={StaticResource BytesToImage}}"
                                       Stretch="Uniform"
                                       Margin="8"
                                       Visibility="{Binding IsImagePreview, Converter={StaticResource BoolToVisibility}}" />
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         FontSize="12"
                                         Margin="6,0,6,6"
                                         Visibility="{Binding IsTextPreview, Converter={StaticResource BoolToVisibility}}" />
                                <RichTextBox x:Name="RtfPreviewBox"
                                             IsReadOnly="True"
                                             IsTabStop="False"
                                             Background="Transparent"
                                             Foreground="White"
                                             BorderThickness="0"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Margin="6,0,6,6"
                                             Visibility="{Binding IsRtfPreview, Converter={StaticResource BoolToVisibility}}" />
                                <WebBrowser x:Name="HtmlPreviewBox"
                                            Margin="6,0,6,6"
                                            Visibility="{Binding IsHtmlPreview, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Vertical CopyQ-style icon toolbar — anchored to the window's right edge
                         so the GridSplitter has clear vertical track. Glyphs are Segoe Fluent
                         Icons (built-in on Win11; Segoe MDL2 Assets on Win10 — same code points). -->
                    <StackPanel Grid.Column="3"
                                Orientation="Vertical"
                                Margin="8,2,0,2"
                                VerticalAlignment="Top">
                        <ui:Button Width="32" Height="32" Padding="0"
                                   Margin="0,0,0,4"
                                   ToolTip="Paste (Enter)"
                                   Appearance="Primary"
                                   Command="{Binding PasteSelectedCommand}">
                            <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ui:Button>
                        <ui:Button Width="32" Height="32" Padding="0"
                                   Margin="0,0,0,4"
                                   ToolTip="Pin / unpin (Ctrl+P)"
                                   Command="{Binding TogglePinSelectedCommand}">
                            <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ui:Button>
                        <ui:Button Width="32" Height="32" Padding="0"
                                   Margin="0,0,0,4"
                                   ToolTip="Open in editor (image only)"
                                   Command="{Binding OpenInEditorCommand}">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ui:Button>
                        <ui:Button Width="32" Height="32" Padding="0"
                                   Margin="0,0,0,4"
                                   ToolTip="Show in explorer"
                                   Command="{Binding OpenInExplorerCommand}">
                            <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ui:Button>
                        <ui:Button Width="32" Height="32" Padding="0"
                                   ToolTip="Delete (Del)"
                                   Appearance="Danger"
                                   Command="{Binding DeleteSelectedCommand}">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ui:Button>
                    </StackPanel>
                </Grid>

                <!-- ── Footer hint ─────────────────────────────────────────────────────────── -->
                <TextBlock Grid.Row="3"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#666" FontSize="11"
                           Text="↑↓ navigate · 1-9 focus · Enter paste · Ctrl+1-9 quick paste · ←→ switch category · Ctrl+F search · Ctrl+P pin · Ctrl+Shift+Del clear all · Esc close" />
            </Grid>

            <!-- Resize grip — same pattern as the launcher (manual thumb because
                 AllowsTransparency hides the standard window-border resize cursor). -->
            <Thumb x:Name="ResizeThumb"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="14" Height="14"
                   Cursor="SizeNWSE"
                   DragDelta="OnResizeThumbDelta"
                   Margin="0,0,4,4">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Path Stroke="#888" StrokeThickness="1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 4,13 L 13,4 M 7,13 L 13,7 M 10,13 L 13,10" />
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
