<Window x:Class="ShareQ.App.Views.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">
    <Grid>
        <!-- Red border framing the captured area (not hit-testable so it doesn't intercept clicks
             on apps inside the recorded region). -->
        <Border BorderBrush="#FF0033" BorderThickness="2" IsHitTestVisible="False" />
        <!-- Top-left controller: badge + Stop / Pause / Abort buttons. -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="#CC0033" Padding="8,4"
                CornerRadius="0,0,4,0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock x:Name="ElapsedLabel"
                           Text="REC 00:00"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button x:Name="StopButton" Content="■ Stop"
                        Margin="0,0,4,0" Padding="8,2"
                        Background="#222" Foreground="White" BorderBrush="#555" BorderThickness="1"
                        Click="OnStopClicked" />
                <Button x:Name="PauseButton" Content="⏸ Pause"
                        Margin="0,0,4,0" Padding="8,2"
                        Background="#222" Foreground="White" BorderBrush="#555" BorderThickness="1"
                        Click="OnPauseClicked" />
                <Button x:Name="AbortButton" Content="✕ Abort"
                        Padding="8,2"
                        Background="#222" Foreground="White" BorderBrush="#555" BorderThickness="1"
                        Click="OnAbortClicked" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
