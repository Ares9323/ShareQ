<ui:FluentWindow x:Class="ShareQ.App.Views.QrGeneratorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="ShareQ - QR generator"
                 Width="780" Height="520"
                 MinWidth="640" MinHeight="420"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Surface1Brush}"
                 Foreground="{DynamicResource AccentForegroundBrush}">
    <ui:FluentWindow.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>
        <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}" />
        <Style x:Key="SubduedHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundDarkBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
    <Border Background="{DynamicResource Surface2Brush}" CornerRadius="8"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="ShareQ - QR generator">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{StaticResource ShareQLogo}" Margin="0,0,-12,0" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <!-- Body — multiline editor on the left, live preview + options on the right.
                 Editor takes the lion's share of width because the typical use cases
                 (vCards, ICE cards, JSON payloads) easily run several hundred characters. -->
            <Grid Grid.Row="1" Margin="12,8,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Editor -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Content" Style="{StaticResource SubduedHeader}" />
                    <ui:TextBox Grid.Row="1" x:Name="InputText"
                                AcceptsReturn="True" AcceptsTab="False"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                FontFamily="Consolas"
                                ClearButtonEnabled="False"
                                PlaceholderText="Paste a URL, text, vCard, Wi-Fi credentials, …" />
                    <TextBlock Grid.Row="2" x:Name="StatusText"
                               Foreground="{DynamicResource AccentForegroundDarkBrush}"
                               FontSize="11" Margin="0,4,0,0"
                               Text="0 characters" />
                </Grid>

                <!-- Preview + options -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="16,0,0,0" Width="290">
                    <TextBlock Text="Preview" Style="{StaticResource SubduedHeader}" />
                    <Border Padding="8" Background="White" CornerRadius="4"
                            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="1">
                        <Image x:Name="QrPreview" Width="260" Height="260" Stretch="Uniform" />
                    </Border>

                    <TextBlock Text="Error correction" Style="{StaticResource SubduedHeader}" Margin="0,12,0,4" />
                    <ComboBox x:Name="EccCombo" SelectionChanged="OnOptionsChanged">
                        <ComboBoxItem Tag="L">L — recovers ~7%</ComboBoxItem>
                        <ComboBoxItem Tag="M">M — recovers ~15%</ComboBoxItem>
                        <ComboBoxItem Tag="Q" IsSelected="True">Q — recovers ~25%</ComboBoxItem>
                        <ComboBoxItem Tag="H">H — recovers ~30%</ComboBoxItem>
                    </ComboBox>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Module size" Style="{StaticResource SubduedHeader}" Margin="0" />
                        <TextBlock Grid.Column="1" x:Name="DensityValueText"
                                   Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11"
                                   Text="12 px" />
                    </Grid>
                    <Slider x:Name="DensitySlider" Minimum="4" Maximum="24" Value="12"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="OnOptionsChanged" />
                </StackPanel>
            </Grid>

            <!-- Action footer -->
            <Border Grid.Row="2" Background="{DynamicResource Surface3Brush}" Padding="12,10"
                    CornerRadius="0,0,6,6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Copy image" Margin="0,0,8,0" Click="OnCopyClicked"
                               ToolTip="Copy the QR PNG to the Windows clipboard" />
                    <ui:Button x:Name="SaveToHistoryButton"
                               Content="Save to history" Margin="0,0,8,0" Click="OnSaveToHistoryClicked"
                               ToolTip="Save the QR PNG to the screenshot folder + insert into the clipboard history (same flow as captures)" />
                    <ui:Button Content="Save PNG…" Margin="0,0,8,0" Click="OnSavePngClicked" />
                    <ui:Button Content="Save SVG…" Margin="0,0,8,0" Click="OnSaveSvgClicked"
                               ToolTip="Save as scalable vector — keeps sharp at any size" />
                    <ui:Button Content="Close" Width="80" Click="OnCloseClicked" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
    <!-- Resize grip — same three-stroke glyph used by the launcher's resize thumb so the
         affordance reads consistently across the app. The window is already resizable from
         every edge (FluentWindow default), this is purely a visual indicator at the corner. -->
    <Thumb HorizontalAlignment="Right" VerticalAlignment="Bottom"
           Width="14" Height="14" Margin="0,0,4,4"
           Cursor="SizeNWSE"
           DragDelta="OnResizeThumbDelta">
        <Thumb.Template>
            <ControlTemplate TargetType="Thumb">
                <Grid Background="Transparent">
                    <Path Stroke="#888" StrokeThickness="1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 4,13 L 13,4 M 7,13 L 13,7 M 10,13 L 13,10" />
                </Grid>
            </ControlTemplate>
        </Thumb.Template>
    </Thumb>
    </Grid>
</ui:FluentWindow>
