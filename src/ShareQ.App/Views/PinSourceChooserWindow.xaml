<Window x:Class="ShareQ.App.Views.PinSourceChooserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Pin to screen"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E"
        Foreground="White"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
    <StackPanel Margin="20" Width="320">
        <TextBlock Text="Pin to screen" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Pick a source for the image you want to pin on top of everything else."
                   Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" />
        <ui:Button x:Name="FromScreenButton" Content="From screen…"
                   HorizontalAlignment="Stretch" Margin="0,0,0,6"
                   ToolTip="Drag a region on the screen; the captured area stays pinned at its original position." />
        <ui:Button x:Name="FromClipboardButton" Content="From clipboard"
                   HorizontalAlignment="Stretch" Margin="0,0,0,6"
                   ToolTip="Pin the image currently on the system clipboard." />
        <ui:Button x:Name="FromFileButton" Content="From file…"
                   HorizontalAlignment="Stretch" Margin="0,0,0,12"
                   ToolTip="Pick a PNG / JPG / BMP / GIF file and pin it." />
        <ui:Button x:Name="CancelButton" Content="Cancel" HorizontalAlignment="Right" Width="100" />
    </StackPanel>
</Window>
