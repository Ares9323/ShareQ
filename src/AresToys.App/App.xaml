                        <GeometryDrawing Brush="#ffffff" Geometry="M55.77,4.31c3.45-.92,6.28,1.57,5.56,5.02-.29,1.4-6.84,8.29-8.22,9.22-2.53,1.7-4.33-4.15-6.92-4.89,2.35-2.05,6.78-8.6,9.59-9.35Z" />
