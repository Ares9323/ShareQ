<Application x:Class="AresToys.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:cv="clr-namespace:AresToys.App.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <cv:BoolToAppearanceConverter x:Key="BoolToAppearance" />
            <cv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <cv:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
            <cv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <cv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility" />
            <cv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />
            <cv:BoolToOpacityConverter x:Key="BoolToOpacity" />
            <cv:InverseBoolConverter x:Key="InverseBool" />
            <cv:ZeroToVisibilityConverter x:Key="ZeroToVisibility" />
            <cv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <cv:BytesToImageConverter x:Key="BytesToImage" />
            <cv:EnumValueDisplayConverter x:Key="EnumValueDisplay" />
            <cv:ColorToBrushConverter x:Key="ColorToBrush" />

            <!-- Checker pattern — used as a backdrop behind any partially-transparent fill so
                 the user can see the alpha (gradient stops, picked colours, preview swatches).
                 Same convention as Photoshop / GIMP / ShareX. -->
            <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" Stretch="None"
                          Viewport="0,0,10,10" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#3A3A3A">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,10,10" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#5A5A5A">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,5,5" />
                                    <RectangleGeometry Rect="5,5,5,5" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- AresToys logo — pre-rendered 1024×1024 PNG (Assets/AresToysLogo.png) shared by every
                 window's title-bar ImageIcon. ImageSource-typed so it plugs into ui:ImageIcon,
                 Image.Source, and Window.Icon. -->
            <BitmapImage x:Key="AresToysLogo" UriSource="pack://application:,,,/Assets/AresToysLogo.png" />

            <!-- Eyedropper / colour-picker icon — multi-colour pipette with R/Y/G/B corner
                 segments forming a "select-colour" mark. Used by the Trace window's
                 Ignore-Color row and any other "open the screen sampler" affordance. ViewBox
                 is 64x64 to match the source SVG; consumers set Width/Height when placing. -->
            <DrawingImage x:Key="EyedropperIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#ff931e" Geometry="M51.29,38.49c.01,10.65-9.76,21.43-20.36,22.43-.6.06-1.65-.11-1.65-.67v-11.26c3.82-1.62,6.5-2.35,8.61-6.23.78-1.43.77-3.07,1.88-4.26h11.52Z" />
                        <GeometryDrawing Brush="#ff1d25" Geometry="M26.72,60.72c-10.65.01-21.43-9.76-22.43-20.36-.06-.6.11-1.65.67-1.65h11.26c1.62,3.82,2.35,6.5,6.23,8.61,1.43.78,3.07.77,4.26,1.88v11.52Z" />
                        <GeometryDrawing Brush="#3fa9f5" Geometry="M4.5,35.88c-.01-10.65,9.76-21.43,20.36-22.43.6-.06,1.65.11,1.65.67v11.26c-3.82,1.62-6.5,2.35-8.61,6.23-.78,1.43-.77,3.07-1.88,4.26H4.5Z" />
                        <GeometryDrawing Brush="#ffffff" Geometry="M42.4,17.54c.48-.08,5.28,4.49,5.59,5.09.2.39.34.63,0,1.02,0,0-12.27,12.27-13.6,13.56s-4.22.38-5.14,1.24-3.06-1.38-2-2.18-.17-3.23,1.59-5.13,13.57-13.59,13.57-13.59Z" />
                        <GeometryDrawing Brush="#ffffff" Geometry="M55.77,4.31c3.45-.92,6.28,1.57,5.56,5.02-.29,1.4-6.84,8.29-8.22,9.22-2.53,1.7-4.33-4.15-6.92-4.89,2.35-2.05,6.78-8.6,9.59-9.35Z" />
                        <GeometryDrawing Brush="#7ac943" Geometry="M29.28,13.92c4.09-.48,7.79,1.52,11.27,3.33,0,.63-8.1,8.98-8.69,9.2-.72.27-2.06-.43-2.58-1.02v-11.52Z" />
                        <GeometryDrawing Brush="#7ac943" Geometry="M51.29,35.93h-11.52l-.79-1.28,8.47-9.47c2.1-.03,4.02,8.87,3.83,10.76Z" />
                        <GeometryDrawing Brush="#ffffff" Geometry="M45.99,19.21c-.96-1.01-3.07-1.83-3.34-3.62-.19-1.24.93-2.45,2.13-2.13.52.14,6.85,6.54,7.16,7.26.35.83-.14,2.11-.99,2.36-1.95.59-3.89-2.75-4.96-3.87Z" />
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>

            <!-- FontAwesome Free Solid embedded via the standard WPF font-resource syntax.
                 Path before "#" is the folder relative to the assembly root; string after "#"
                 is the font's INTERNAL Family Name (verified via PrivateFontCollection), not
                 the filename. Used by category icons and the icon-picker dialog. -->
            <FontFamily x:Key="IconFont">/Assets/Fonts/#Font Awesome 7 Free Solid</FontFamily>

            <!-- Implicit TextBlock style: routes every plain TextBlock that doesn't set
                 Foreground locally onto AccentForegroundBrush via DynamicResource. WPF-UI v4's
                 FluentWindow template sets TextElement.Foreground with a StaticResource — the
                 reference is snapshotted at template instantiation, so swapping
                 TextFillColorPrimaryBrush at runtime never reaches the inherited tone. By
                 putting a DynamicResource on the implicit Style we get live retheming for the
                 thousands of "labelled hex" / header / inline-info TextBlocks across the app
                 without touching them one by one. Local Foreground setters still win. -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            </Style>


        </ResourceDictionary>
    </Application.Resources>
</Application>
