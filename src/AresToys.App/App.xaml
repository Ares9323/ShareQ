                 segments forming a "select-colour" mark. Used by the Trace window's
                 Ignore-Color row and any other "open the screen sampler" affordance. ViewBox
                 is 64x64 to match the source SVG; consumers set Width/Height when placing. -->
            <DrawingImage x:Key="EyedropperIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#ff931e" Geometry="M51.29,38.49c.01,10.65-9.76,21.43-20.36,22.43-.6.06-1.65-.11-1.65-.67v-11.26c3.82-1.62,6.5-2.35,8.61-6.23.78-1.43.77-3.07,1.88-4.26h11.52Z" />
