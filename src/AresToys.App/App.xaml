                        <GeometryDrawing Brush="#7fc99a" Geometry="M954.49,544.58c-60.98,211.84-344.51,314.36-506.7,149.14.57-.05,1.13-.11,1.7-.16-63.51-54.92-109.38-137.74-118.72-244.56-70.49,80.86-95.51,190.62-66.87,289.93,13.54,42.36,35.76,82.37,65.07,116.66,36.8,40.93,87.27,75.4,152.41,98.76-.11.04-.21.08-.32.13,249.77,99.47,586.53-133.48,473.61-410.38-.06.15-.12.31-.18.46Z" />
