<ui:FluentWindow x:Class="AresToys.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:AresToys.App.ViewModels"
                 xmlns:Markup="clr-namespace:AresToys.App.Markup"
                 Title="AresToys"
                 Icon="pack://application:,,,/Assets/icon.ico"
                 Width="900" Height="600"
                 MinWidth="640" MinHeight="420"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 Background="{DynamicResource Surface2Brush}"
                 ExtendsContentIntoTitleBar="True">
    <ui:FluentWindow.InputBindings>
        <!-- Esc returns from the inline workflow-edit view to the list. CanExecute gating on
             IsEditingWorkflow keeps the binding inert when no detail view is open.
             KeyBindings sit on the Window's command routing layer and fire regardless of focus —
             the inline rename TextBox swallows Esc (e.Handled=true) so it doesn't bubble out
             while the user is still typing. -->
        <KeyBinding Key="Escape" Command="{Binding Hotkeys.BackToListCommand}" />
    </ui:FluentWindow.InputBindings>
    <ui:FluentWindow.Resources>
        <!-- Tab-strip styling shared by Uploaders (Image / File / Text / …) and Hotkeys
             (Capture / Clipboard / Upload / Tools / Custom). Promoted here so both sections
             render an identical strip without duplicating the template. Plain TextBlock-style
             look with a 2px accent underline on selected. -->
        <!-- Hotkey chip rendered as a clickable button: shows the current binding (or "Click
             to set hotkey…" when unbound) and opens the rebind dialog on click. Replaces the
             previous "Border + separate Rebind button" combo so the whole chip is the affordance,
             which matches what users naturally try first anyway. Hover lifts the background,
             pressed dims it; cursor flips to Hand to advertise the click target. -->
        <!-- Hotkey chip — same accent-dark resting / accent-light hover treatment as the
             "Add" button in Clipboard categories. Unbound rows dim the foreground to
             AccentForegroundDarkBrush so "Click to set hotkey…" reads as a placeholder
             instead of competing with real shortcuts. -->
        <Style x:Key="HotkeyChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBackgroundDarkBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBackgroundDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBackgroundBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAssigned}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundDarkBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Title-as-link inside a hotkey row: clicking the workflow name opens its step list,
             same action that a separate "Edit" button used to fire. Borderless / transparent so
             the row still reads as a card rather than a button strip; hover brightens the text
             and underlines it so the affordance is discoverable without adding chrome. -->
        <Style x:Key="HotkeyTitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Label" Property="Foreground" Value="White" />
                                <Setter TargetName="Label" Property="TextDecorations" Value="Underline" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Label" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UploaderTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundDarkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                <Border x:Name="Indicator"
                                        Height="2"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource AccentBackgroundDarkBrush}"
                                        Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface3Brush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <!-- Accent-tinted 1px frame around the whole window content. FluentWindow keeps the system
         titlebar chrome on the outside, so this Border reads as an inner accent line just
         inside the frame — same role as the explicit borders on Launcher / Clipboard / Toast /
         HotkeyCapture windows, so all surfaces share the same "accent telaio" treatment. -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2" CornerRadius="8">
    <!-- Outer wrapper Grid so the Border can hold both the main layout AND the resize thumb
         (Border accepts only one child, Grid happily stacks via z-order). -->
    <Grid>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- TitleBar with the AresToys logo as icon (replaces the empty default slot WPF-UI
             leaves before the title text). The vector icon mirrors what's in the Home tab,
             so the chrome reads as the same brand at every size. -->
        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Title="AresToys">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{StaticResource AresToysLogo}" Margin="0,0,-12,0" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Sidebar -->
        <!-- CornerRadius on the bottom-left matches the outer Border's CornerRadius (8) minus
             its BorderThickness (2) so the fill curves with the window corner instead of
             bleeding past it. WPF Border doesn't auto-clip child Backgrounds to the parent's
             rounded shape — this is the standard workaround.
             Vertical gradient Surface1 (bottom) → Surface2 (top): the sidebar reads as a faint
             column gradient that fades into the main content surface at the top, instead of a
             flat panel. Colors are bound dynamically to the theme so the gradient retunes
             whenever the user changes Surface1 / Surface2 in the Theme tab. -->
        <Border Grid.Row="1" Grid.Column="0" Padding="8,12"
                CornerRadius="0,0,0,6"
                Background="{DynamicResource SidebarGradientBrush}"
                BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="0,0,1,0">
            <Border.Resources>
                <!-- Override the AccentButton* brush family inside this Border's resource scope
                     only — WPF-UI's Button Primary template resolves them via DynamicResource,
                     so re-keying here flips the SELECTED sidebar button background from the
                     light accent to the dark accent. Non-selected buttons use ButtonBackground
                     (defined globally in ThemeService) and stay untouched. Primary buttons
                     anywhere else in the app keep the light accent because this scope is
                     limited to the sidebar Border. -->
                <SolidColorBrush x:Key="AccentButtonBackground"
                                 Color="{DynamicResource AccentBackgroundDarkColor}" />
                <!-- Hover / pressed flip back to the LIGHT accent so the user gets a visible
                     "this is interactive" cue against the resting dark accent. Same idea as
                     a button getting brighter when hovered. -->
                <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"
                                 Color="{DynamicResource AccentBackgroundColor}" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPressed"
                                 Color="{DynamicResource AccentBackgroundColor}" />
                <!-- WPF-UI's Primary button paints a 1px border via AccentControlElevationBorderBrush
                     that's set globally to the LIGHT accent. Without overriding it the dark fill
                     keeps a light-accent halo around it. Match the resting dark + lighten on
                     hover so the border tracks the background instead of fighting it. -->
                <SolidColorBrush x:Key="AccentControlElevationBorderBrush"
                                 Color="{DynamicResource AccentBackgroundDarkColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrushPressed"
                                 Color="{DynamicResource AccentBackgroundColor}" />

                <!-- Non-selected sidebar buttons (default Appearance) hover to the LIGHT accent
                     so the user gets an "accent-tinted preview" of where they'd land instead
                     of a flat surface-coloured hover. Scoped here so other ui:Buttons across
                     the app (right-pane content, dialogs) keep their neutral hover.
                     ButtonBackgroundPointerOver is the WPF-UI v4 default-Appearance hover key
                     (verified in dark.baml). The Primary-Appearance hover lives on
                     AccentButtonBackgroundPointerOver above and is untouched. -->
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                 Color="{DynamicResource AccentBackgroundLightColor}" />
            </Border.Resources>
            <StackPanel>
                <!-- Hotkeys is the most-edited section (every workflow lives here, every hotkey
                     is bound from here), so it sits first and is the default landing page. The
                     old Home tab held only a static logo + welcome blurb — that lives in About
                     now where the version / repo links naturally cluster. -->
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_HotkeysWorkflows}"
                           Command="{Binding ShowHotkeysCommand}"
                           Appearance="{Binding IsHotkeysSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_Uploaders}"
                           Command="{Binding ShowUploadersCommand}"
                           Appearance="{Binding IsUploadersSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_ClipboardCategories}"
                           Command="{Binding ShowCategoriesCommand}"
                           Appearance="{Binding IsCategoriesSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_Wormholes}"
                           Command="{Binding ShowWormholesCommand}"
                           Appearance="{Binding IsWormholesSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_CaptureSettings}"
                           Command="{Binding ShowCaptureCommand}"
                           Appearance="{Binding IsCaptureSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_AppSettings}"
                           Command="{Binding ShowSettingsCommand}"
                           Appearance="{Binding IsSettingsSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_AppTheme}"
                           Command="{Binding ShowThemeCommand}"
                           Appearance="{Binding IsThemeSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Margin="0,0,0,4"
                           Content="{Markup:Loc Sidebar_DebugConsole}"
                           Command="{Binding ShowDebugCommand}"
                           Appearance="{Binding IsDebugSelected, Converter={StaticResource BoolToAppearance}}" />
                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                           Content="{Markup:Loc Sidebar_About}"
                           Command="{Binding ShowAboutCommand}"
                           Appearance="{Binding IsAboutSelected, Converter={StaticResource BoolToAppearance}}" />
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1" Grid.Column="1">
            <!-- Uploaders -->
            <Grid Visibility="{Binding IsUploadersSelected, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <!-- Shared row template: checkbox + "Configure…" button (only shown for
                         IConfigurableUploader / IOAuthUploader). Reused across all 4 category tabs;
                         only the ItemsSource changes. -->
                    <DataTemplate x:Key="UploaderRowTemplate" DataType="{x:Type vm:UploaderSelectionItemViewModel}">
                        <Grid Margin="0,2">
                            <!-- Local override of WPF-UI v4's checkbox brush keys (verified by
                                 string-extracting Wpf.Ui.dll): scoped to this DataTemplate so the
                                 uploader checkboxes pick up the ambient "Accent Background Dark"
                                 tone for the fill and "Foreground Light" for the border + glyph
                                 instead of the bright primary accent. Lookup walks up the visual
                                 tree, so the keys defined here win inside this row only — Settings
                                 / About checkboxes elsewhere keep the standard accent. -->
                            <Grid.Resources>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="{DynamicResource AccentBackgroundDarkColor}" />
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="{DynamicResource AccentBackgroundDarkColor}" />
                                <SolidColorBrush x:Key="CheckBoxCheckBorderBrush" Color="{DynamicResource AccentForegroundColor}" />
                                <SolidColorBrush x:Key="CheckBoxCheckGlyphForeground" Color="{DynamicResource AccentForegroundColor}" />
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <ui:Button Grid.Column="1"
                                       Content="{Markup:Loc Common_Configure}"
                                       Padding="10,2"
                                       Click="OnConfigureUploaderClicked"
                                       Tag="{Binding}"
                                       Visibility="{Binding IsConfigurable, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </DataTemplate>

                    <!-- Tab header style is shared with Hotkeys; declared once on the Window so
                         both sections render an identical strip. See FluentWindow.Resources. -->
                </Grid.Resources>

                <!-- Header: title + subtitle, sit above the tab strip. -->
                <StackPanel Grid.Row="0" Margin="24,16,24,8">
                    <TextBlock Text="{Markup:Loc Sidebar_Uploaders}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap"
                               Text="{Markup:Loc Uploaders_Blurb}" />
                </StackPanel>

                <!-- Tabbed body: 4 category tabs (Image / File / Text / Video) + Custom (.sxcu).
                     TabControl has Background=Transparent + BorderThickness=0 so it inherits the
                     section background; per-tab styling is in UploaderTabItemStyle above. -->
                <TabControl Grid.Row="1" Margin="24,0,24,16"
                            Background="Transparent" BorderThickness="0" Padding="0">
                    <TabItem Header="{Markup:Loc Uploaders_TabImage}" Style="{StaticResource UploaderTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Uploaders.ImageUploaders}"
                                          ItemTemplate="{StaticResource UploaderRowTemplate}"
                                          Margin="0,12,0,0" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="{Markup:Loc Uploaders_TabFile}" Style="{StaticResource UploaderTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Uploaders.FileUploaders}"
                                          ItemTemplate="{StaticResource UploaderRowTemplate}"
                                          Margin="0,12,0,0" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="{Markup:Loc Uploaders_TabText}" Style="{StaticResource UploaderTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Uploaders.TextUploaders}"
                                          ItemTemplate="{StaticResource UploaderRowTemplate}"
                                          Margin="0,12,0,0" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="{Markup:Loc Uploaders_TabVideo}" Style="{StaticResource UploaderTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Uploaders.VideoUploaders}"
                                          ItemTemplate="{StaticResource UploaderRowTemplate}"
                                          Margin="0,12,0,0" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="{Markup:Loc Uploaders_TabUrl}" Style="{StaticResource UploaderTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                           Text="URL shorteners — take a URL on the clipboard and turn it into a shorter one. Use 'Shorten clipboard URL' workflow (Settings → Hotkeys) to bind a key." />
                                <ItemsControl ItemsSource="{Binding Uploaders.UrlUploaders}"
                                              ItemTemplate="{StaticResource UploaderRowTemplate}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Custom (.sxcu): import / open folder / per-file delete. ShareX-compatible
                         JSON files dropped into %LOCALAPPDATA%\AresToys\custom-uploaders\ become
                         destinations on next restart and surface in the Image/File/Text/Video
                         tabs above based on their declared DestinationType. -->
                    <TabItem Header="{Markup:Loc Uploaders_TabCustom}" Style="{StaticResource UploaderTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                           Text="{Markup:Loc CustomUploaders_Blurb}" />

                                <ItemsControl ItemsSource="{Binding Uploaders.CustomUploaders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CustomUploaderListItemViewModel}">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" />
                                                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" />
                                                </StackPanel>
                                                <ui:Button Grid.Column="1"
                                                           Content="{Markup:Loc Common_Delete}"
                                                           Appearance="Danger"
                                                           Padding="8,2"
                                                           Click="OnDeleteCustomUploaderClicked"
                                                           Tag="{Binding FilePath}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Margin="0,8,0,12"
                                           Text="{Markup:Loc CustomUploaders_NoneYet}"
                                           Visibility="{Binding Uploaders.HasNoCustomUploaders, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <ui:Button Content="{Markup:Loc Common_ImportSxcu}" Padding="14,4" Margin="0,0,8,0" Click="OnImportCustomUploaderClicked" />
                                    <ui:Button Content="{Markup:Loc Common_OpenFolder}" Padding="14,4" Click="OnOpenCustomUploadersFolderClicked" />
                                </StackPanel>

                                <!-- File association toggle: writes per-user HKCU\Software\Classes
                                     entries (no admin) so .sxcu files double-clicked from Explorer
                                     open through AresToys and trigger the import flow. Reversible
                                     from the same checkbox. Will be replaced by Velopack-managed
                                     install-time registration once we ship a packaged release. -->
                                <Border Background="{DynamicResource Surface3Brush}" CornerRadius="4" Padding="12" Margin="0,16,0,0">
                                    <StackPanel>
                                        <CheckBox x:Name="SxcuAssociationCheckBox"
                                                  Content="{Markup:Loc CustomUploaders_SxcuAssociation}"
                                                  Loaded="OnSxcuAssociationCheckBoxLoaded"
                                                  Click="OnSxcuAssociationToggled" />
                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                                   FontSize="11" TextWrapping="Wrap" Margin="22,4,0,0"
                                                   Text="{Markup:Loc CustomUploaders_SxcuAssociationHint}" />
                                    </StackPanel>
                                </Border>

                                <!-- Explorer right-click → "Upload with AresToys" verb. Per-user
                                     HKCU\Software\Classes\*\shell\AresToys entry, fully reversible.
                                     On Windows 11 the verb appears under "Show more options"
                                     (Microsoft hides third-party verbs by default in the new menu). -->
                                <Border Background="{DynamicResource Surface3Brush}" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                    <StackPanel>
                                        <CheckBox x:Name="ExplorerContextMenuCheckBox"
                                                  Content="{Markup:Loc CustomUploaders_ExplorerVerb}"
                                                  Loaded="OnExplorerContextMenuCheckBoxLoaded"
                                                  Click="OnExplorerContextMenuToggled" />
                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                                   FontSize="11" TextWrapping="Wrap" Margin="22,4,0,0"
                                                   Text="{Markup:Loc CustomUploaders_ExplorerVerbHint}" />

                                        <!-- Workflow selector: which pipeline profile the verb runs.
                                             Default 'Manual upload' uploads to first compatible
                                             destination + copies link, but the user can pick e.g.
                                             a custom 'Save to disk + copy markdown' workflow they
                                             built in Hotkeys & workflows. -->
                                        <Grid Margin="22,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Markup:Loc CustomUploaders_RunWorkflow}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <ComboBox Grid.Column="1" x:Name="ExplorerContextMenuWorkflowCombo"
                                                      Loaded="OnExplorerContextMenuWorkflowComboLoaded"
                                                      SelectionChanged="OnExplorerContextMenuWorkflowChanged"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Id" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Hotkeys & workflows: single tab with two sub-views toggled by IsEditingWorkflow.
                 List view (default) shows every hotkey-able workflow grouped by built-in / custom.
                 Edit view replaces it when the user clicks Edit on a row — it hosts the inline
                 rename, action buttons, and pipeline step editor. Back returns to list view. -->
            <Grid Visibility="{Binding IsHotkeysSelected, Converter={StaticResource BoolToVisibility}}">

                <!-- ── LIST VIEW ──────────────────────────────────────────────────────────── -->
                <Grid Visibility="{Binding Hotkeys.IsEditingWorkflow, Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <!-- Shared row template for every category tab + Custom. Identical to the
                             pre-tabs flat-list row so muscle memory carries over. -->
                        <DataTemplate x:Key="HotkeyRowTemplate" DataType="{x:Type vm:HotkeyItemViewModel}">
                            <Border Margin="0,0,0,8" Padding="14,10" Background="{DynamicResource Surface1Brush}"
                                    BorderThickness="0" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Title is the affordance for the workflow's step list — click
                                         it to open the editor. Borderless link-style button (see
                                         HotkeyTitleButtonStyle): the card stays clean, the workflow
                                         name itself reads as actionable. Replaces the previous
                                         separate Edit button on the right. -->
                                    <Button Grid.Column="0"
                                            Style="{StaticResource HotkeyTitleButtonStyle}"
                                            Content="{Binding DisplayName}"
                                            Command="{Binding OpenInWorkflowsCommand}"
                                            ToolTip="Open this workflow's step list" />
                                    <!-- Chip is the rebind affordance — clicking it opens the
                                         capture dialog. When unbound the text reads
                                         "Click to set hotkey…" so the action is self-explanatory. -->
                                    <Button Grid.Column="1" Style="{StaticResource HotkeyChipButtonStyle}"
                                            Content="{Binding BindingDisplay}"
                                            Command="{Binding RebindCommand}"
                                            ToolTip="Click to assign / change / clear the hotkey" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </Grid.Resources>

                    <!-- Header: title + Reset all + subtitle, sit above the tab strip (mirrors
                         the Uploaders section layout for visual consistency). -->
                    <StackPanel Grid.Row="0" Margin="24,16,24,8">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Markup:Loc Sidebar_HotkeysWorkflows}" FontSize="20" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <ui:Button Grid.Column="1" Content="{Markup:Loc Common_ResetAll}"
                                       Appearance="Danger"
                                       Command="{Binding Hotkeys.Workflows.ResetAllToDefaultsCommand}"
                                       ToolTip="Reset every built-in workflow to its default steps and hotkey. Asks for confirmation; custom workflows are not touched." />
                        </Grid>
                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap"
                                   Text="{Markup:Loc Hotkeys_Blurb}" />
                    </StackPanel>

                    <!-- Tabbed body: 4 built-in category tabs + Custom. Same UploaderTabItemStyle
                         the Uploaders section uses, so the strip looks unified across Settings. -->
                    <TabControl Grid.Row="1" Margin="24,0,24,16"
                                Background="Transparent" BorderThickness="0" Padding="0">
                        <TabItem Header="{Markup:Loc WorkflowCategory_Capture}" Style="{StaticResource UploaderTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Hotkeys.CaptureItems}"
                                              ItemTemplate="{StaticResource HotkeyRowTemplate}"
                                              Margin="0,12,0,0" />
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="{Markup:Loc WorkflowCategory_Clipboard}" Style="{StaticResource UploaderTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Hotkeys.ClipboardItems}"
                                              ItemTemplate="{StaticResource HotkeyRowTemplate}"
                                              Margin="0,12,0,0" />
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="{Markup:Loc WorkflowCategory_Upload}" Style="{StaticResource UploaderTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Hotkeys.UploadItems}"
                                              ItemTemplate="{StaticResource HotkeyRowTemplate}"
                                              Margin="0,12,0,0" />
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="{Markup:Loc WorkflowCategory_Tools}" Style="{StaticResource UploaderTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Hotkeys.ToolsItems}"
                                              ItemTemplate="{StaticResource HotkeyRowTemplate}"
                                              Margin="0,12,0,0" />
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="{Markup:Loc Uploaders_TabCustom}" Style="{StaticResource UploaderTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="{Markup:Loc Hotkeys_NoCustomYet}"
                                               Foreground="#666" FontSize="11" FontStyle="Italic"
                                               Visibility="{Binding Hotkeys.CustomItems.Count, Converter={StaticResource ZeroToVisibility}}"
                                               Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding Hotkeys.CustomItems}"
                                                  ItemTemplate="{StaticResource HotkeyRowTemplate}" />
                                    <ui:Button Content="{Markup:Loc Hotkeys_AddCustomWorkflow}" HorizontalAlignment="Left" Margin="0,8,0,0"
                                               Command="{Binding Hotkeys.AddCustomWorkflowCommand}" />
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>

                <!-- ── EDIT VIEW ──────────────────────────────────────────────────────────── -->
                <!-- Esc handling lives on the Window (PreviewKeyDown there) so it fires regardless
                     of where focus currently sits — clicking Edit on a row leaves focus on the
                     (now hidden) button, so a ScrollViewer-scoped handler wouldn't catch it. -->
                <ScrollViewer Visibility="{Binding Hotkeys.IsEditingWorkflow, Converter={StaticResource BoolToVisibility}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,24,16">
                        <!-- Header: Back on the left, action cluster on the right. The inline name
                             editor sits below; rename happens on focus loss / Enter via the
                             SaveDisplayNameAsync hook in code-behind. -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Content="← Back"
                                       Command="{Binding Hotkeys.BackToListCommand}"
                                       ToolTip="{Markup:Loc Hotkeys_BackToList}" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <ui:Button Content="{Markup:Loc Common_Duplicate}" Margin="0,0,4,0"
                                           Command="{Binding Hotkeys.Workflows.DuplicateWorkflowCommand}"
                                           ToolTip="{Markup:Loc Hotkeys_DuplicateTooltip}" />
                                <ui:Button Content="{Markup:Loc Common_Remove}" Margin="0,0,4,0"
                                           Appearance="Danger"
                                           Command="{Binding Hotkeys.Workflows.RemoveWorkflowCommand}"
                                           ToolTip="{Markup:Loc Hotkeys_RemoveTooltip}" />
                                <ui:Button Content="{Markup:Loc Common_ResetToDefaults}"
                                           Appearance="Danger"
                                           Command="{Binding Hotkeys.Workflows.Editor.ResetToDefaultsCommand}"
                                           Visibility="{Binding Hotkeys.Workflows.Editor.CanResetToDefaults, Converter={StaticResource BoolToVisibility}}"
                                           ToolTip="{Markup:Loc Hotkeys_ResetTooltip}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Markup:Loc Hotkeys_WorkflowName}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox x:Name="WorkflowNameInline"
                                    Text="{Binding Hotkeys.Workflows.EditingDisplayName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    LostFocus="OnWorkflowNameLostFocus"
                                    KeyDown="OnWorkflowNameKeyDown"
                                    Padding="10,8"
                                    FontSize="13"
                                    Margin="0,0,0,16" />

                        <!-- Inline rebind: same chip used in the list view. Click it to open the
                             capture dialog (Reset / Clear are inside that dialog). Hidden when
                             no workflow is selected (e.g. during initial load). -->
                        <StackPanel Margin="0,0,0,16"
                                    Visibility="{Binding Hotkeys.EditingWorkflowHotkey, Converter={StaticResource NotNullToVisibility}}">
                            <TextBlock Text="{Markup:Loc Hotkeys_Hotkey}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <!-- DataContext nailed to the EditingWorkflowHotkey VM so the chip
                                 style's IsAssigned DataTrigger resolves against the right object
                                 (otherwise it'd look up IsAssigned on the root VM and never fire). -->
                            <Button DataContext="{Binding Hotkeys.EditingWorkflowHotkey}"
                                    Style="{StaticResource HotkeyChipButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Content="{Binding BindingDisplay}"
                                    Command="{Binding RebindCommand}"
                                    ToolTip="Click to assign / change / clear the hotkey" />
                        </StackPanel>

                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pipeline steps" FontWeight="SemiBold" FontSize="14"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="{Markup:Loc Hotkeys_StepEditorBlurb}" />
                        <ItemsControl x:Name="StepsItemsControl" ItemsSource="{Binding Hotkeys.Workflows.Editor.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WorkflowStepViewModel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="Transparent">
                                            <Border Height="2" Background="{DynamicResource AccentBackgroundBrush}" CornerRadius="1"
                                                    VerticalAlignment="Center" Margin="2,0"
                                                    Visibility="{Binding IsDropTargetAbove, Converter={StaticResource BoolToVisibility}}" />
                                        </Border>
                                        <Border Grid.Row="1" Padding="10,8" Background="{DynamicResource Surface1Brush}"
                                                BorderBrush="#333" BorderThickness="1" CornerRadius="4"
                                                Opacity="{Binding IsDragSource, Converter={StaticResource BoolToOpacity}}"
                                                AllowDrop="True"
                                                DragOver="OnStepRowDragOver"
                                                DragLeave="OnStepRowDragLeave"
                                                Drop="OnStepRowDrop">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Margin="0,0,12,0" Padding="6,4"
                                                        Cursor="SizeAll" Background="Transparent"
                                                        ToolTip="Drag to reorder"
                                                        MouseLeftButtonDown="OnStepHandleMouseDown"
                                                        MouseMove="OnStepHandleMouseMove"
                                                        MouseLeftButtonUp="OnStepHandleMouseUp">
                                                    <TextBlock Text="⋮⋮" Foreground="#777" FontSize="14"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                                                        <Border Margin="8,0,0,0" Padding="6,1" Background="{DynamicResource Surface3Brush}" CornerRadius="3"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding Category, Converter={StaticResource NonEmptyToVisibility}}">
                                                            <TextBlock Text="{Binding Category}" Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="10" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11"
                                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                Visibility="{Binding HasParameter, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding ParameterLabel}" Foreground="#AAA" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <!-- All three controls (- / value / +) share the same Height so the row reads
                                                             as one composed stepper instead of two short buttons hugging a tall input.
                                                             32 is the WPF-UI TextBox baseline that's already used elsewhere in the app. -->
                                                        <ui:Button Content="−" Width="32" Height="32" Padding="0"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalContentAlignment="Center"
                                                                   VerticalContentAlignment="Center"
                                                                   Command="{Binding DecrementParameterCommand}"
                                                                   ToolTip="Decrease" />
                                                        <ui:TextBox Text="{Binding ParameterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="64" Height="32" Margin="4,0"
                                                                    TextAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    VerticalContentAlignment="Center" />
                                                        <ui:Button Content="+" Width="32" Height="32" Padding="0"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalContentAlignment="Center"
                                                                   VerticalContentAlignment="Center"
                                                                   Command="{Binding IncrementParameterCommand}"
                                                                   ToolTip="Increase" />
                                                    </StackPanel>
                                                    <!-- Boolean toggles for the step's config flags. Each one persists into
                                                         step.Config[Key] via the BoolParameterEntry callback. -->
                                                    <ItemsControl ItemsSource="{Binding BoolParameters}"
                                                                  Visibility="{Binding HasBoolParameters, Converter={StaticResource BoolToVisibility}}"
                                                                  Margin="0,6,0,0">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox Content="{Binding Label}"
                                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                          Foreground="#DDD" FontSize="11"
                                                                          Margin="0,0,16,0" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <!-- Free-form text inputs for the step's path / args / shell-command config.
                                                         One row per StringParameter; UpdateSourceTrigger=PropertyChanged so each
                                                         keystroke persists immediately via OnStringParameterChangedAsync. -->
                                                    <ItemsControl ItemsSource="{Binding StringParameters}"
                                                                  Visibility="{Binding HasStringParameters, Converter={StaticResource BoolToVisibility}}"
                                                                  Margin="0,6,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <!-- Auto + MinWidth so a longer translated label ("Strumento predefinito",
                                                                             "Modalità di composizione" …) doesn't get clipped, while short labels
                                                                             still align across rows visually. -->
                                                                        <ColumnDefinition Width="Auto" MinWidth="100" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                               Foreground="#DDD" FontSize="11"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,8,0" />
                                                                    <!-- Editable ComboBox when the parameter declares an OptionsKey (e.g. preset
                                                                         picker). IsEditable=True so the user can still type a name not yet in
                                                                         the list — match-by-name at runtime tolerates fresh presets. -->
                                                                    <!-- Pure selector when StringParameter.IsEditable=false (e.g. image format,
                                                                         editor tool): SelectedValue round-trips the raw enum / format name into
                                                                         step.Config, DisplayMemberPath shows the localised label. -->
                                                                    <ComboBox Grid.Column="1"
                                                                              ItemsSource="{Binding OptionEntries}"
                                                                              SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              SelectedValuePath="Raw"
                                                                              DisplayMemberPath="Display"
                                                                              FontSize="11">
                                                                        <ComboBox.Style>
                                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding HasOptions}" Value="True" />
                                                                                            <Condition Binding="{Binding IsEditable}" Value="False" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ComboBox.Style>
                                                                    </ComboBox>
                                                                    <!-- Editable ComboBox for free-form options (preset names): user can type a
                                                                         name not in the list. Text binding round-trips the typed value. -->
                                                                    <ComboBox Grid.Column="1"
                                                                              ItemsSource="{Binding OptionEntries}"
                                                                              DisplayMemberPath="Display"
                                                                              SelectedValuePath="Raw"
                                                                              Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              IsEditable="True"
                                                                              FontSize="11">
                                                                        <ComboBox.Style>
                                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding HasOptions}" Value="True" />
                                                                                            <Condition Binding="{Binding IsEditable}" Value="True" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ComboBox.Style>
                                                                    </ComboBox>
                                                                    <ui:TextBox Grid.Column="1"
                                                                                Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                PlaceholderText="{Binding Placeholder}"
                                                                                FontSize="11"
                                                                                Visibility="{Binding HasOptions, Converter={StaticResource InverseBoolToVisibility}}" />
                                                                    <!-- Picker buttons live to the right of the text box. Visibility is bound
                                                                         to the entry's ShowFileButton / ShowFolderButton flags so a parameter
                                                                         without a picker (args, command) shows just the text box. Same
                                                                         32×32 + Surface3 + #444 border treatment as the categories icon picker
                                                                         so the row reads as a single composed control rather than three styles
                                                                         glued together. FontAwesome glyphs replace the previous emoji. -->
                                                                    <Button Grid.Column="2"
                                                                            Width="32" Height="32" Padding="0"
                                                                            Background="{DynamicResource Surface3Brush}"
                                                                            BorderBrush="#444" BorderThickness="1"
                                                                            Cursor="Hand" Margin="4,0,0,0"
                                                                            Command="{Binding BrowseFileCommand}"
                                                                            ToolTip="Pick a file…"
                                                                            Visibility="{Binding ShowFileButton, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBlock Text="&#xF15B;"
                                                                                   FontFamily="{DynamicResource IconFont}"
                                                                                   FontSize="14" Foreground="#DDD"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                    <Button Grid.Column="3"
                                                                            Width="32" Height="32" Padding="0"
                                                                            Background="{DynamicResource Surface3Brush}"
                                                                            BorderBrush="#444" BorderThickness="1"
                                                                            Cursor="Hand" Margin="4,0,0,0"
                                                                            Command="{Binding BrowseFolderCommand}"
                                                                            ToolTip="Pick a folder…"
                                                                            Visibility="{Binding ShowFolderButton, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBlock Text="&#xF07B;"
                                                                                   FontFamily="{DynamicResource IconFont}"
                                                                                   FontSize="14" Foreground="#DDD"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                 VerticalAlignment="Center" Margin="12,0,0,0" />
                                                <ui:Button Grid.Column="3" Width="30" Height="22" Padding="0"
                                                           Appearance="Danger"
                                                           Command="{Binding RemoveCommand}"
                                                           ToolTip="Remove this step from the workflow"
                                                           VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <!-- Trash glyph (FontAwesome ) — XAML
                                                         entity reference because raw PUA chars
                                                         get stripped by editor save round-trips. -->
                                                    <TextBlock Text="&#xF1F8;"
                                                               FontFamily="{DynamicResource IconFont}"
                                                               FontSize="11" />
                                                </ui:Button>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Height="12" Background="Transparent"
                                AllowDrop="True"
                                DragOver="OnStepFooterDragOver"
                                DragLeave="OnStepFooterDragLeave"
                                Drop="OnStepFooterDrop">
                            <Border Height="2" Background="{DynamicResource AccentBackgroundBrush}" CornerRadius="1"
                                    VerticalAlignment="Center" Margin="2,0"
                                    Visibility="{Binding Hotkeys.Workflows.Editor.IsDropTargetAtEnd, Converter={StaticResource BoolToVisibility}}" />
                        </Border>
                        <ui:Button x:Name="AddStepButton" Margin="0,4,0,0" HorizontalAlignment="Left"
                                   Content="{Markup:Loc Hotkeys_AddStep}"
                                   Click="OnAddStepButtonClick" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Capture — wrapped in ScrollViewer so the bottom controls (image format,
                 fallback threshold, external editor) stay reachable when the window is
                 short. Same pattern as Theme / Categories / etc. -->
            <ScrollViewer Visibility="{Binding IsCaptureSelected, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,16">
                <TextBlock Text="{Markup:Loc Sidebar_CaptureSettings}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="{Markup:Loc Capture_Blurb}" />

                <TextBlock Text="{Markup:Loc Capture_SaveFolder}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding Capture.Folder, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="%USERPROFILE%\Pictures\AresToys" />
                    <ui:Button Grid.Column="1" Content="{Markup:Loc Common_Browse}" Command="{Binding Capture.BrowseFolderCommand}" Margin="6,0,0,0" />
                </Grid>

                <TextBlock Text="{Markup:Loc Capture_SubFolderPattern}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <ui:TextBox Text="{Binding Capture.SubFolderPattern, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{Markup:Loc Capture_SubFolderPlaceholder}"
                            Margin="0,0,0,4" />
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="{Markup:Loc Capture_SubFolderHint}" />

                <TextBlock Text="{Markup:Loc Capture_DelaySeconds}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <ui:NumberBox Value="{Binding Capture.DelaySeconds, Mode=TwoWay}"
                              Minimum="0" Maximum="30" SmallChange="1"
                              HorizontalAlignment="Left" Width="120" />

                <!-- Image format. Drives both capture pipelines (CaptureCoordinator encodes new
                     screenshots into the chosen format) and the editor's "Save" button (history
                     entry created in the same format). "Save as…" inside the editor still lets
                     the user override per-export. AutoJpeg + threshold mirror ShareX so the user
                     can keep PNG default but fall back to JPEG when a screenshot would balloon
                     above the threshold (uploads, history footprint). -->
                <TextBlock Text="{Markup:Loc Capture_ImageFormat}" FontWeight="SemiBold" Margin="0,16,0,4" />
                <ComboBox ItemsSource="{x:Static vm:CaptureDefaultsViewModel.ImageFormats}"
                          SelectedItem="{Binding Capture.ImageFormat, Mode=TwoWay}"
                          HorizontalAlignment="Left" Width="160" Margin="0,0,0,8" />

                <TextBlock Text="{Markup:Loc Capture_JpegQuality}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                            Minimum="1" Maximum="100"
                            Value="{Binding Capture.JpegQuality, Mode=TwoWay}"
                            VerticalAlignment="Center" Margin="0,0,8,0" />
                    <!-- SpinButtonPlacementMode=Hidden: no chevrons → the value renders flush in
                         a slim column where the spinner buttons would otherwise eat the digits.
                         The slider remains the primary input; the box is for typing exact values. -->
                    <ui:NumberBox Grid.Column="1"
                                  Value="{Binding Capture.JpegQuality, Mode=TwoWay}"
                                  Minimum="1" Maximum="100" SmallChange="5"
                                  SpinButtonPlacementMode="Hidden"
                                  HorizontalContentAlignment="Center" />
                </Grid>

                <TextBlock Text="{Markup:Loc Capture_ThresholdKb}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:NumberBox Value="{Binding Capture.AutoJpegThresholdKb, Mode=TwoWay}"
                                  Minimum="64" Maximum="65536" SmallChange="256"
                                  SpinButtonPlacementMode="Hidden"
                                  IsEnabled="{Binding Capture.AutoJpeg}"
                                  HorizontalContentAlignment="Center"
                                  Width="100" />
                    <CheckBox Content="{Markup:Loc Capture_AutoJpeg}"
                              IsChecked="{Binding Capture.AutoJpeg, Mode=TwoWay}"
                              Margin="12,0,0,0"
                              VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap"
                           Text="{Markup:Loc Capture_AutoJpegHint}" />

                <!-- External editor for clipboard text rows. Empty = let Windows open the temp
                     .txt with whatever's the user's default handler (notepad, VSCode if it
                     hijacked .txt, etc.). Otherwise the path / command runs with the temp
                     file path as argument. The clipboard popup's Edit button (text-row only)
                     fires this; edits stream back via FileSystemWatcher. -->
                <TextBlock Text="{Markup:Loc Capture_ExternalEditor}" FontWeight="SemiBold" Margin="0,16,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                Text="{Binding Capture.ExternalEditorCommand, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="{Markup:Loc Capture_ExternalEditorPlaceholder}" />
                    <ui:Button Grid.Column="1" Content="{Markup:Loc Common_Browse}" Command="{Binding Capture.BrowseExternalEditorCommand}" Margin="6,0,0,0" />
                </Grid>
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap"
                           Text="{Markup:Loc Capture_ExternalEditorHint}" />
            </StackPanel>
            </ScrollViewer>

            <!-- Theme — wrapped in ScrollViewer because the page now has three colour rows +
                 a backup card; on a short window the bottom controls would otherwise clip. -->
            <ScrollViewer Visibility="{Binding IsThemeSelected, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,16">
                <TextBlock Text="{Markup:Loc Sidebar_AppTheme}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="{Markup:Loc Theme_Blurb}" />

                <!-- Preset picker. Selecting one fills every hex field below in a single
                     suppress-then-apply pass so the swatches + saved theme update once instead
                     of seven times. The first entry is "Custom (current values)" — selecting it
                     is a no-op so reopening the tab doesn't snap-overwrite tweaked colours. -->
                <TextBlock Text="{Markup:Loc Theme_PresetPicker}" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Theme.Presets}"
                          SelectedItem="{Binding Theme.SelectedPreset, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource AccentForegroundBrush}">
                    <!-- Local popup-chrome override: route every "popup body" key for this
                         specific picker onto Surface3 so the dropdown reads as one elevated
                         card instead of the standard Surface2 floating panel. Scoped to this
                         ComboBox only — other dropdowns across the app keep the global
                         Surface2-popup convention. Item text re-pinned to AccentForegroundBrush
                         so the row labels stay readable on the lighter Surface3 surface. -->
                    <ComboBox.Resources>
                        <!-- ComboBoxDropDownBackground is the actual key WPF-UI v4 binds the
                             popup chrome to (verified by string-extracting Wpf.Ui.dll); the
                             earlier "ComboBoxPopupBackground" guess never resolved, which is
                             why the dropdown stayed on the dark theme default. Surface3 here
                             so this specific picker reads as one shade above the standard
                             Surface2 popup convention used elsewhere — a cue that the picker
                             is itself a "settings surface" rather than a generic chooser. -->
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{DynamicResource Surface3Color}" />
                        <SolidColorBrush x:Key="ComboBoxItemBackground" Color="{DynamicResource Surface3Color}" />
                        <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{DynamicResource AccentBackgroundDarkColor}" />
                        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{DynamicResource AccentBackgroundDarkColor}" />
                        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="{DynamicResource AccentBackgroundDarkColor}" />
                        <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{DynamicResource AccentForegroundColor}" />
                        <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="{DynamicResource AccentForegroundColor}" />
                        <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{DynamicResource AccentForegroundColor}" />
                        <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="{DynamicResource AccentForegroundColor}" />
                    </ComboBox.Resources>
                </ComboBox>

                <!-- Foreground rows come first — these drive both the on-accent text colour and
                     the dim subtext used across captions / metadata; visually the most "global"
                     of the seven controls so reading top-to-bottom matches their reach. -->
                <TextBlock Text="{Markup:Loc Theme_ForegroundLight}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentForegroundPreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnAccentFgSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentForegroundLightHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#FFFFFF"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="{Markup:Loc Theme_ForegroundLightHint}" />

                <TextBlock Text="{Markup:Loc Theme_ForegroundDark}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentForegroundDarkPreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnAccentForegroundDarkSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentForegroundDarkHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#878787"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="{Markup:Loc Theme_ForegroundDarkHint}" />

                <!-- Background row — renamed "light" so it pairs visually with "Accent background
                     dark" below. Both tint surfaces inside the app: light is the bright primary
                     accent, dark is the ambient surface tone. -->
                <TextBlock Text="{Markup:Loc Theme_AccentBackgroundLight}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentBackgroundPreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnAccentBgSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentBackgroundLightHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#751C8B"
                                FontFamily="Consolas" />
                </Grid>

                <!-- Accent dark — used by ambient surfaces that follow the theme but aren't the
                     primary accent: launcher cells, inactive tab headers. Sits darker than the
                     main accent so the bright accent reads cleanly on top of it. -->
                <TextBlock Text="{Markup:Loc Theme_AccentBackgroundDark}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentBackgroundDarkPreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnAccentDarkSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentBackgroundDarkHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#371242"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="{Markup:Loc Theme_AccentBackgroundDarkHint}" />

                <!-- Destructive-action accent: Delete buttons, trash icons, "this is irreversible"
                     cues. Separate from the main accent so a green/blue theme doesn't get stuck
                     with a default red that fights its palette. -->
                <TextBlock Text="{Markup:Loc Theme_AccentDanger}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.AccentDeletePreview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnAccentDeleteSwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.AccentDangerHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#8F2720"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="{Markup:Loc Theme_AccentDangerHint}" />

                <!-- Three neutral surface tones — darkest → lightest. The XAML across the app
                     consumes these via DynamicResource so changes propagate everywhere live. -->
                <TextBlock Text="{Markup:Loc Theme_Surface1}" FontWeight="SemiBold" Margin="0,12,0,4" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.Surface1Preview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnSurface1SwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.Surface1Hex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#1A1A1A"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Text="{Markup:Loc Theme_Surface2}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.Surface2Preview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnSurface2SwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.Surface2Hex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#1F1F1F"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Text="{Markup:Loc Theme_Surface3}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Theme.Surface3Preview}"
                            BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"
                            Cursor="Hand"
                            ToolTip="{Markup:Loc Theme_TooltipSwatch}"
                            MouseLeftButtonDown="OnSurface3SwatchClick" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Theme.Surface3Hex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="#2D2D2D"
                                FontFamily="Consolas" />
                </Grid>

                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="{Markup:Loc Theme_SurfacesHint}" />

                <!-- No sample / Apply button: clicking a swatch opens the picker, which previews
                     the new colour on its own OK button. The accent only commits app-wide when
                     the picker closes with OK — so editing here doesn't constantly repaint the
                     whole UI behind the dialog. Reset stays as the one button that DOES apply
                     immediately because there's no separate preview surface for it. -->
                <ui:Button Content="{Markup:Loc Common_ResetToDefaults}" HorizontalAlignment="Left"
                           Appearance="Danger"
                           Command="{Binding Theme.ResetCommand}"
                           ToolTip="Restore the original AresToys accent and surface palette." />
            </StackPanel>
            </ScrollViewer>

            <!-- Categories — clipboard "tabs" à la CopyQ. Each row is a category the user can
                 rename / cap / cleanup. The default "Clipboard" bucket is read-only because
                 there's nowhere to dump its items if it disappeared. -->
            <ScrollViewer Visibility="{Binding IsCategoriesSelected, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,16,24,16">
                    <TextBlock Text="{Markup:Loc Sidebar_ClipboardCategories}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="{Markup:Loc Categories_Blurb}" />

                    <!-- Add row -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4"
                            Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Categories_AddNew}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid>
                                <!-- Same accent-dark resting / accent-light hover treatment as
                                     the sidebar's selected button — scoped to this Grid so it
                                     only affects the Add button without re-keying app-wide. -->
                                <Grid.Resources>
                                    <SolidColorBrush x:Key="AccentButtonBackground"
                                                     Color="{DynamicResource AccentBackgroundDarkColor}" />
                                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"
                                                     Color="{DynamicResource AccentBackgroundColor}" />
                                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed"
                                                     Color="{DynamicResource AccentBackgroundColor}" />
                                    <SolidColorBrush x:Key="AccentControlElevationBorderBrush"
                                                     Color="{DynamicResource AccentBackgroundDarkColor}" />
                                    <SolidColorBrush x:Key="AccentButtonBorderBrushPressed"
                                                     Color="{DynamicResource AccentBackgroundColor}" />
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0"
                                            Text="{Binding Categories.NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="{Markup:Loc Categories_NewNamePlaceholder}"
                                            Margin="0,0,8,0" />
                                <!-- Pick-icon button: square (matches the Name TextBox height
                                     for visual alignment). NewCategoryIcon is seeded with the
                                     star glyph by the VM so this always renders something — no
                                     empty-state fallback needed. Click opens the picker. -->
                                <Button Grid.Column="1" Tag="NewCategoryIcon"
                                        Click="OnPickCategoryIconClicked"
                                        Width="32" Height="32"
                                        Background="{DynamicResource Surface3Brush}"
                                        BorderBrush="#444" BorderThickness="1"
                                        Cursor="Hand" Padding="0"
                                        Margin="0,0,8,0"
                                        ToolTip="Click to pick an icon from the library.">
                                    <TextBlock Text="{Binding Categories.NewCategoryIcon}"
                                               FontFamily="{DynamicResource IconFont}"
                                               FontSize="16" Foreground="#DDD"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Button>
                                <ui:Button Grid.Column="2" Content="{Markup:Loc Common_Add}"
                                           Command="{Binding Categories.AddCategoryCommand}"
                                           Appearance="Primary"
                                           Padding="14,4" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Categories.Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryRowViewModel}">
                                <Border Background="{DynamicResource Surface1Brush}"
                                        BorderThickness="0" CornerRadius="6"
                                        Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <!-- Stepper columns auto-fit so a 4-digit cap doesn't
                                                 get visually clipped. The inner TextBox has
                                                 MinWidth so a single digit doesn't collapse the
                                                 control to almost-nothing. -->
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <!-- Save column removed: autosave on field commit
                                                 (LostFocus / Enter) replaces the manual button. -->
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Per-row pick button — square 32×32, mirrors the Add
                                             row's button. Empty state shows the same dim star
                                             so users see "this opens a picker" without text. -->
                                        <Button Grid.Column="0" Tag="{Binding}"
                                                Click="OnPickRowIconClicked"
                                                Width="32" Height="32"
                                                Background="{DynamicResource Surface3Brush}"
                                                BorderBrush="#444" BorderThickness="1"
                                                Cursor="Hand" Padding="0"
                                                IsEnabled="{Binding CanConfigure}"
                                                Margin="0,0,8,0"
                                                ToolTip="Click to pick an icon from the library.">
                                            <Grid>
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="{DynamicResource IconFont}"
                                                           FontSize="16" Foreground="#DDD"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Icon, Converter={StaticResource NonEmptyToVisibility}}" />
                                                <!-- Star fallback (FontAwesome ) for the
                                                     "no icon picked yet" empty state. -->
                                                <TextBlock Text="&#xF005;"
                                                           FontFamily="{DynamicResource IconFont}"
                                                           FontSize="16" Foreground="#777"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Icon, Converter={StaticResource NullOrEmptyToVisibility}}" />
                                            </Grid>
                                        </Button>
                                        <ui:TextBox Grid.Column="1"
                                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                    IsEnabled="{Binding CanModify}"
                                                    LostFocus="OnCategoryFieldCommitted"
                                                    KeyDown="OnCategoryFieldKeyDown"
                                                    Margin="0,0,8,0"
                                                    ToolTip="Category name. Renaming re-routes every existing item to the new name." />
                                        <!-- Stepper: [-] [N] [+]. Replaces the WPF-UI NumberBox
                                             chevrons with a more obvious tap-target on each side.
                                             Binding goes through a TextBox in the middle so
                                             keyboard typing still works; the Tag carries the row
                                             VM so the +/- handlers can mutate the right field. -->
                                        <!-- MaxItems stepper. StackPanel auto-fits to content
                                             via MinWidth on the TextBox, so 1 digit shows ~36px
                                             of input and 5 digits expand naturally. The +/-
                                             buttons sit 2px clear of the TextBox so the chrome
                                             doesn't visually merge into a single block. -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    Margin="0,0,8,0">
                                            <Button Content="−" Tag="MaxItems-"
                                                    Click="OnCategoryStepperClicked"
                                                    Width="28" Height="32"
                                                    Background="{DynamicResource Surface3Brush}"
                                                    BorderBrush="#444" BorderThickness="1"
                                                    Cursor="Hand" Padding="0"
                                                    IsEnabled="{Binding CanConfigure}"
                                                    ToolTip="Decrease by 1." />
                                            <ui:TextBox Text="{Binding MaxItems, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                        IsEnabled="{Binding CanConfigure}"
                                                        TextAlignment="Center"
                                                        MinWidth="36"
                                                        Margin="2,0,2,0"
                                                        LostFocus="OnCategoryFieldCommitted"
                                                        ToolTip="Max items kept (0 = no cap)." />
                                            <Button Content="+" Tag="MaxItems+"
                                                    Click="OnCategoryStepperClicked"
                                                    Width="28" Height="32"
                                                    Background="{DynamicResource Surface3Brush}"
                                                    BorderBrush="#444" BorderThickness="1"
                                                    Cursor="Hand" Padding="0"
                                                    IsEnabled="{Binding CanConfigure}"
                                                    ToolTip="Increase by 1." />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                    Margin="0,0,8,0">
                                            <Button Content="−" Tag="AutoCleanupAfter-"
                                                    Click="OnCategoryStepperClicked"
                                                    Width="28" Height="32"
                                                    Background="{DynamicResource Surface3Brush}"
                                                    BorderBrush="#444" BorderThickness="1"
                                                    Cursor="Hand" Padding="0"
                                                    IsEnabled="{Binding CanConfigure}"
                                                    ToolTip="Decrease by 1 minute." />
                                            <ui:TextBox Text="{Binding AutoCleanupAfter, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                        IsEnabled="{Binding CanConfigure}"
                                                        TextAlignment="Center"
                                                        MinWidth="36"
                                                        Margin="2,0,2,0"
                                                        LostFocus="OnCategoryFieldCommitted"
                                                        ToolTip="Auto-delete items older than N minutes (0 = never)." />
                                            <Button Content="+" Tag="AutoCleanupAfter+"
                                                    Click="OnCategoryStepperClicked"
                                                    Width="28" Height="32"
                                                    Background="{DynamicResource Surface3Brush}"
                                                    BorderBrush="#444" BorderThickness="1"
                                                    Cursor="Hand" Padding="0"
                                                    IsEnabled="{Binding CanConfigure}"
                                                    ToolTip="Increase by 1 minute." />
                                        </StackPanel>
                                        <!-- Custom rows get a Trash button (delete category).
                                             The default 'Clipboard' row swaps it for an Undo
                                             glyph that resets icon + MaxItems + AutoCleanupAfter
                                             back to defaults — the row can't be deleted (every
                                             item needs a fallback bucket) so a reset is the
                                             closest equivalent. -->
                                        <ui:Button Grid.Column="4"
                                                   Command="{Binding DeleteCommand}"
                                                   Appearance="Danger"
                                                   Visibility="{Binding CanModify, Converter={StaticResource BoolToVisibility}}"
                                                   ToolTip="Delete category (items will move to 'Clipboard').">
                                            <TextBlock Text="&#xF1F8;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="13" />
                                        </ui:Button>
                                        <ui:Button Grid.Column="4"
                                                   Command="{Binding ResetToDefaultsCommand}"
                                                   Appearance="Danger"
                                                   Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}"
                                                   ToolTip="Reset icon, max items and auto-cleanup back to defaults.">
                                            <TextBlock Text="&#xF0E2;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="13" />
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Wormholes — list of every wormhole the user owns (Data + Portal), with their
                 current position / size / lock / hidden state and per-row actions (open folder,
                 delete). The "+ New wormhole" button at the top mirrors the tray entry and pops
                 the same dialog. Two-way binding on Lock / Hidden CheckBoxes drives the chrome's
                 live state via WormholeWindowManager.ReconcileAsync — the panel is the single
                 surface a user with a stuck-hidden wormhole needs to recover. -->
            <ScrollViewer Visibility="{Binding IsWormholesSelected, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,16,24,16">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Markup:Loc Sidebar_Wormholes}"
                                   FontSize="20" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Content="{Markup:Loc Wormholes_NewButton}"
                                       Appearance="Primary" Padding="14,4" Margin="0,0,8,0"
                                       Command="{Binding Wormholes.NewWormholeCommand}" />
                            <ui:Button Content="{Markup:Loc Wormholes_RefreshButton}"
                                       Padding="14,4"
                                       Command="{Binding Wormholes.RefreshCommand}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="{Markup:Loc Wormholes_Blurb}" />

                    <!-- Column header strip. Surface2 background to distinguish from rows. -->
                    <Border Background="{DynamicResource Surface2Brush}" CornerRadius="4"
                            Padding="12,6" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Markup:Loc Wormholes_ColTitle}"   FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" />
                            <TextBlock Grid.Column="1" Text="X"      FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Y"      FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="W"      FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="H"      FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="{Markup:Loc Wormholes_ColLock}"    FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="{Markup:Loc Wormholes_ColHidden}"  FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="7" Text="📁"     FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="8" Text="🗑"     FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentForegroundDarkBrush}" HorizontalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Empty state — visible only when there are no wormhole records. Hidden
                         column header would feel out of place hanging over an empty list, but
                         the column header still helps users discover the layout when they're
                         about to create their first wormhole, so we keep it always. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4"
                            Padding="14" Margin="0,0,0,12"
                            Visibility="{Binding Wormholes.IsEmpty, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Markup:Loc Wormholes_EmptyState}"
                                   Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                   FontStyle="Italic" FontSize="12"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <ItemsControl ItemsSource="{Binding Wormholes.Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4"
                                        Padding="12,8" Margin="0,0,0,4"
                                        ToolTip="{Binding Tooltip}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                                   FontSize="13" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <!-- X / Y / W / H as TextBoxes: TwoWay binding with the default UpdateSourceTrigger=LostFocus
                                             so the row VM commits only when the user tabs away or clicks elsewhere — typing partial
                                             values like "-12" doesn't snap-back mid-edit. Enter also commits, via OnGeometryKeyDown
                                             in code-behind. Live updates from chrome drag/resize flow back through the manager's
                                             RecordChanged event into RefreshDisplay() so these cells stay in sync without reload. -->
                                        <TextBox Grid.Column="1" Text="{Binding PositionX, Mode=TwoWay}" PreviewKeyDown="OnGeometryKeyDown"
                                                 GotKeyboardFocus="OnGeometryGotFocus"
                                                 PreviewMouseLeftButtonDown="OnGeometryPreviewMouseDown"
                                                 HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" Padding="0" />
                                        <TextBox Grid.Column="2" Text="{Binding PositionY, Mode=TwoWay}" PreviewKeyDown="OnGeometryKeyDown"
                                                 GotKeyboardFocus="OnGeometryGotFocus"
                                                 PreviewMouseLeftButtonDown="OnGeometryPreviewMouseDown"
                                                 HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" Padding="0" />
                                        <TextBox Grid.Column="3" Text="{Binding SizeW,     Mode=TwoWay}" PreviewKeyDown="OnGeometryKeyDown"
                                                 GotKeyboardFocus="OnGeometryGotFocus"
                                                 PreviewMouseLeftButtonDown="OnGeometryPreviewMouseDown"
                                                 HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" Padding="0" />
                                        <TextBox Grid.Column="4" Text="{Binding SizeH,     Mode=TwoWay}" PreviewKeyDown="OnGeometryKeyDown"
                                                 GotKeyboardFocus="OnGeometryGotFocus"
                                                 PreviewMouseLeftButtonDown="OnGeometryPreviewMouseDown"
                                                 HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" Padding="0" />

                                        <CheckBox Grid.Column="5" IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="6" IsChecked="{Binding IsHidden, Mode=TwoWay}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <ui:Button Grid.Column="7"
                                                   Width="28" Height="28" Padding="0"
                                                   Background="Transparent" BorderThickness="0"
                                                   Command="{Binding OpenFolderCommand}"
                                                   ToolTip="{Markup:Loc Wormholes_OpenFolderTooltip}">
                                            <TextBlock Text="&#xE8DA;"
                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource AccentForegroundBrush}" />
                                        </ui:Button>

                                        <ui:Button Grid.Column="8"
                                                   Width="28" Height="28" Padding="0"
                                                   Background="Transparent" BorderThickness="0"
                                                   Appearance="Danger"
                                                   Command="{Binding DeleteCommand}"
                                                   ToolTip="{Markup:Loc Wormholes_DeleteTooltip}">
                                            <TextBlock Text="&#xE74D;"
                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       FontSize="14" />
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Wormhole defaults card. Lives below the list so the rows stay the
                         primary surface and these are obvious "settings that apply to every
                         wormhole unless overridden". Per-wormhole values continue to win;
                         the chrome's Ctrl+Wheel zoom + appearance slider override these. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4"
                            Padding="14" Margin="0,16,0,16">
                        <StackPanel>
                            <TextBlock Text="Defaults for new and unconfigured wormholes"
                                       FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="Per-wormhole overrides win when set (Ctrl+Wheel inside a wormhole sets that wormhole's zoom; the appearance slider in the chrome sets its opacity). 0 for icon size means 'use the Windows desktop icon size'." />

                            <!-- Icon size: numeric input. Min 0 (sentinel = desktop default),
                                 24 px is the smallest readable tile, 256 the largest preset
                                 Windows supports for Extra Large icons. ClearButtonEnabled=False
                                 removes the WPF-UI default "X" affordance — it both clutters a
                                 number field AND committed 0 on click, which here is the magic
                                 "use desktop size" value. UpdateSourceTrigger=PropertyChanged so
                                 typed digits / arrow clicks propagate to live wormholes on each
                                 change, not on focus-out. -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                           Text="Default icon size (px, 0 = desktop)" />
                                <ui:NumberBox Grid.Column="1" Width="120"
                                              Minimum="0" Maximum="256" SmallChange="8"
                                              ClearButtonEnabled="False"
                                              Value="{Binding Wormholes.DefaultIconSizePx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <!-- Tile padding: 0 = Portals-style dense pack, 32 = airy. Slider
                                 because the user typically dials by feel rather than picking an
                                 exact pixel count. -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                           Text="Tile padding" />
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="32" SmallChange="1" LargeChange="4"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        Value="{Binding Wormholes.DefaultTilePaddingPx, Mode=TwoWay}"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                           Text="{Binding Wormholes.DefaultTilePaddingPx, StringFormat={}{0}px}" />
                            </Grid>

                            <!-- Opacity slider 30–100 (anything below 30 makes the wormhole
                                 hard to click). Bound as int percent; the service converts to
                                 the 0.30–1.00 double form the WPF Opacity property wants. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                           Text="Default opacity" />
                                <Slider Grid.Column="1"
                                        Minimum="30" Maximum="100" SmallChange="1" LargeChange="5"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        Value="{Binding Wormholes.DefaultOpacityPercent, Mode=TwoWay}"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                           Text="{Binding Wormholes.DefaultOpacityPercent, StringFormat={}{0}%}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Settings — generic preferences that don't belong under a specific feature tab.
                 Lives between Theme and Debug in the sidebar. Wraps content in ScrollViewer
                 because we expect this list to grow (autostart + future toggles + backup). -->
            <ScrollViewer Visibility="{Binding IsSettingsSelected, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,16,24,16">
                    <TextBlock Text="{Markup:Loc Sidebar_AppSettings}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="{Markup:Loc Settings_Blurb}" />

                    <!-- Modules: per-feature toggles. Disabled modules skip eager pre-warm,
                         ingestion hooks, tray entries, and hotkey registration — the goal is
                         that a user who never wants the Clipboard or Launcher (or who hasn't
                         opted into Wormholes yet) pays zero runtime cost for those subsystems.
                         Changes persist immediately but require a restart to take effect; the
                         hint label below appears as soon as the first toggle moves. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_ModulesTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_ModulesHint}" />
                            <CheckBox IsChecked="{Binding ClipboardModuleEnabled, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_ModuleClipboard}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left" Margin="0,0,0,8"
                                      ToolTip="{Markup:Loc Settings_ModuleClipboardTooltip}" />
                            <CheckBox IsChecked="{Binding LauncherModuleEnabled, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_ModuleLauncher}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left" Margin="0,0,0,8"
                                      ToolTip="{Markup:Loc Settings_ModuleLauncherTooltip}" />
                            <CheckBox IsChecked="{Binding WormholesModuleEnabled, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_ModuleWormholes}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left" Margin="0,0,0,8"
                                      ToolTip="{Markup:Loc Settings_ModuleWormholesTooltip}" />
                            <!-- Restart row appears as soon as any module toggle moves. The button
                                 relaunches the process via OnRestartAppClicked (the same handler
                                 previously hosted under the Language card — the language picker
                                 now refreshes live on CultureChanged so a restart is no longer
                                 needed there, while module gates DO run only at startup). -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding ModulesRestartRequired, Converter={StaticResource BoolToVisibility}}">
                                <ui:Button Content="{Markup:Loc Settings_ModulesRestartButton}"
                                           Padding="14,4"
                                           Click="OnRestartAppClicked"
                                           ToolTip="{Markup:Loc Settings_ModulesRestartHint}" />
                                <TextBlock Foreground="{DynamicResource AccentForegroundBrush}" FontSize="11" FontStyle="Italic"
                                           VerticalAlignment="Center" Margin="10,0,0,0"
                                           Text="{Markup:Loc Settings_ModulesRestartHint}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Windows integration: autostart, startup window state, and tray-icon
                         click routing. All three share the "how AresToys plugs into the OS"
                         theme so they live in one card; previously the autostart / minimised
                         flags were loose checkboxes and the tray combos were a separate card,
                         which read as three disconnected blobs. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_WindowsIntegrationTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_WindowsIntegrationHint}" />
                            <CheckBox IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_StartWithWindows}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left" Margin="0,0,0,8"
                                      ToolTip="{Markup:Loc Settings_StartWithWindowsTooltip}" />
                            <CheckBox IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_StartMinimized}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left" Margin="0,0,0,12"
                                      ToolTip="{Markup:Loc Settings_StartMinimizedTooltip}" />

                            <!-- In-card divider between the boolean toggles above and the tray
                                 click-routing matrix below. Same Surface3 thickness/opacity as
                                 the other in-card separators across the app so the visual
                                 weight stays consistent. -->
                            <Border Height="1" Background="{DynamicResource AccentForegroundDarkBrush}" Opacity="0.3" Margin="0,0,0,12" />

                            <TextBlock Text="{Markup:Loc Settings_TrayClicksTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_TrayClicksHint}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Markup:Loc Settings_TrayLeftClick}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="TrayLeftClickCombo"
                                           Loaded="OnTrayClickComboLoaded"
                                           SelectionChanged="OnTrayLeftClickChanged"
                                           Margin="0,0,0,8" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Markup:Loc Settings_TrayDoubleClick}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="TrayDoubleClickCombo"
                                           Loaded="OnTrayClickComboLoaded"
                                           SelectionChanged="OnTrayDoubleClickChanged"
                                           Margin="0,0,0,8" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Markup:Loc Settings_TrayMiddleClick}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="TrayMiddleClickCombo"
                                           Loaded="OnTrayClickComboLoaded"
                                           SelectionChanged="OnTrayMiddleClickChanged" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Editor: knobs for the image editor (start state + per-gesture
                         behaviour). Sits next to the Image effects card below since both are
                         editor-adjacent surfaces. EditorStartMaximized lives here rather than
                         under "Windows integration" because it governs editor-launch behaviour,
                         not OS-level startup. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_EditorSectionTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_EditorSectionHint}" />
                            <CheckBox IsChecked="{Binding EditorStartMaximized, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_EditorStartMaximized}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left" Margin="0,0,0,8"
                                      ToolTip="{Markup:Loc Settings_EditorStartMaximizedTooltip}" />
                            <CheckBox IsChecked="{Binding EditorAltClickSelectAny, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_EditorAltClickSelectAny}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left"
                                      ToolTip="{Markup:Loc Settings_EditorAltClickSelectAnyTooltip}" />
                        </StackPanel>
                    </Border>

                    <!-- Clipboard window display options. Lives next to the Editor section card
                         because both are feature-specific display-behaviour knobs; OS-level
                         integration knobs stay higher up. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_ClipboardSectionTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_ClipboardSectionHint}" />
                            <CheckBox IsChecked="{Binding ClipboardShowSnippetWithLabel, Mode=TwoWay}"
                                      Content="{Markup:Loc Settings_ClipboardShowSnippetWithLabel}"
                                      Foreground="#DDD" FontSize="12"
                                      HorizontalAlignment="Left"
                                      ToolTip="{Markup:Loc Settings_ClipboardShowSnippetWithLabelTooltip}" />
                        </StackPanel>
                    </Border>

                    <!-- Image effects editor: opens a separate ShareX-style chain editor where
                         the user defines named presets (sequences of adjustments / filters /
                         drawings). Presets live in memory for now; Step 4 wires SQLite
                         persistence and Step 5 lets a pipeline task apply one to every
                         capture. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_ImageEffectsTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_ImageEffectsHint}" />
                            <ui:Button Content="{Markup:Loc Settings_ImageEffectsOpen}" Padding="14,4" Click="OnOpenImageEffectsClicked" />

                            <!-- Same per-user HKCU\Software\Classes shape we use for .sxcu — opt-in, reversible
                                 from the same checkbox. Once Velopack ships the installer it can register both
                                 at install time. -->
                            <Border Background="{DynamicResource Surface3Brush}" CornerRadius="4" Padding="12" Margin="0,16,0,0">
                                <StackPanel>
                                    <CheckBox x:Name="SxieAssociationCheckBox"
                                              Content="{Markup:Loc Settings_SxieAssociation}"
                                              Loaded="OnSxieAssociationCheckBoxLoaded"
                                              Click="OnSxieAssociationToggled" />
                                    <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                               FontSize="11" TextWrapping="Wrap" Margin="22,4,0,0"
                                               Text="{Markup:Loc Settings_SxieAssociationHint}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- UI language picker. Writes the selected culture tag to ui.language; the
                         picker itself stays in English so a wrong choice is recoverable without
                         hunting for the right entry in an unfamiliar language. CurrentTag setter
                         applies live — bound surfaces (tray menu, future XAML Loc bindings)
                         refresh on CultureChanged without a restart. Sits below Image effects
                         (rather than near the OS-integration knobs at the top) because it's a
                         localisation choice — adjacent to Backup which is the other
                         "rare-touch / configuration" card at the bottom. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_Language}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_LanguageHint}" />
                            <ComboBox x:Name="LanguageCombo"
                                      Loaded="OnLanguageComboLoaded"
                                      SelectionChanged="OnLanguageComboChanged"
                                      MinWidth="220" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Portable JSON dump of every non-sensitive setting. Skips OAuth tokens /
                         credentials / DPAPI-protected payloads — those are bound to the local
                         user account and wouldn't decrypt on another machine anyway. -->
                    <Border Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Markup:Loc Settings_BackupTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="{Markup:Loc Settings_BackupHint}" />
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="{Markup:Loc Common_Export}" Margin="0,0,8,0" Padding="14,4"
                                           Click="OnExportSettingsClicked"
                                           ToolTip="Save every non-sensitive setting to a JSON file." />
                                <ui:Button Content="{Markup:Loc Common_Import}" Padding="14,4"
                                           Click="OnImportSettingsClicked"
                                           ToolTip="Load settings from a previously-exported JSON file. Existing values get overwritten; settings not in the file stay untouched." />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Debug: live in-app log viewer. Captures every ILogger<T>.Log call across the
                 codebase via InMemoryLoggerProvider, so packaged builds + non-Rider runs still
                 give us visibility into errors / warnings / pipeline traces. -->
            <Grid Visibility="{Binding IsDebugSelected, Converter={StaticResource BoolToVisibility}}"
                  Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Markup:Loc Sidebar_DebugConsole}" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1" Content="{Markup:Loc Debug_CopyAll}" Margin="0,0,4,0"
                               Command="{Binding Debug.CopyAllCommand}"
                               ToolTip="{Markup:Loc Debug_CopyAllTooltip}" />
                    <ui:Button Grid.Column="2" Content="{Markup:Loc Debug_Clear}"
                               Command="{Binding Debug.ClearCommand}"
                               ToolTip="{Markup:Loc Debug_ClearTooltip}" />
                </Grid>
                <CheckBox Grid.Row="1" Content="{Markup:Loc Debug_AutoScroll}"
                          IsChecked="{Binding Debug.AutoScroll, Mode=TwoWay}"
                          Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Margin="0,8,0,8"
                          ToolTip="{Markup:Loc Debug_AutoScrollTooltip}" />
                <Border Grid.Row="2" Background="#0F0F0F" BorderBrush="#333" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="DebugLogList"
                             ItemsSource="{Binding Debug.Entries}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Timestamp text uses a fixed gray so the debug log panel
                                         keeps its "terminal" inverted look regardless of the
                                         active theme. AccentForegroundDarkBrush is theme-bound
                                         and on a light theme (e.g. BurnMyEyes) drops to near-
                                         black, which is unreadable on the panel's hardcoded
                                         #0F0F0F surface. -->
                                    <TextBlock Grid.Column="0" Text="{Binding TimestampDisplay}" Foreground="#888" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding LevelDisplay}" Margin="0,0,8,0"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding LevelBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="#999" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#DDD" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- About -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsAboutSelected, Converter={StaticResource BoolToVisibility}}">
                <Image Source="pack://application:,,,/Assets/AresToysLogo.png"
                       Width="96" Height="96" Margin="0,0,0,12" HorizontalAlignment="Center" />
                <TextBlock Text="AresToys" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Run Text="{Markup:Loc About_Version}" /><Run Text="{Binding AppVersion, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,0"
                           Text="{Markup:Loc About_Tagline}" />

                <!-- Source code link. Hyperlink.RequestNavigate fires OnHyperlinkClicked in
                     code-behind which shells out to the user's default browser. Foreground is
                     a lighter shade of the user's accent background (derived in ThemeService
                     so changing the accent in Settings → Theme also retints the links). -->
                <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0" FontSize="12">
                    <Hyperlink NavigateUri="https://github.com/Ares9323/AresToys" RequestNavigate="OnHyperlinkClicked"
                               Foreground="{DynamicResource AccentForegroundBrush}">
                        github.com/Ares9323/AresToys
                    </Hyperlink>
                </TextBlock>

                <!-- Inspirations / upstream credits. ShareX is the heaviest dependency (most of
                     the capture / editor / uploader code lineage); CopyQ shaped the clipboard
                     popup model; MaxLauncher inspired the launcher grid. -->
                <TextBlock HorizontalAlignment="Center" Margin="0,20,0,4"
                           Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11"
                           Text="{Markup:Loc About_InspiredBy}" />
                <TextBlock HorizontalAlignment="Center" FontSize="12">
                    <Hyperlink NavigateUri="https://github.com/ShareX/ShareX" RequestNavigate="OnHyperlinkClicked"
                               Foreground="{DynamicResource AccentForegroundBrush}">ShareX</Hyperlink>
                    <Run Text=" · " Foreground="#666" />
                    <Hyperlink NavigateUri="https://github.com/hluk/CopyQ" RequestNavigate="OnHyperlinkClicked"
                               Foreground="{DynamicResource AccentForegroundBrush}">CopyQ</Hyperlink>
                    <Run Text=" · " Foreground="#666" />
                    <Hyperlink NavigateUri="https://maxlauncher.sourceforge.io/" RequestNavigate="OnHyperlinkClicked"
                               Foreground="{DynamicResource AccentForegroundBrush}">MaxLauncher</Hyperlink>
                </TextBlock>

                <!-- Manual update check. Disabled when running outside a Velopack-managed install
                     (e.g. dev build / hand-extracted zip) — there's nothing to atomically swap. -->
                <ui:Button x:Name="CheckForUpdatesButton" Content="{Markup:Loc About_CheckForUpdates}"
                           Margin="0,28,0,0" HorizontalAlignment="Center"
                           Padding="16,6"
                           Click="OnCheckForUpdatesClicked" />
                <TextBlock x:Name="UpdateStatusText" Foreground="{DynamicResource AccentForegroundDarkBrush}"
                           FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
    </Grid>
    </Border>
</ui:FluentWindow>
