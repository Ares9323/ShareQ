<Window x:Class="AresToys.App.Views.WormholeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        AllowDrop="True"
        Width="320" Height="240"
        MinWidth="220" MinHeight="80"
        Title="Wormhole">
    <!-- Outer border: rounded corners + theme accent. Slightly transparent to feel like a soft
         layer over the wallpaper rather than a hard floating panel. The child header Border
         carries its own top CornerRadius="6,6,0,0" so an opaque header doesn't paint over the
         outer rounded corners (WPF children don't inherit a parent Border's geometry clip). -->
    <Border CornerRadius="6"
            Background="{DynamicResource Surface1Brush}"
            Opacity="0.95"
            BorderBrush="{DynamicResource AccentBackgroundBrush}"
            BorderThickness="1"
            MouseDown="OnContentAreaMouseDown"
            DragEnter="OnDragEnter"
            DragOver="OnDragOver"
            Drop="OnDrop">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header chrome. Layout: [chevron] [title] [spacer] [lock] [hamburger].
                 CornerRadius="6,6,0,0" matches the outer Border so the top corners stay rounded. -->
            <Border Grid.Row="0" Height="32" CornerRadius="6,6,0,0"
                    Background="{DynamicResource Surface2Brush}"
                    MouseLeftButtonDown="OnHeaderMouseDown"
                    MouseLeftButtonUp="OnHeaderMouseUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Chevron: toggle roll-up. Glyph swapped at runtime in ApplyRollState. -->
                    <Button x:Name="ChevronButton"
                            Grid.Column="0"
                            Width="28" Height="28"
                            Margin="2,2,0,2"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OnChevronClicked"
                            ToolTip="Roll up / unroll">
                        <TextBlock x:Name="ChevronGlyph"
                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>

                    <!-- Title: TextBlock (visible by default) and TextBox (visible when renaming
                         via the hamburger menu). Both bound to Title so the values stay in sync;
                         visibility is toggled in code-behind. -->
                    <TextBlock x:Name="TitleText"
                               Grid.Column="1"
                               Text="{Binding Title}"
                               Foreground="{DynamicResource AccentForegroundBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="6,0,8,0"
                               TextTrimming="CharacterEllipsis" />
                    <TextBox x:Name="TitleEditor"
                             Grid.Column="1"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"
                             Margin="6,0,8,0"
                             FontSize="13" FontWeight="SemiBold"
                             KeyDown="OnTitleEditorKeyDown"
                             LostFocus="OnTitleEditorLostFocus" />

                    <Button x:Name="LockButton"
                            Grid.Column="2"
                            Width="28" Height="28"
                            Margin="0,2"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OnLockClicked"
                            ToolTip="Lock / unlock">
                        <TextBlock x:Name="LockGlyph"
                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>

                    <Button x:Name="HamburgerButton"
                            Grid.Column="3"
                            Width="28" Height="28"
                            Margin="0,2,4,2"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OnHamburgerClicked"
                            ToolTip="Menu">
                        <TextBlock FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Run Text="&#xE700;" />
                        </TextBlock>
                    </Button>
                </Grid>
            </Border>

            <!-- Content area: WrapPanel of items, scrollable on overflow. Empty state shows a
                 hint about dropping files. The placeholder is hidden in code-behind whenever
                 there's at least one item, and reappears when the last one is removed. -->
            <Border x:Name="ContentArea" Grid.Row="1" Padding="6">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ItemsHost">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Per-item tile: icon on top + label below, fixed 72-wide
                                         column so the WrapPanel produces a tidy grid even with
                                         variable filename lengths. MouseDown handler turns a
                                         double click into a "open the target via .lnk" gesture. -->
                                    <Border Width="72" Height="68" Margin="4"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnItemMouseDown">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                                            <Image Source="{Binding Icon}"
                                                   Width="32" Height="32"
                                                   Margin="0,4,0,4" />
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource AccentForegroundBrush}"
                                                       FontSize="11"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="28"
                                                       TextTrimming="CharacterEllipsis"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock x:Name="EmptyStateHint"
                               Text="No items yet — drop files here."
                               Foreground="{DynamicResource AccentForegroundDarkBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
