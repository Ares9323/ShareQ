<Window x:Class="AresToys.App.Views.NewWormholeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStartupLocation="CenterOwner"
        Title="New wormhole"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{DynamicResource Surface1Brush}"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="New wormhole" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,0,16" />

        <!-- Title input. Defaults to "Wormhole"; the user typically edits it before confirming
             so we focus + select-all in OnLoaded for a one-keystroke retype gesture. -->
        <TextBlock Text="Title" Foreground="{DynamicResource AccentForegroundBrush}"
                   FontSize="12" Margin="0,0,0,4" />
        <TextBox x:Name="TitleBox" Text="Wormhole" FontSize="13" Margin="0,0,0,12" />

        <!-- Type radio. Shortcuts/Links = curated list of .lnk/.url; Folder portal = live
             mirror of a real folder. Picking Folder portal auto-opens the folder picker (the
             field below is informational only — you can't usefully type a path here). -->
        <TextBlock Text="Type" Foreground="{DynamicResource AccentForegroundBrush}"
                   FontSize="12" Margin="0,0,0,4" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="DataRadio" GroupName="Kind" IsChecked="True"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Checked="OnKindChanged" Margin="0,0,20,0">
                <TextBlock Text="Shortcuts/Links"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           VerticalAlignment="Center" />
            </RadioButton>
            <RadioButton x:Name="PortalRadio" GroupName="Kind"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Checked="OnKindChanged">
                <TextBlock Text="Folder portal"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           VerticalAlignment="Center" />
            </RadioButton>
        </StackPanel>

        <!-- Portal folder row: surfaces the chosen path read-only-ish (the textbox is enabled
             but the picker is the authoritative way to set it — typing a path is error-prone
             and was the cause of a "the field doesn't accept my input" report in -A). -->
        <StackPanel x:Name="PortalFolderRow" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock Text="Folder" Foreground="{DynamicResource AccentForegroundBrush}"
                       FontSize="12" Margin="0,0,0,4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderBox" Grid.Column="0" FontSize="13"
                         IsReadOnly="True" />
                <ui:Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                           Padding="12,4" Click="OnBrowseClicked" />
            </Grid>
            <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11"
                       TextWrapping="Wrap" Margin="0,6,0,0"
                       Text="Files added to / removed from this folder via Explorer appear or disappear automatically. Drop on the wormhole: same drive moves, different drive copies — Ctrl forces Copy, Shift forces Move." />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <ui:Button x:Name="OkButton" Content="Create" Padding="14,4" Margin="0,0,8,0"
                       Appearance="Primary" Click="OnOkClicked" />
            <ui:Button Content="Cancel" Padding="14,4" Click="OnCancelClicked" />
        </StackPanel>
    </StackPanel>
</Window>
