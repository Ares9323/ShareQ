<ui:FluentWindow x:Class="AresToys.App.Views.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:Markup="clr-namespace:AresToys.App.Markup"
        Title=""
        Width="460" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowBackdropType="None"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource Surface2Brush}"
        Foreground="{DynamicResource AccentForegroundBrush}">
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- titlebar -->
                <RowDefinition Height="*" />     <!-- content -->
            </Grid.RowDefinitions>
            <ui:TitleBar Grid.Row="0" Title="" ShowMaximize="False" ShowMinimize="False">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{StaticResource AresToysLogo}" Margin="0,0,-12,0" />
                </ui:TitleBar.Icon>
                <ui:TitleBar.Header>
                    <Grid Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="AresToys - Set hotkey"
                                   Foreground="#FFF" FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center" />
                    </Grid>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Press a key combination"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           FontSize="14" FontWeight="SemiBold" />
                <Border Grid.Row="1" Margin="0,12" Padding="12"
                        Background="{DynamicResource Surface3Brush}"
                        BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="1" CornerRadius="4">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="ComboPreview" Text="(waiting for keys…)"
                                   FontFamily="Consolas" FontSize="14"
                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11"
                                   Margin="0,8,0,0" HorizontalAlignment="Center"
                                   Text="Hold modifiers (Ctrl / Alt / Shift / Win) then press a key. Esc cancels." />
                    </StackPanel>
                </Border>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Reset only shows for built-in workflows (visibility set in code-behind);
                         Clear wipes the binding; Cancel dismisses without changes. -->
                    <ui:Button Grid.Column="0" x:Name="ResetButton" Content="{Markup:Loc HotkeyCapture_ResetToDefault}"
                               HorizontalAlignment="Left" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="1" x:Name="ClearButton" Content="{Markup:Loc HotkeyCapture_ClearBinding}"
                               HorizontalAlignment="Left" />
                    <ui:Button Grid.Column="3" x:Name="CancelButton" Content="{Markup:Loc Common_Cancel}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
