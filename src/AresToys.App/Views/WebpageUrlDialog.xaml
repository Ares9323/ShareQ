<Window x:Class="AresToys.App.Views.WebpageUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:Markup="clr-namespace:AresToys.App.Markup"
        Title="Capture webpage"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <!-- AllowsTransparency=True + Background=Transparent on the Window so the inner Border can
         render rounded corners + a 1px outer stroke. Same shell as IconPickerDialog /
         PinSourceChooserWindow / Launcher. WindowStartupLocation=Manual because Center* + SizeToContent
         is broken in WPF (the window is positioned before content is measured → lands at 0,0);
         the xaml.cs recenters on the active monitor in the Loaded event, DPI-aware. -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource OuterBorderBrush}" BorderThickness="1"
            CornerRadius="8">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Webpage URL" Foreground="White"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

            <ui:TextBox Grid.Row="1" x:Name="UrlBox"
                        PlaceholderText="https://example.com" />

            <TextBlock Grid.Row="2" Foreground="{DynamicResource AccentForegroundDarkBrush}"
                       FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                       Text="The page is loaded in a hidden WebView2, then captured full-height (everything below the fold included). Login-walled pages won't render the protected content." />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button x:Name="OkButton" Content="Capture" Width="92" Height="32" Margin="0,0,8,0"
                           IsDefault="True" Click="OnOkClicked" FontWeight="SemiBold"
                           Appearance="Primary" />
                <ui:Button Content="{Markup:Loc Common_Cancel}" Width="80" Height="32"
                           IsCancel="True" Click="OnCancelClicked" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
