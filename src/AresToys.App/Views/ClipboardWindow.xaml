<ui:FluentWindow x:Class="AresToys.App.Views.ClipboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:AresToys.App.ViewModels"
        xmlns:Markup="clr-namespace:AresToys.App.Markup"
        Title="AresToys - Clipboard"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="980" Height="600"
        MinWidth="640" MinHeight="380"
        WindowStartupLocation="Manual"
        WindowBackdropType="None"
        Background="{DynamicResource Surface2Brush}"
        Foreground="{DynamicResource AccentForegroundBrush}"
        ExtendsContentIntoTitleBar="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <ui:FluentWindow.Resources>
        <!-- Same Primary-button override as the Settings sidebar: rest = AccentBackgroundDark
             (deeper green/blue), hover/pressed flip to the brighter AccentBackground for
             visible feedback. Border colour matches the fill so no light halo around the
             primary buttons. Scoped to this Window so other Primary buttons elsewhere stay
             on the global accent. Covers the selected category tab, the toolbar copy/edit/pin
             buttons, the Clear all button, and any future Primary button added to the popup. -->
        <SolidColorBrush x:Key="AccentButtonBackground"
                         Color="{DynamicResource AccentBackgroundDarkColor}" />
        <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"
                         Color="{DynamicResource AccentBackgroundColor}" />
        <SolidColorBrush x:Key="AccentButtonBackgroundPressed"
                         Color="{DynamicResource AccentBackgroundColor}" />
        <SolidColorBrush x:Key="AccentControlElevationBorderBrush"
                         Color="{DynamicResource AccentBackgroundDarkColor}" />
        <SolidColorBrush x:Key="AccentButtonBorderBrushPressed"
                         Color="{DynamicResource AccentBackgroundColor}" />

        <!-- Press-feedback for the right-rail toolbar icon buttons (Paste / Pin / Copy path /
             QR / Edit image / Edit text / Delete). The default ui:Button press visual is too
             subtle — the user couldn't tell whether they'd actually clicked. Same Opacity 0.7
             dip used by the category-chip style above (TargetName="Bd" trigger on IsPressed).
             Opacity is non-destructive: it doesn't touch the WPF-UI template's internal
             RenderTransform / Background animations, so we get the visual cue without breaking
             keyed-style cascades. Scoped to this Window only — global ui:Button overrides
             cause Primary / Danger / chip buttons to look broken in unrelated surfaces. -->
        <Style x:Key="ToolbarIconBtn" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>
    <!-- Accent-tinted 2px frame around the whole window content (titlebar + body), matching
         MainWindow / ImageEffectsWindow / GradientEditorWindow / QrGeneratorWindow. FluentWindow's
         own chrome stays outside this Border, so the accent line reads as an inner "telaio". -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource OuterBorderBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0 titlebar -->
                <RowDefinition Height="*" />     <!-- 1 main content -->
            </Grid.RowDefinitions>

            <!-- WPF-UI titlebar — drag / max / min / close + dark caption via DWM. Mirrors
                 LauncherWindow's layout: the title's right-side carries Search + Pinned mode
                 toggle. Title text rendered explicitly inside the Header Grid because a wide
                 Header can otherwise hide WPF-UI's own Title slot. -->
            <!-- Title="" intentionally — see LauncherWindow for rationale. -->
            <ui:TitleBar Grid.Row="0" Title="">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{StaticResource AresToysLogo}" Margin="0,0,-12,0" />
                </ui:TitleBar.Icon>
                <ui:TitleBar.Header>
                    <Grid Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />    <!-- title text -->
                            <ColumnDefinition Width="200" />     <!-- search -->
                            <ColumnDefinition Width="Auto" />    <!-- pinned toggle -->
                            <ColumnDefinition Width="*" />       <!-- spacer -->
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Markup:Loc Clipboard_Title}"
                                   Foreground="{DynamicResource AccentForegroundBrush}" FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,16,0" />
                        <ui:TextBox Grid.Column="1" x:Name="SearchBox"
                                    PlaceholderText="{Markup:Loc Clipboard_SearchPlaceholder}"
                                    FontSize="11"
                                    Margin="0,0,8,0"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <!-- Pinned (sticky) mode toggle. When on, paste / double-click no
                             longer auto-dismisses the popup — the focus is force-grabbed back
                             so multi-paste workflows keep firing into the same target. Esc and
                             Win+V still dismiss. State persisted to clipboard.pinned. Caption
                             swaps via DataTrigger to mirror the launcher's drag-mode toggle. -->
                        <ui:Button Grid.Column="2"
                                   Padding="10,4" FontSize="11"
                                   Click="OnPinnedToggleClick"
                                   ToolTip="{Markup:Loc Clipboard_TooltipPinned}">
                            <ui:Button.Style>
                                <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <Setter Property="Content" Value="{Markup:Loc Clipboard_PinnedMode}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                            <Setter Property="Content" Value="{Markup:Loc Clipboard_PinnedOn}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </Grid>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <Grid Grid.Row="1" Margin="14,0,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- type chips + tabs + Clear all + search (combined header) -->
                    <RowDefinition Height="*" />     <!-- history + toolbar + preview -->
                    <RowDefinition Height="Auto" />  <!-- footer -->
                </Grid.RowDefinitions>

                <!-- ── Combined header: image/text chips, category tabs, Clear all. Search +
                      Pinned toggle moved to the titlebar (matching the launcher's layout). -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- type chips -->
                        <ColumnDefinition Width="*" />     <!-- category tabs -->
                        <ColumnDefinition Width="Auto" />  <!-- Clear all -->
                    </Grid.ColumnDefinitions>

                    <!-- Type chips. ToggleButton; ON = include that kind in the list, OFF =
                         hide. ShowImages also covers files / videos; ShowText covers HTML
                         (an image-URL pasted from a browser is HTML clipboard, not Image — gating
                         it under the text chip matches user expectation). Both off = empty list.
                         State persisted to clipboard.show_images / clipboard.show_text.
                         Background = AccentBackgroundDarkBrush so the chips match the unselected
                         category-tab tone next to them; foreground stays the default light
                         AccentForegroundBrush so the glyph reads on top. -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <StackPanel.Resources>
                            <!-- Off → Surface3Brush (neutral, "filter not applied").
                                 On → AccentBackgroundDarkBrush (the inactive-tab tone, signals
                                 the filter is active). Hover → AccentBackgroundBrush (highlight).
                                 Foreground stays light at every state. -->
                            <Style TargetType="ToggleButton">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Surface3Brush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBackgroundBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBackgroundBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>
                        <ToggleButton IsChecked="{Binding ShowImages, Mode=TwoWay}"
                                      Margin="0,0,4,0">
                            <ToggleButton.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterImageTitle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterIncludes}" Margin="0,4,0,2" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterImageBullet1}" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterImageBullet2}" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterImageBullet3}" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterClickToHide}" Margin="0,4,0,0" FontStyle="Italic" />
                                    </StackPanel>
                                </ToolTip>
                            </ToggleButton.ToolTip>
                            <TextBlock Text="&#xEB9F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding ShowText, Mode=TwoWay}">
                            <ToggleButton.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterTextTitle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterIncludes}" Margin="0,4,0,2" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterTextBullet1}" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterTextBullet2}" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterTextBullet3}" />
                                        <TextBlock Text="{Markup:Loc Clipboard_FilterClickToHide}" Margin="0,4,0,0" FontStyle="Italic" />
                                    </StackPanel>
                                </ToolTip>
                            </ToggleButton.ToolTip>
                            <!-- E8A5 = Document — universal page glyph available in both Segoe
                                 Fluent Icons (Win11) and Segoe MDL2 Assets (Win10) fallback. -->
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                    </StackPanel>

                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Categories}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryTab}">
                                <!-- Icon + name on the same row. Icon is empty for the
                                     synthetic "All" tab and for categories the user hasn't
                                     given an emoji to; the StackPanel collapses spacing in
                                     that case (no margin around an empty TextBlock). -->
                                <ui:Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding Name}"
                                           Appearance="{Binding IsActive, Converter={StaticResource BoolToAppearance}}"
                                           Margin="0,0,4,0"
                                           Tag="{Binding Name}"
                                           AllowDrop="True"
                                           DragEnter="OnCategoryTabDragEnter"
                                           DragLeave="OnCategoryTabDragLeave"
                                           Drop="OnCategoryTabDrop">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{DynamicResource IconFont}"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Icon, Converter={StaticResource NonEmptyToVisibility}}" />
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </ui:Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ui:Button Grid.Column="2"
                               Content="{Markup:Loc Clipboard_ClearAll}"
                               Appearance="Danger"
                               Margin="8,0,0,0"
                               Cursor="Arrow"
                               Command="{Binding ClearAllCommand}"
                               ToolTip="{Markup:Loc Clipboard_TooltipClearAll}" />
                </Grid>

                <!-- ── Body: history list | splitter | preview pane | vertical toolbar ────── -->
                <!-- Toolbar lives in the rightmost (Auto) column so the GridSplitter (col 1)
                     resizes only the list and the preview — the toolbar stays anchored to the
                     window's right edge and never gets in the way of the resize handle. -->
                <Grid Grid.Row="1">
                    <!-- MinWidths kept low so the toolbar (Auto column on the right) is always
                         guaranteed its ~40 px regardless of how aggressively the user shrinks the
                         window. The preview column's content (text + image) wraps/scales below
                         these mins, which is the right trade-off — losing toolbar buttons on
                         shrink is much worse than a tighter preview. -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="160" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition x:Name="PreviewColumn" Width="2*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource Surface1Brush}"
                            BorderBrush="{DynamicResource InnerBorderBrush}" BorderThickness="1" CornerRadius="4"
                            Padding="6">
                            <ListBox x:Name="HistoryList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding Rows}"
                                     SelectedItem="{Binding SelectedRow}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <!-- Kill the system focus rectangle (the faint blue square
                                             outline on the selected row) — we already paint our own
                                             selection state on the inner Border via IsSelected
                                             DataTrigger below. -->
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <!-- Replace the default ListBoxItem template with a flat
                                             ContentPresenter. The default template renders a
                                             SystemColors-tinted selection chrome on top of our
                                             custom Border, producing the doubled-up "blue rectangle
                                             over green fill" look the user reported. A transparent
                                             pass-through template lets the inner Border be the only
                                             visual for selection / hover. -->
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ItemRowViewModel}">
                                        <Border x:Name="RowBorder"
                                                Padding="8,6" Margin="0,2"
                                                CornerRadius="4"
                                                BorderThickness="2"
                                                AllowDrop="True"
                                                PreviewMouseRightButtonDown="OnItemRowPreviewRightClick"
                                                PreviewMouseLeftButtonDown="OnItemRowPreviewLeftButtonDown"
                                                PreviewMouseMove="OnItemRowPreviewMouseMove"
                                                DragEnter="OnItemRowDragEnter"
                                                DragLeave="OnItemRowDragLeave"
                                                Drop="OnItemRowDrop"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Border.ContextMenu>
                                                <!-- ContextMenu lives in a popup outside the visual tree, so
                                                     RelativeSource AncestorType=Window doesn't resolve from inside.
                                                     Stash the parent VM in Border.Tag and rebind the menu's
                                                     DataContext via PlacementTarget.Tag. -->
                                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{Markup:Loc Clipboard_MenuPinUnpin}"
                                                              Command="{Binding TogglePinSelectedCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="{Markup:Loc Clipboard_MenuMoveTo}"
                                                              ItemsSource="{Binding MovableCategories}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command"
                                                                        Value="{Binding DataContext.MoveSelectedToCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <MenuItem Header="{Markup:Loc Clipboard_MenuCopyTo}"
                                                              ItemsSource="{Binding MovableCategories}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command"
                                                                        Value="{Binding DataContext.CopySelectedToCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <Separator />
                                                    <!-- Rename label — flips the row template into inline-rename
                                                         mode. Handler reads the clicked row from the menu's
                                                         PlacementTarget.DataContext (the row VM) and sets
                                                         IsRenaming=true so the title TextBlock swaps for a TextBox. -->
                                                    <MenuItem Header="{Markup:Loc Clipboard_MenuRenameLabel}"
                                                              Click="OnRenameLabelClicked" />
                                                    <Separator />
                                                    <!-- Generate QR — only meaningful for text-shaped rows
                                                         (Text/Html/Rtf). On Image/Video/Files the entry hides
                                                         entirely; the handler still has a defensive bail-out for
                                                         programmatic invocation paths. -->
                                                    <MenuItem Header="{Markup:Loc Clipboard_MenuGenerateQr}"
                                                              Click="OnGenerateQrFromItemClicked"
                                                              Visibility="{Binding IsTextSelected, Converter={StaticResource BoolToVisibility}}" />
                                                    <Separator />
                                                    <MenuItem Header="{Markup:Loc Common_Delete}"
                                                              Command="{Binding DeleteSelectedCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBackgroundDarkBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBackgroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Left rail: Ctrl+N quick-paste badge. The pinned-state glyph used
                                                     to live here as well — replaced by the right-edge accent strip
                                                     (last column) for visual consistency between labeled and
                                                     unlabeled pinned rows. -->
                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,0,8,0">
                                                    <Border Width="22" Height="22"
                                                            Background="{DynamicResource AccentBackgroundLightBrush}"
                                                            CornerRadius="3"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,0,0,2"
                                                            Visibility="{Binding HasIndexBadge, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding IndexBadge}"
                                                                   Foreground="{DynamicResource Surface1Brush}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Width="56" Height="56"
                                                        Margin="0,0,10,0"
                                                        Background="{DynamicResource Surface1Brush}"
                                                        BorderBrush="{DynamicResource InnerBorderBrush}" BorderThickness="1"
                                                        Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}">
                                                    <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                                           Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <!-- Title row: TextBlock (TitleText = Label if set, else
                                                         Preview) + a 📎 badge marking labeled rows. Swaps to a
                                                         TextBox when IsRenaming is true so the user can edit the
                                                         label in place. Enter commits, Esc/LostFocus cancel. -->
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal"
                                                                    Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <TextBlock Text="&#xF02B;"
                                                                       FontFamily="{DynamicResource IconFont}"
                                                                       Foreground="{DynamicResource AccentBackgroundLightBrush}"
                                                                       FontSize="11"
                                                                       Margin="0,0,6,0"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasLabel, Converter={StaticResource BoolToVisibility}}" />
                                                            <TextBlock Text="{Binding TitleText}"
                                                                       Foreground="{DynamicResource AccentForegroundBrush}"
                                                                       FontSize="13"
                                                                       TextWrapping="Wrap"
                                                                       MaxHeight="60"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBox x:Name="RenameTextBox"
                                                                 Text="{Binding Label, Mode=OneWay}"
                                                                 MaxLength="200"
                                                                 FontSize="13"
                                                                 Foreground="{DynamicResource AccentForegroundBrush}"
                                                                 Background="{DynamicResource Surface1Brush}"
                                                                 BorderBrush="{DynamicResource AccentBackgroundBrush}"
                                                                 BorderThickness="1"
                                                                 Padding="4,2"
                                                                 IsVisibleChanged="OnRenameTextBoxVisibleChanged"
                                                                 KeyDown="OnRenameTextBoxKeyDown"
                                                                 LostFocus="OnRenameTextBoxLostFocus"
                                                                 Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibility}}" />
                                                    </Grid>
                                                    <!-- Secondary line: original content snippet shown under a label
                                                         when the user opts in via App Settings →
                                                         clipboard.show_snippet_with_label. ShowSnippet on the row VM
                                                         already AND's HasLabel with the setting, so plain rows
                                                         (no label) never render this. -->
                                                    <TextBlock Text="{Binding SnippetText}"
                                                               Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="40"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding ShowSnippet, Converter={StaticResource BoolToVisibility}}" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding Age}" />
                                                        <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding KindLabel}" />
                                                        <TextBlock Foreground="#666" FontSize="11" Text=" · " />
                                                        <TextBlock Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" Text="{Binding SourceProcess}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Reorder chevrons on the pinned strip — appear only on hover over a pinned
                                                     row (MultiDataTrigger: Pinned AND IsMouseOver on the row Border). Click
                                                     handlers call PopupWindowViewModel.MovePinnedAsync which swaps the row
                                                     with its neighbour. Drag-to-reorder is the alternative gesture and is
                                                     wired on the row Border's Drop event. -->
                                                <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Pinned}" Value="True" />
                                                                        <Condition Binding="{Binding IsMouseOver, ElementName=RowBorder}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Button Width="22" Height="20" Padding="0" Margin="0,0,0,2"
                                                            Background="Transparent" BorderThickness="0"
                                                            Click="OnRowMoveUpClicked"
                                                            ToolTip="{Markup:Loc Clipboard_TooltipMoveUp}">
                                                        <TextBlock Text="&#xF077;" FontFamily="{DynamicResource IconFont}"
                                                                   FontSize="11" Foreground="{DynamicResource AccentForegroundBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Button>
                                                    <Button Width="22" Height="20" Padding="0"
                                                            Background="Transparent" BorderThickness="0"
                                                            Click="OnRowMoveDownClicked"
                                                            ToolTip="{Markup:Loc Clipboard_TooltipMoveDown}">
                                                        <TextBlock Text="&#xF078;" FontFamily="{DynamicResource IconFont}"
                                                                   FontSize="11" Foreground="{DynamicResource AccentForegroundBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Button>
                                                </StackPanel>
                                                <!-- Pinned-state indicator: a 4px accent-coloured strip flush
                                                     against the row's right edge. Replaces the two pin glyphs
                                                     (rail 📌 + inline FA map-pin) — uniform treatment for
                                                     labeled and unlabeled rows. Negative margin escapes the
                                                     RowBorder's Padding so the strip touches the actual edge.
                                                     Visibility is Collapsed (= zero width contribution) when
                                                     the row isn't pinned, so the layout doesn't shift. -->
                                                <Border Grid.Column="4"
                                                        Width="4"
                                                        Margin="6,-6,-8,-6"
                                                        Background="{DynamicResource AccentBackgroundLightBrush}"
                                                        Visibility="{Binding Pinned, Converter={StaticResource BoolToVisibility}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="4"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ShowsPreview="False" />

                    <!-- Preview pane: meta line + image / text / RTF / HTML body. The body
                         visibilities are driven by the VM's IsImagePreview / IsTextPreview /
                         IsRtfPreview / IsHtmlPreview flags. RichTextBox.Document and
                         WebBrowser.NavigateToString aren't bindable — code-behind watches the
                         VM's PropertyChanged and pushes the documents imperatively. -->
                    <Border Grid.Column="2"
                            x:Name="PreviewPane"
                            Background="{DynamicResource Surface1Brush}"
                            BorderBrush="{DynamicResource InnerBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- Row 0: Label + (optional) Trigger sequence on the same line.
                                 Label takes the lion's share (column 0 = *), Trigger is a
                                 narrower field on the right (column 1 = 200px) so the user can
                                 see both at once instead of stacking them. The Trigger column is
                                 entirely collapsed when the Key Sequences module is disabled —
                                 no listener installed, no point editing a trigger string. -->
                            <Grid Grid.Row="0" Margin="8,6,8,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Always-on Label editor for the selected row. Bound OneWay to
                                     SelectedRow.Label; code-behind LostFocus/Enter handler reads
                                     the TextBox text and persists via PopupWindowViewModel.CommitLabelAsync. -->
                                <ui:TextBox Grid.Column="0"
                                            x:Name="PreviewPaneLabelBox"
                                            MaxLength="200"
                                            FontSize="12"
                                            Text="{Binding SelectedRow.Label, Mode=OneWay, FallbackValue=''}"
                                            PlaceholderText="{Markup:Loc Clipboard_LabelPlaceholder}"
                                            KeyDown="OnPreviewLabelKeyDown"
                                            LostFocus="OnPreviewLabelLostFocus"
                                            Visibility="{Binding SelectedRow, Converter={StaticResource NotNullToVisibility}}" />
                                <!-- Key Sequences trigger ([a-zA-Z0-9_]+). PreviewTextInput
                                     handler filters disallowed chars at input time so users can't
                                     even type invalid characters in the box. -->
                                <ui:TextBox Grid.Column="1"
                                            x:Name="PreviewPaneTriggerBox"
                                            MinWidth="200"
                                            Margin="6,0,0,0"
                                            MaxLength="64"
                                            FontSize="12"
                                            Text="{Binding SelectedRow.Trigger, Mode=OneWay, FallbackValue=''}"
                                            PlaceholderText="Trigger sequence"
                                            ToolTip="Type a short tag (letters, digits, underscore) to make this entry pasteable from any app. While the Key Sequences module is on, typing the tag anywhere on the system opens the overlay so you can confirm + paste this entry. Leave empty to disable for this item."
                                            PreviewTextInput="OnPreviewTriggerTextInput"
                                            DataObject.Pasting="OnPreviewTriggerPasting"
                                            KeyDown="OnPreviewTriggerKeyDown"
                                            LostFocus="OnPreviewTriggerLostFocus"
                                            Visibility="{Binding IsKeySequencesEnabled, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="8,2,8,6"
                                       Foreground="{DynamicResource AccentForegroundDarkBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding PreviewMeta}" />
                            <Grid Grid.Row="2" Margin="0,0,0,4">
                                <!-- Image preview wrapped in a ScrollViewer so the user can pan after
                                     zooming. Ctrl+wheel scales the LayoutTransform (PreviewMouseWheel
                                     in code-behind to intercept before the ScrollViewer tries to
                                     consume the event for vertical scroll). The wheel without Ctrl
                                     keeps the default scroll behaviour. PreviewImageScale is reset
                                     to 1.0 every time SelectedRow flips so a new item starts
                                     fit-to-container instead of inheriting the previous zoom. -->
                                <ScrollViewer x:Name="PreviewImageScroller"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="OnPreviewImageWheel"
                                              PreviewMouseDown="OnPreviewImagePreviewMouseDown"
                                              PreviewMouseMove="OnPreviewImageMouseMove"
                                              PreviewMouseUp="OnPreviewImagePreviewMouseUp"
                                              Visibility="{Binding IsImagePreview, Converter={StaticResource BoolToVisibility}}">
                                    <Image Source="{Binding PreviewImageBytes, Converter={StaticResource BytesToImage}}"
                                           Stretch="Uniform"
                                           Margin="8">
                                        <Image.LayoutTransform>
                                            <ScaleTransform x:Name="PreviewImageScale" ScaleX="1" ScaleY="1" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </ScrollViewer>
                                <!-- Video / animated GIF preview. MediaElement source is set
                                     imperatively from code-behind on PreviewVideoPath changes
                                     so the file handle is properly released between selections
                                     (binding directly is unreliable for MediaElement). A small
                                     translucent button bar overlays the bottom of the surface
                                     for Play/Pause + restart, and the entire surface accepts
                                     left-click to toggle Play/Pause (matches Telegram/WhatsApp
                                     UX). LoadedBehavior=Manual gives us full control. -->
                                <Grid Visibility="{Binding IsVideoPreview, Converter={StaticResource BoolToVisibility}}">
                                    <MediaElement x:Name="PreviewVideoPlayer"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Stop"
                                                  Stretch="Uniform"
                                                  Margin="8"
                                                  ScrubbingEnabled="False"
                                                  MediaOpened="OnPreviewVideoOpened"
                                                  MediaEnded="OnPreviewVideoEnded"
                                                  MediaFailed="OnPreviewVideoFailed"
                                                  MouseLeftButtonDown="OnPreviewVideoSurfaceClick"
                                                  Cursor="Hand" />
                                    <!-- Bottom control bar: Play/Pause + seek slider + timecode.
                                         Stretched horizontally so the slider grows with the
                                         preview pane; the slider's Value is driven by a
                                         DispatcherTimer while playing and pushed back to the
                                         MediaElement.Position on user drag (a guard flag avoids
                                         the feedback loop). Slider clicks on the track count as
                                         a seek too (WPF default with IsMoveToPointEnabled). -->
                                    <Border VerticalAlignment="Bottom"
                                            HorizontalAlignment="Stretch"
                                            Margin="16,0,16,12"
                                            Background="#AA000000"
                                            CornerRadius="6"
                                            Padding="6,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Play/Pause: simple square / triangle from the
                                                 basic Symbols block — the dedicated media-control
                                                 codepoints (⏸ / ▶︎) render inconsistently across
                                                 fallback fonts. -->
                                            <Button Grid.Column="0"
                                                    x:Name="PreviewVideoPlayPauseButton"
                                                    Click="OnPreviewVideoPlayPauseClicked"
                                                    Width="32" Height="28"
                                                    Margin="0,0,8,0"
                                                    Background="Transparent"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="12"
                                                    Content="■"
                                                    ToolTip="Play / Pause (click anywhere on the video also toggles)." />
                                            <Slider Grid.Column="1"
                                                    x:Name="PreviewVideoSlider"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    SmallChange="0.5"
                                                    LargeChange="5"
                                                    IsMoveToPointEnabled="True"
                                                    VerticalAlignment="Center"
                                                    ValueChanged="OnPreviewVideoSliderValueChanged"
                                                    Foreground="White" />
                                            <TextBlock Grid.Column="2"
                                                       x:Name="PreviewVideoTimeText"
                                                       Margin="8,0,8,0"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Consolas"
                                                       Text="00:00 / 00:00" />
                                            <!-- Mute toggle. Persists globally via the settings
                                                 store (clipboard.preview.muted) so the user's
                                                 last choice carries across selections + restarts. -->
                                            <Button Grid.Column="3"
                                                    x:Name="PreviewVideoMuteButton"
                                                    Click="OnPreviewVideoMuteClicked"
                                                    Width="32" Height="28"
                                                    Background="Transparent"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="12"
                                                    Content="🔊"
                                                    ToolTip="Mute / unmute (remembered across selections + restarts)." />
                                        </Grid>
                                    </Border>
                                </Grid>
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         FontSize="12"
                                         Margin="6,0,6,6"
                                         Visibility="{Binding IsTextPreview, Converter={StaticResource BoolToVisibility}}" />
                                <RichTextBox x:Name="RtfPreviewBox"
                                             IsReadOnly="True"
                                             IsTabStop="False"
                                             Background="Transparent"
                                             Foreground="White"
                                             BorderThickness="0"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Margin="6,0,6,6"
                                             Visibility="{Binding IsRtfPreview, Converter={StaticResource BoolToVisibility}}" />
                                <WebBrowser x:Name="HtmlPreviewBox"
                                            Margin="6,0,6,6"
                                            Visibility="{Binding IsHtmlPreview, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Vertical CopyQ-style icon toolbar — anchored to the window's right edge
                         so the GridSplitter has clear vertical track. Glyphs are Segoe Fluent
                         Icons (built-in on Win11; Segoe MDL2 Assets on Win10 — same code points).
                         Wrapped in a ScrollViewer so a very short window can scroll the toolbar
                         instead of clipping the bottom buttons. -->
                    <ScrollViewer Grid.Column="3"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="8,2,0,2">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipPaste}"
                                       Appearance="Primary"
                                       Command="{Binding PasteSelectedCommand}">
                                <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Pin/unpin: visual state mirrors the SelectedRow's Pinned flag.
                                 DataTrigger on Pinned=True swaps the button's Appearance to
                                 Primary so the accent fill makes "this row is pinned" obvious
                                 — same on/off pattern the category-tab chips and filter chips
                                 use. The trigger lives in a per-button Style that BasedOn the
                                 ToolbarIconBtn so the press-feedback Opacity-dip carries over. -->
                            <ui:Button Width="32" Height="32" Padding="0"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipPin}"
                                       Command="{Binding TogglePinSelectedCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource ToolbarIconBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedRow.Pinned}" Value="True">
                                                <Setter Property="Appearance" Value="Primary" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Copy file path to clipboard — visible only when the selected row
                                 has a real on-disk file (image/video/files saved via a SaveToFile
                                 step). Lets the user paste the path into another app instead of
                                 the binary contents. Bound to HasFileOnDisk so rows without a
                                 BlobRef collapse the button entirely (nothing to copy). -->
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipCopyPath}"
                                       ToolTipService.InitialShowDelay="500"
                                       ToolTipService.ShowOnDisabled="True"
                                       Command="{Binding CopyPathToClipboardCommand}"
                                       Visibility="{Binding HasFileOnDisk, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Generate QR — opens the live generator pre-filled with the row's
                                 preview text. Visible only for text-shaped rows (Text/Html/Rtf):
                                 a QR code carries a textual payload, so on Image/Video/Files
                                 rows the button has nothing useful to do and collapses out. -->
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipQr}"
                                       Click="OnGenerateQrFromItemClicked"
                                       Visibility="{Binding IsTextSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xED14;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Edit (image): in-app annotation editor. Hidden for text /
                                 file rows. -->
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipOpenEditor}"
                                       Command="{Binding OpenInEditorCommand}"
                                       Visibility="{Binding IsImageSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Edit (text / HTML / RTF): external editor — VSCode / Notepad /
                                 whatever's set in Settings → Capture → External editor command,
                                 falling back to the Windows .txt default. Edits stream back to
                                 the SQLite item via FileSystemWatcher. Same Edit glyph as the
                                 image button — both buttons share the slot mutually-exclusively. -->
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipExtEditor}"
                                       Command="{Binding OpenInExternalEditorCommand}"
                                       Visibility="{Binding IsTextSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipShowExplorer}"
                                       Command="{Binding OpenInExplorerCommand}"
                                       Visibility="{Binding HasFileOnDisk, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Open URL in browser — visible only when the selected text item parses
                                 as an http(s) URL. Glyph: Globe (Segoe Fluent Icons E774). -->
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipOpenUrl}"
                                       Command="{Binding OpenInBrowserCommand}"
                                       Visibility="{Binding IsUrlSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <!-- Capture webpage — visible when the row holds a URL AND the
                                 WebView2 Runtime is installed (CanCaptureWebpage). Older Win10
                                 builds without the runtime get the button hidden entirely; the
                                 tray menu offers a "(install runtime)" fallback in that case.
                                 Renders the URL in a hidden WebView2, feeds the PNG into the
                                 webpage-capture pipeline (save / history / copy / upload /
                                 toast). Glyph: ScreenSnapshot (E89E). -->
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       Margin="0,0,0,4"
                                       ToolTip="{Markup:Loc Clipboard_TooltipCaptureWebpage}"
                                       Command="{Binding CaptureWebpageCommand}"
                                       Visibility="{Binding CanCaptureWebpage, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE89E;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                            <ui:Button Width="32" Height="32" Padding="0" Style="{StaticResource ToolbarIconBtn}"
                                       ToolTip="{Markup:Loc Clipboard_TooltipDelete}"
                                       Appearance="Danger"
                                       Command="{Binding DeleteSelectedCommand}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            </ui:Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── Footer hint ─────────────────────────────────────────────────────────── -->
                <TextBlock Grid.Row="2"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11"
                           Text="{Markup:Loc Clipboard_FooterHint}" />
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
