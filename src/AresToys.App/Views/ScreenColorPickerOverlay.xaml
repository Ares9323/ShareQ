<Window x:Class="AresToys.App.Views.ScreenColorPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Markup="clr-namespace:AresToys.App.Markup"
        WindowStyle="None"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Cursor="Cross"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseRightButtonDown="OnMouseRightButtonDown"
        MouseWheel="OnMouseWheel"
        KeyDown="OnKeyDown">
    <Grid>
        <!-- Frozen screenshot of the desktop, captured before the overlay shows. Painted as
             the background so we can drop AllowsTransparency=True (which forces WPF into
             software rendering on a full-screen window — the dominant cause of stutter). -->
        <Image x:Name="ScreenshotImage" Stretch="Fill" />
        <Canvas x:Name="OverlayCanvas">
            <!-- Note: no screen-edge marching-ants crosshair here — ShareX puts it only in
                 the region-capture overlay (where it helps align rect edges) and not in the
                 colour sampler. Adding it on a multi-monitor virtual screen also incurs a
                 visible WPF render-pipeline lag (long lines × dash tessellation) for very
                 marginal benefit when sampling a single pixel. -->

            <!-- Round pixel-picker. Image element (with NearestNeighbor scaling — reliable
                 only on Image, not on ImageBrush) clipped to an ellipse via Image.Clip; the
                 outline ring + centre crosshair sit on top in the same Grid. -->
            <Grid x:Name="MagnifierGroup" Width="140" Height="140">
                <Image x:Name="MagnifierImage"
                       Width="140" Height="140"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       IsHitTestVisible="False">
                    <Image.Clip>
                        <EllipseGeometry Center="70,70" RadiusX="70" RadiusY="70" />
                    </Image.Clip>
                </Image>
                <Ellipse Width="140" Height="140"
                         Stroke="#80FFFFFF" StrokeThickness="1.5"
                         Fill="Transparent"
                         IsHitTestVisible="False" />
                <Rectangle x:Name="MagnifierCrosshair"
                           Stroke="Red" StrokeThickness="1.5"
                           Fill="Transparent"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </Grid>
            <Border x:Name="MagnifierLabelsBorder"
                    Background="#222"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8,4">
                <StackPanel>
                    <TextBlock x:Name="HexLabel"
                               Text="#000000"
                               Foreground="White"
                               FontFamily="Consolas"
                               FontWeight="Bold"
                               FontSize="14"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="RgbLabel"
                               Text="0, 0, 0"
                               Foreground="#AAA"
                               FontFamily="Consolas"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,1,0,0" />
                    <TextBlock x:Name="CoordsLabel"
                               Text="X: 0  Y: 0"
                               Foreground="#AAA"
                               FontFamily="Consolas"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,1,0,0" />
                    <TextBlock x:Name="ZoomLabel"
                               Text="Zoom: 11px"
                               Foreground="#888"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Markup:Loc ScreenColorPicker_Hint}"
                               Foreground="#666"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
